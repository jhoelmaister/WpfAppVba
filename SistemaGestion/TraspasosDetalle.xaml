<UserControl x:Class="SistemaGestion.TraspasosDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>

        <!-- ── Botones con esquinas redondeadas ── -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimario"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"      Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ThemeBtnSecFg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
        </Style>
        <Style x:Key="BtnPeligro" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- ── Input redondeado ── -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height"                   Value="28"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="Padding"                  Value="7,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground"               Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Etiquetas ── -->
        <Style x:Key="LblMuted" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="Foreground"        Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,4,0"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="10,8"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0  Encabezado -->
            <RowDefinition Height="Auto"/>  <!-- 1  Toolbar artículos -->
            <RowDefinition Height="*"/>     <!-- 2  GridItems -->
            <RowDefinition Height="140"/>   <!-- 3  Stock + Observaciones -->
            <RowDefinition Height="Auto"/>  <!-- 4  Totales -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- 0 · ENCABEZADO                                          -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <StackPanel>

                <!-- Fila 1: ícono + título + badge + Guardar/Cancelar -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ícono + título + doc -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                        <Border x:Name="IconoBorde"
                                Width="36" Height="36" CornerRadius="8"
                                Background="#FEF3C7" Margin="0,0,10,0">
                            <TextBlock x:Name="LblIconoTipo"
                                       Text="SA" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#92400E"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="LblTitulo"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTexto}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="Documento "
                                           FontSize="11"
                                           Foreground="{DynamicResource ThemeTextoSec}"/>
                                <TextBlock x:Name="LblDocNum"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThemeTexto}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Badge estado -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="BadgeEstado" CornerRadius="10" Padding="8,3">
                            <TextBlock x:Name="TxtBadgeEstado"
                                       FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Guardar / Cancelar -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnCancelar" Content="Cancelar" Style="{StaticResource BtnSecundario}"
                                Margin="0,0,6,0" Click="BtnCancelar_Click"/>
                        <Button x:Name="BtnGuardar" Content="💾 Guardar"
                                Height="30" Padding="14,0"
                                FontSize="12" FontWeight="SemiBold"
                                Style="{StaticResource BtnPrimario}"
                                Click="BtnGuardar_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Fila 2: campos de cabecera en línea -->
                <Grid x:Name="PanelCamposCabecera">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="134"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="134"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="96"/>
                    </Grid.ColumnDefinitions>

                    <!-- Doc. Traspaso -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Doc. Traspaso" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_DocumentoT" Style="{StaticResource ModernInput}"
                                 PreviewTextInput="Box_Numeros_PreviewTextInput"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <!-- Fecha -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fecha" Style="{StaticResource LblMuted}"/>
                        <DatePicker x:Name="Box_Fecha" Height="28" FontSize="12"
                                    SelectedDateChanged="Campo_DateChanged"/>
                    </StackPanel>

                    <!-- Hora -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Hora" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_Hora" Style="{StaticResource ModernInput}"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <!-- Sucursal: label dinámica encima + combo con todas menos la activa -->
                    <StackPanel Grid.Column="6">
                        <TextBlock x:Name="LblSucursalTipo" Text="Sucursal destino"
                                   Style="{StaticResource LblMuted}"/>
                        <ComboBox x:Name="CboSucursal" Height="28" FontSize="12"
                                  SelectionChanged="CboSucursal_SelectionChanged"/>
                    </StackPanel>

                    <!-- Referencia -->
                    <StackPanel Grid.Column="8">
                        <TextBlock Text="Referencia" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_Referencia" Style="{StaticResource ModernInput}"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <!-- Estado -->
                    <StackPanel Grid.Column="10">
                        <TextBlock Text="Estado" Style="{StaticResource LblMuted}"/>
                        <ComboBox x:Name="Box_Estado" Height="28" FontSize="12"
                                  SelectionChanged="Campo_SelectionChanged">
                            <ComboBoxItem Content="pendiente"/>
                            <ComboBoxItem Content="pendiente revisar"/>
                            <ComboBoxItem Content="entregado"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Tipo -->
                    <StackPanel Grid.Column="12">
                        <TextBlock Text="Movimiento" Style="{StaticResource LblMuted}"/>
                        <ComboBox x:Name="CboMovimiento" Height="28" FontSize="12"
                                  SelectionChanged="CboMovimiento_SelectionChanged">
                            <ComboBoxItem Content="Entrada"/>
                            <ComboBoxItem Content="Salida"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Fila 3: emisión / edición -->
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="Emisión:" Style="{StaticResource LblMuted}"/>
                    <TextBlock x:Name="TxtEmision" FontSize="10"
                               Foreground="{DynamicResource ThemeTexto}"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="Edición:" Style="{StaticResource LblMuted}"/>
                    <TextBlock x:Name="TxtEdicion" FontSize="10"
                               Foreground="{DynamicResource ThemeTexto}"
                               VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- 1 · TOOLBAR ARTÍCULOS                                   -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Artículos del traspaso"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center"/>
                <StackPanel x:Name="PanelBotonesArticulos" Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnImportarArticulos" Content="Importar artículos"
                            Style="{StaticResource BtnPrimario}"
                            Margin="0,0,5,0" Click="BtnImportarArticulos_Click"/>
                    <Button x:Name="BtnBuscarArticulo" Content="Buscar artículo"
                            Style="{StaticResource BtnSecundario}"
                            Margin="0,0,5,0" Click="BtnBuscarArticulo_Click"/>
                    <Button x:Name="BtnInsertar" Content="Insertar"
                            Style="{StaticResource BtnSecundario}"
                            Margin="0,0,5,0" Click="BtnInsertar_Click"/>
                    <Button x:Name="BtnNuevaLinea" Content="Nueva línea"
                            Style="{StaticResource BtnSecundario}"
                            Margin="0,0,5,0" Click="BtnNuevaLinea_Click"/>
                    <Button x:Name="BtnDuplicarLinea" Content="Duplicar"
                            Style="{StaticResource BtnSecundario}"
                            Margin="0,0,5,0" Click="BtnDuplicarLinea_Click"/>
                    <Button x:Name="BtnEliminarLinea" Content="Eliminar línea"
                            Style="{StaticResource BtnPeligro}"
                            Click="BtnEliminarLinea_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- 2 · GRID ARTÍCULOS  +  CATEGORÍAS (derecha)            -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderThickness="0">
            <DataGrid x:Name="GridItems"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="{DynamicResource ThemeBorde}"
                      BorderThickness="0"
                      FontSize="12"
                      RowHeight="32"
                      SelectionChanged="GridItems_SelectionChanged"
                      CellEditEnding="GridItems_CellEditEnding"
                      PreparingCellForEdit="GridItems_PreparingCellForEdit"
                      ScrollViewer.PanningMode="VerticalOnly">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
                        <Setter Property="Foreground"      Value="{DynamicResource ThemeTextoSec}"/>
                        <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding"         Value="8,5"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Lín." Binding="{Binding Linea}"
                                        Width="42" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"        Value="{DynamicResource ThemeTextoSec}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin"            Value="8,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Código"      Binding="{Binding Codigo}"      Width="80"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Cantidad"
                                        Binding="{Binding Cantidad, StringFormat=#\,##0.##}"
                                        Width="86"
                                        ElementStyle="{StaticResource CeldaNumero}"
                                        EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

            <!-- Categorías (a la derecha del grid) -->
            <Border Grid.Column="1"
                    Background="{DynamicResource ThemeBgSurface}"
                    BorderBrush="{DynamicResource ThemeBorde}"
                    BorderThickness="1,0,0,0"
                    Padding="10,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Categorías"
                               Style="{StaticResource SectionHeader}"/>
                    <DataGrid x:Name="GridCategorias"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              FontSize="10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="*"/>
                            <DataGridTextColumn Header="Cant."     Binding="{Binding Cantidad}"  Width="50"
                                                ElementStyle="{StaticResource CeldaNumero}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- 3 · STOCK + OBSERVACIONES (debajo del grid)             -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3"
              Background="{DynamicResource ThemeBgSurface}"
              Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Stock -->
            <DockPanel Grid.Column="0" Margin="14,8,10,8">
                <TextBlock DockPanel.Dock="Top" Text="Stock actual"
                           Style="{StaticResource SectionHeader}"/>
                <Border CornerRadius="6" BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeBorde}" ClipToBounds="True">
                    <DataGrid x:Name="GridStock"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              FontSize="11">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
                                <Setter Property="Foreground"      Value="{DynamicResource ThemeTextoSec}"/>
                                <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding"         Value="6,4"/>
                                <Setter Property="FontSize"        Value="10"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Artículo"  Binding="{Binding Codigo}"     Width="*"/>
                            <DataGridTextColumn Header="Disp."     Binding="{Binding Disponible}" Width="52"
                                                ElementStyle="{StaticResource CeldaNumero}"/>
                            <DataGridTextColumn Header="Stock"     Binding="{Binding Stock}"      Width="52"
                                                ElementStyle="{StaticResource CeldaNumero}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </DockPanel>

            <!-- Separador vertical -->
            <Rectangle Grid.Column="1" Fill="{DynamicResource ThemeBorde}"/>

            <!-- Observaciones -->
            <DockPanel Grid.Column="2" Margin="10,8,14,8">
                <TextBlock DockPanel.Dock="Top" Text="Observaciones"
                           Style="{StaticResource SectionHeader}"/>
                <Border CornerRadius="6" BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeBordeInput}" ClipToBounds="True">
                    <TextBox x:Name="Box_Observaciones" FontSize="12"
                             Padding="7,5"
                             BorderThickness="0"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             TextChanged="Campo_TextChanged"/>
                </Border>
            </DockPanel>
        </Grid>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- 4 · BARRA DE TOTALES                                    -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Total unidades -->
                <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Total unidades" FontSize="10"
                                   Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtTotalUnidades"
                                   FontSize="17" FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource ThemeTexto}"/>
                    </StackPanel>
                </Border>

                <!-- Diferentes -->
                <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Diferentes" FontSize="10"
                                   Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtUnidadesDiferentes"
                                   FontSize="17" FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource ThemeTexto}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
