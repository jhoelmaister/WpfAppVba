<Window x:Class="WpfAppVba.SucursalesDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sucursal" Height="550" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F2F5"
        Closing="Window_Closing">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock x:Name="LblTitulo" Grid.Row="0" FontSize="15" FontWeight="Bold"
                   Foreground="#1A1A2E" Margin="0,0,0,12"/>

        <!-- Campos -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="Código:" FontSize="11" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Codigo" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="#CCC" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"/>

                <TextBlock Text="NIT:" FontSize="11" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Nit" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="#CCC" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"
                         PreviewTextInput="Box_Nit_PreviewTextInput"/>

                <TextBlock Text="Descripción:" FontSize="11" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Descripcion" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="#CCC" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"
                         PreviewTextInput="Box_Descripcion_PreviewTextInput"/>

                <TextBlock Text="Región (Código):" FontSize="11" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Referido_Codigo" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="#CCC" Margin="0,0,0,4"
                         TextChanged="Box_Referido_Codigo_TextChanged"
                         PreviewTextInput="Box_Referido_Codigo_PreviewTextInput"/>
                <TextBlock x:Name="Box_Referido_Descripcion" FontSize="11" Foreground="#777"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Teléfono:" FontSize="11" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Telefono" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="#CCC" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"
                         PreviewTextInput="Box_Telefono_PreviewTextInput"/>

                <TextBlock Text="Dirección:" FontSize="11" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Direccion" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="#CCC" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"/>

                <TextBlock Text="Fecha:" FontSize="11" Foreground="#555" Margin="0,0,0,2"/>
                <DatePicker x:Name="Box_Fecha" Height="30" FontSize="12"
                            BorderBrush="#CCC" Margin="0,0,0,8"
                            SelectedDateChanged="Box_Fecha_SelectedDateChanged"/>

                <TextBlock Text="Observaciones:" FontSize="11" Foreground="#555" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Observacion" Height="70" FontSize="12" Padding="6,4"
                         BorderBrush="#CCC" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
