<UserControl x:Class="WpfAppVba.SucursalesDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LblTitulo" Grid.Row="0" FontSize="15" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Código -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Código:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="Box_Codigo"
                         Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}"
                         Margin="0,0,0,10" MaxWidth="180" HorizontalAlignment="Left"
                         TextChanged="Campo_TextChanged"/>

                <!-- NIT -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="NIT:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="Box_Nit"
                         Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}"
                         Margin="0,0,0,10" MaxWidth="200" HorizontalAlignment="Left"
                         TextChanged="Campo_TextChanged"
                         PreviewTextInput="Box_Nit_PreviewTextInput"/>

                <!-- Descripción -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Descripción:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="Box_Descripcion"
                         Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,10"
                         TextChanged="Campo_TextChanged"/>

                <!-- Región (selector) -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Región:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="Box_Referido_Codigo" Grid.Column="0"
                             Height="30" FontSize="12" Padding="6,4"
                             BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,6,0"
                             TextChanged="Box_Referido_Codigo_TextChanged"
                             PreviewTextInput="Box_Referido_Codigo_PreviewTextInput"/>
                    <TextBlock x:Name="Box_Referido_Descripcion" Grid.Column="1"
                               FontSize="11" Foreground="{DynamicResource ThemeTextoMuted}"
                               VerticalAlignment="Center" Margin="0,0,6,0" TextTrimming="CharacterEllipsis"/>
                    <Button x:Name="BtnVerRegiones" Grid.Column="2"
                            Content="Ver Regiones" Height="30" Padding="10,0" FontSize="11"
                            BorderThickness="0" Cursor="Hand"
                            Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                            Click="BtnVerRegiones_Click"/>
                </Grid>

                <!-- Teléfono -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Teléfono:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="Box_Telefono"
                         Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}"
                         Margin="0,0,0,10" MaxWidth="180" HorizontalAlignment="Left"
                         TextChanged="Campo_TextChanged"
                         PreviewTextInput="Box_Telefono_PreviewTextInput"/>

                <!-- Dirección -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Dirección:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="Box_Direccion"
                         Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,10"
                         TextChanged="Campo_TextChanged"/>

                <!-- Fecha + Hora inline -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Fecha:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <DatePicker x:Name="Box_Fecha" Width="160" Height="30" FontSize="12"
                                BorderBrush="{DynamicResource ThemeBordeInput}"
                                SelectedDateChanged="Box_Fecha_SelectedDateChanged"/>
                    <TextBlock Text="Hora:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                               VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <TextBox x:Name="Box_Hora" Width="90" Height="30" FontSize="12" Padding="6,4"
                             BorderBrush="{DynamicResource ThemeBordeInput}"
                             TextChanged="Campo_TextChanged"/>
                </StackPanel>

                <!-- Separador -->
                <Separator Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                           Background="{DynamicResource ThemeBorde}" Margin="0,0,0,10"/>

                <!-- Observaciones -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Observaciones:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Top" Margin="0,7,8,0"/>
                <TextBox Grid.Row="8" Grid.Column="1" x:Name="Box_Observacion"
                         Height="80" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         TextChanged="Campo_TextChanged"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Guardar" Height="32" Padding="14,0" FontSize="12"
                    Background="#1A73E8" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                    Click="BtnGuardar_Click"/>
            <Button Content="Cancelar" Height="32" Padding="14,0" FontSize="12"
                    Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
