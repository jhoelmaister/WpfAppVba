<UserControl x:Class="WpfAppVba.SucursalesDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="CaretBrush" Value="#4F8EF7"/>
        </Style>
        <Style x:Key="SelectorBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4F8EF7"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ ENCABEZADO ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="36" Height="36" CornerRadius="8"
                        Background="#1A3A6B" Margin="0,0,12,0">
                    <TextBlock Text="&#x1F3E2;" FontSize="18" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="LblTitulo" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTexto}"/>
                    <TextBlock Text="Gestión de Sucursales" FontSize="11"
                               Foreground="{DynamicResource ThemeTextoSec}" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ CONTENIDO ══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,0">
            <StackPanel>

                <!-- ▸ CARD: IDENTIFICACIÓN -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● IDENTIFICACIÓN"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="CÓDIGO"/>
                                <TextBox x:Name="Box_Codigo" Style="{StaticResource ModernInput}"
                                         TextChanged="Campo_TextChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="NIT"/>
                                <TextBox x:Name="Box_Nit" Style="{StaticResource ModernInput}"
                                         TextChanged="Campo_TextChanged"
                                         PreviewTextInput="Box_Nit_PreviewTextInput"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ▸ CARD: INFORMACIÓN -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● INFORMACIÓN"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource SectionLabel}" Text="DESCRIPCIÓN"/>
                            <TextBox x:Name="Box_Descripcion" Style="{StaticResource ModernInput}"
                                     TextChanged="Campo_TextChanged"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="DIRECCIÓN"/>
                                <TextBox x:Name="Box_Direccion" Style="{StaticResource ModernInput}"
                                         TextChanged="Campo_TextChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="TELÉFONO"/>
                                <TextBox x:Name="Box_Telefono" Style="{StaticResource ModernInput}"
                                         TextChanged="Campo_TextChanged"
                                         PreviewTextInput="Box_Telefono_PreviewTextInput"/>
                            </StackPanel>
                        </Grid>

                        <!-- Fecha + Hora -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="FECHA"/>
                                <DatePicker x:Name="Box_Fecha" Height="36" FontSize="13"
                                            VerticalContentAlignment="Center"
                                            SelectedDateChanged="Box_Fecha_SelectedDateChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="HORA"/>
                                <TextBox x:Name="Box_Hora" Style="{StaticResource ModernInput}"
                                         TextChanged="Campo_TextChanged"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ▸ CARD: REGIÓN -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● REGIÓN"/>

                        <TextBlock Style="{StaticResource SectionLabel}" Text="REGIÓN"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="Box_Referido_Codigo" Grid.Column="0"
                                     Style="{StaticResource ModernInput}"
                                     TextChanged="Box_Referido_Codigo_TextChanged"
                                     PreviewTextInput="Box_Referido_Codigo_PreviewTextInput"/>
                            <Border Grid.Column="2" CornerRadius="6"
                                    Background="{DynamicResource ThemeBgReadOnly}" Padding="10,0">
                                <TextBlock x:Name="Box_Referido_Descripcion"
                                           VerticalAlignment="Center" FontSize="12"
                                           Foreground="{DynamicResource ThemeTextoMuted}"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <Button x:Name="BtnVerRegiones" Grid.Column="4"
                                    Style="{StaticResource SelectorBtn}"
                                    Content="&#x1F50D; Regiones"
                                    Click="BtnVerRegiones_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ▸ CARD: OBSERVACIONES -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● OBSERVACIONES"/>
                        <TextBox x:Name="Box_Observacion"
                                 MinHeight="80" FontSize="13" Padding="10,8"
                                 BorderBrush="{DynamicResource ThemeBordeInput}"
                                 BorderThickness="0,0,0,2"
                                 Background="{DynamicResource ThemeInputBg}"
                                 Foreground="{DynamicResource ThemeTexto}"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>
                </Border>

                <Rectangle Height="16"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ══ BARRA DE ACCIONES ══════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,1,0,0"
                Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar"
                        Height="36" Padding="18,0" FontSize="13"
                        Background="{DynamicResource ThemeBtnSecBg}"
                        Foreground="{DynamicResource ThemeBtnSecFg}"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                        Click="BtnCancelar_Click"/>
                <Button Content="&#x1F4BE; Guardar"
                        Height="36" Padding="18,0" FontSize="13" FontWeight="SemiBold"
                        Background="#1A73E8" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnGuardar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
