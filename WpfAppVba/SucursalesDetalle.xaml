<Window x:Class="WpfAppVba.SucursalesDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sucursal" Height="550" Width="420"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource ThemeBgPrincipal}"
        Closing="Window_Closing">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock x:Name="LblTitulo" Grid.Row="0" FontSize="15" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,12"/>

        <!-- Campos -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="Código:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Codigo" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"/>

                <TextBlock Text="NIT:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Nit" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"
                         PreviewTextInput="Box_Nit_PreviewTextInput"/>

                <TextBlock Text="Descripción:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Descripcion" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"/>

                <TextBlock Text="Región (Código):" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="Box_Referido_Codigo" Grid.Column="0" Height="30" FontSize="12" Padding="6,4"
                             BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,6,0"
                             TextChanged="Box_Referido_Codigo_TextChanged"
                             PreviewTextInput="Box_Referido_Codigo_PreviewTextInput"/>
                    <TextBlock x:Name="Box_Referido_Descripcion" Grid.Column="1" FontSize="11"
                               Foreground="{DynamicResource ThemeTextoMuted}"
                               VerticalAlignment="Center" Margin="0,0,6,0" TextTrimming="CharacterEllipsis"/>
                    <Button x:Name="BtnVerRegiones" Grid.Column="2" Content="Ver Regiones" Height="30" Padding="8,0"
                            FontSize="11" BorderThickness="0" Cursor="Hand"
                            Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                            Click="BtnVerRegiones_Click"/>
                </Grid>

                <TextBlock Text="Teléfono:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Telefono" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"
                         PreviewTextInput="Box_Telefono_PreviewTextInput"/>

                <TextBlock Text="Dirección:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Direccion" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Fecha:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                        <DatePicker x:Name="Box_Fecha" Height="30" FontSize="12"
                                    BorderBrush="{DynamicResource ThemeBordeInput}"
                                    SelectedDateChanged="Box_Fecha_SelectedDateChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Hora (HH:mm:ss):" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                        <TextBox x:Name="Box_Hora" Height="30" FontSize="12" Padding="6,4"
                                 BorderBrush="{DynamicResource ThemeBordeInput}"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Observaciones:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Observacion" Height="70" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Botones -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Guardar" Height="32" Padding="14,0" FontSize="12"
                    Background="{DynamicResource ThemeAcento}" Foreground="White"
                    BorderThickness="0" Margin="0,0,8,0"
                    Click="BtnGuardar_Click"/>
            <Button Content="Cancelar" Height="32" Padding="14,0" FontSize="12"
                    Background="{DynamicResource ThemeBgSecundario}" Foreground="{DynamicResource ThemeTexto}"
                    BorderThickness="0"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
