<UserControl x:Class="WpfAppVba.InventariosGeneral"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Inventarios de Apertura" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,10"/>

        <!-- DataGrid -->
        <Border Grid.Row="1" CornerRadius="6" ClipToBounds="True"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                Background="{DynamicResource ThemeBgSurface}">
        <DataGrid x:Name="Grid1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  FontSize="12"
                  MouseDoubleClick="Grid1_MouseDoubleClick"
                  PreviewKeyDown="Grid1_PreviewKeyDown">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"        Width="60"/>
                <DataGridTextColumn Header="DocumentoI"  Binding="{Binding Id}"           Width="90"/>
                <DataGridTextColumn Header="Fecha"       Binding="{Binding FechaStr}"     Width="*"/>
                <DataGridTextColumn Header="Cant. Total" Binding="{Binding CantidadTotal, StringFormat=#\,##0.##}" Width="100"
                                    ElementStyle="{StaticResource CeldaNumero}"/>
            </DataGrid.Columns>
        </DataGrid>
        </Border>

        <!-- Nota -->
        <TextBlock Grid.Row="2" Margin="0,6,0,0" FontSize="11" Foreground="{DynamicResource ThemeTextoMuted}"
                   Text="Solo se puede editar/eliminar la apertura más reciente."/>

        <!-- Botones -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Nuevo Inventario"    Margin="0,0,6,0" Background="#1A73E8" Foreground="White"   Click="BtnNuevo_Click"    Style="{StaticResource Btn}"/>
            <Button Content="Editar Inventario"   Margin="0,0,6,0" Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeTexto}" Click="BtnEditar_Click"   Style="{StaticResource Btn}"/>
            <Button Content="Eliminar Inventario" Margin="0,0,0,0" Background="#D93025" Foreground="White"   Click="BtnEliminar_Click" Style="{StaticResource Btn}"/>
        </StackPanel>
    </Grid>
</UserControl>
