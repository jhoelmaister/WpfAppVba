<UserControl x:Class="WpfAppVba.CorreccionesGeneral"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Correcciones de Stock" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,10"/>

        <!-- Filtros + búsqueda -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Movimiento:" FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,6,0"/>
                <ComboBox x:Name="CboFiltroMovimiento" Width="130" Height="28" FontSize="12"
                          SelectionChanged="CboFiltroMovimiento_SelectionChanged">
                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                    <ComboBoxItem Content="descontar"/>
                    <ComboBoxItem Content="ingresar"/>
                </ComboBox>
            </StackPanel>

            <TextBox x:Name="TxtBuscar" Grid.Column="2" Width="220" Height="28" FontSize="12"
                     Padding="6,4" VerticalContentAlignment="Center"
                     BorderBrush="{DynamicResource ThemeBordeInput}"
                     KeyDown="TxtBuscar_KeyDown"/>
            <Button Grid.Column="3" Content="Buscar" Margin="6,0,0,0"
                    Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeTexto}"
                    Click="BtnBuscar_Click" Style="{StaticResource Btn}"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid x:Name="Grid1" Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                  FontSize="12"
                  MouseDoubleClick="Grid1_MouseDoubleClick"
                  PreviewKeyDown="Grid1_PreviewKeyDown">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"      Width="55"/>
                <DataGridTextColumn Header="DocumentoC"  Binding="{Binding Id}"         Width="90"/>
                <DataGridTextColumn Header="Fecha"       Binding="{Binding FechaStr}"   Width="*"/>
                <DataGridTextColumn Header="Movimiento"  Binding="{Binding Movimiento}" Width="100"/>
                <DataGridTextColumn Header="Motivo"      Binding="{Binding Motivo}"     Width="140"/>
                <DataGridTextColumn Header="Cant. Total" Binding="{Binding CantidadTotal, StringFormat=#\,##0.##}" Width="100"
                                    ElementStyle="{StaticResource CeldaNumero}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Nota -->
        <TextBlock Grid.Row="3" Margin="0,6,0,0" FontSize="11" Foreground="{DynamicResource ThemeTextoMuted}"
                   Text="Descontar resta del stock (pérdida, merma, hurto, consumo interno). Ingresar suma al stock (error de registro, registros omitidos)."/>

        <!-- Botones -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Nuevo"    Margin="0,0,6,0" Background="#1A73E8" Foreground="White"   Click="BtnNuevo_Click"    Style="{StaticResource Btn}"/>
            <Button Content="Editar"   Margin="0,0,6,0" Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeTexto}" Click="BtnEditar_Click"   Style="{StaticResource Btn}"/>
            <Button Content="Eliminar" Margin="0,0,0,0" Background="#D93025" Foreground="White"   Click="BtnEliminar_Click" Style="{StaticResource Btn}"/>
        </StackPanel>
    </Grid>
</UserControl>
