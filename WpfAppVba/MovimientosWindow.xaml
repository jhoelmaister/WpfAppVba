<Window x:Class="WpfAppVba.MovimientosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movimientos de Artículo" Height="600" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#E8EDF5"/>
            <Setter Property="Foreground" Value="#5F6368"/>
        </Style>

        <!-- Estilo columnas numéricas -->
        <Style x:Key="CeldaDerecha" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Búsqueda + descripción -->
            <RowDefinition Height="*"/>       <!-- DataGrid -->
            <RowDefinition Height="Auto"/>    <!-- Totales -->
            <RowDefinition Height="Auto"/>    <!-- Botón procesar -->
        </Grid.RowDefinitions>

        <!-- ── Búsqueda ──────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Código:" VerticalAlignment="Center"
                       FontSize="12" Foreground="#555" Margin="0,0,6,0"/>
            <TextBox x:Name="TxtCodigo" Grid.Row="0" Grid.Column="1" Height="30" FontSize="12"
                     Padding="6,4" BorderBrush="#CCC" Margin="0,0,6,0"
                     KeyDown="TxtCodigo_KeyDown"/>
            <Button Grid.Row="0" Grid.Column="2" Content="Buscar"
                    Style="{StaticResource BtnPrimario}" Margin="0,0,12,0"
                    Click="BtnBuscar_Click"/>
            <TextBlock x:Name="LblDescripcion" Grid.Row="0" Grid.Column="3"
                       VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                       Foreground="#1A1A2E" TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- ── DataGrid ──────────────────────────────────────── -->
        <DataGrid x:Name="Grid1" Grid.Row="1"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#DDD" BorderThickness="1"
                  FontSize="11">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Línea"      Binding="{Binding Linea}"       Width="50"/>
                <DataGridTextColumn Header="Fecha"      Binding="{Binding FechaStr}"     Width="130"/>
                <DataGridTextColumn Header="Movimiento" Binding="{Binding Movimiento}"   Width="130"/>
                <DataGridTextColumn Header="Estado"     Binding="{Binding Estado}"       Width="100"/>
                <DataGridTextColumn Header="Forma"      Binding="{Binding Forma}"        Width="70"/>
                <DataGridTextColumn Header="Contable"   Binding="{Binding Contable}"     Width="70"/>
                <DataGridTextColumn Header="Cantidad"   Binding="{Binding Cantidad}"     Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Unitario"   Binding="{Binding Unitario}"     Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="SubTotal"   Binding="{Binding SubTotal}"     Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Stock"      Binding="{Binding Stock}"        Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Totales ───────────────────────────────────────── -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="1"
                CornerRadius="4" Margin="0,8,0,0" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Total Compras:"  FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalCompras" FontSize="12" FontWeight="Bold" Foreground="#1A73E8" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Total Ventas:"   FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalVentas"  FontSize="12" FontWeight="Bold" Foreground="#D93025" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Total Entradas:" FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalEntradas" FontSize="12" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Total Salidas:"  FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalSalidas" FontSize="12" FontWeight="Bold" Foreground="#E65100" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Botón Procesar ────────────────────────────────── -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Procesar / Actualizar" Style="{StaticResource BtnSecundario}"
                    Click="BtnProcesar_Click"/>
        </StackPanel>
    </Grid>
</Window>
