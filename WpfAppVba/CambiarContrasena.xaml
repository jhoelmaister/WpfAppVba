<Window x:Class="WpfAppVba.CambiarContrasena"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cambiar Contraseña" Height="320" Width="380"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="{DynamicResource ThemeBgPrincipal}">

    <Window.Resources>

        <Style x:Key="ModernPassword" TargetType="PasswordBox">
            <Setter Property="Height"                   Value="32"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground"               Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Background"      Value="#1A73E8"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Cambiar Contraseña" FontSize="15" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,18"/>

        <!-- Campos -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Contraseña Actual:" FontSize="11"
                           Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PwdActual" Style="{StaticResource ModernPassword}"
                             Margin="0,0,0,14"/>

                <TextBlock Text="Nueva Contraseña:" FontSize="11"
                           Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PwdNueva" Style="{StaticResource ModernPassword}"
                             Margin="0,0,0,14"/>

                <TextBlock Text="Confirmar Nueva Contraseña:" FontSize="11"
                           Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PwdConfirmar" Style="{StaticResource ModernPassword}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Botón -->
        <Button Grid.Row="2" Content="Guardar Contraseña"
                Style="{StaticResource BtnPrimario}"
                Margin="0,18,0,0"
                Click="BtnGuardar_Click"/>
    </Grid>
</Window>
