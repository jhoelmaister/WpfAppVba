<Window x:Class="WpfAppVba.CambiarContrasena"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cambiar Contraseña" Height="320" Width="380"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="{DynamicResource ThemeBgPrincipal}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Cambiar Contraseña" FontSize="15" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,18"/>

        <!-- Campos -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Contraseña Actual:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <PasswordBox x:Name="PwdActual" Height="30" FontSize="12"
                             Padding="6,4" BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,12"/>

                <TextBlock Text="Nueva Contraseña:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <PasswordBox x:Name="PwdNueva" Height="30" FontSize="12"
                             Padding="6,4" BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,12"/>

                <TextBlock Text="Confirmar Nueva Contraseña:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <PasswordBox x:Name="PwdConfirmar" Height="30" FontSize="12"
                             Padding="6,4" BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Botón -->
        <Button Grid.Row="2" Content="Guardar Contraseña"
                Height="34" FontSize="13" FontWeight="SemiBold"
                Background="#1A73E8" Foreground="White"
                BorderThickness="0" Cursor="Hand"
                Margin="0,18,0,0"
                Click="BtnGuardar_Click"/>
    </Grid>
</Window>
