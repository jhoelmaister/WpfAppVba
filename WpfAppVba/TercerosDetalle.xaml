<UserControl x:Class="WpfAppVba.TercerosDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LblTitulo" Grid.Row="0" FontSize="15" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Código -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Código:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="Box_Codigo"
                         Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}"
                         Margin="0,0,0,10" MaxWidth="180" HorizontalAlignment="Left"
                         TextChanged="Campo_TextChanged"/>

                <!-- NIT -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="NIT:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="Box_Nit"
                         Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}"
                         Margin="0,0,0,10" MaxWidth="200" HorizontalAlignment="Left"
                         TextChanged="Campo_TextChanged"
                         PreviewTextInput="Box_Nit_PreviewTextInput"/>

                <!-- Descripción -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Descripción:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="Box_Descripcion"
                         Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,10"
                         TextChanged="Campo_TextChanged"/>

                <!-- Contacto + Teléfono en la misma fila -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Contacto:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="Box_Contacto" Grid.Column="0"
                             Height="30" FontSize="12" Padding="6,4"
                             BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,8,0"
                             TextChanged="Campo_TextChanged"/>
                    <TextBlock Grid.Column="1" Text="Teléfono:"
                               FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="Box_Telefono" Grid.Column="2"
                             Height="30" FontSize="12" Padding="6,4"
                             BorderBrush="{DynamicResource ThemeBordeInput}"
                             TextChanged="Campo_TextChanged"
                             PreviewTextInput="Box_Telefono_PreviewTextInput"/>
                </Grid>

                <!-- Dirección -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Dirección:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="Box_Direccion"
                         Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,10"
                         TextChanged="Campo_TextChanged"/>

                <!-- Contacto 2 + Teléfono 2 en la misma fila -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Contacto 2:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <Grid Grid.Row="5" Grid.Column="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="Box_Contacto2" Grid.Column="0"
                             Height="30" FontSize="12" Padding="6,4"
                             BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,8,0"
                             TextChanged="Campo_TextChanged"/>
                    <TextBlock Grid.Column="1" Text="Teléfono 2:"
                               FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="Box_Telefono2" Grid.Column="2"
                             Height="30" FontSize="12" Padding="6,4"
                             BorderBrush="{DynamicResource ThemeBordeInput}"
                             TextChanged="Campo_TextChanged"
                             PreviewTextInput="Box_Telefono_PreviewTextInput"/>
                </Grid>

                <!-- Observaciones (separador visual antes) -->
                <Separator Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                           Background="{DynamicResource ThemeBorde}" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Observaciones:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Top" Margin="0,7,8,0"/>
                <TextBox Grid.Row="7" Grid.Column="1" x:Name="Box_Observacion"
                         Height="80" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         TextChanged="Campo_TextChanged"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Guardar" Height="32" Padding="14,0" FontSize="12"
                    Background="#1A73E8" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                    Click="BtnGuardar_Click"/>
            <Button Content="Cancelar" Height="32" Padding="14,0" FontSize="12"
                    Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
