<UserControl x:Class="WpfAppVba.Configuracion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="LblEtiqueta" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="CajaLectura" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBgReadOnly}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
        </Style>
        <Style x:Key="CajaEditable" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <!-- Encabezado de sección -->
        <Style x:Key="LblSeccion" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Título -->
            <RowDefinition Height="*"/>     <!-- Campos -->
            <RowDefinition Height="Auto"/>  <!-- Botón -->
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Configuración" FontSize="15" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,14"/>

        <!-- Campos -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ══ Sección: General ══════════════════════════════════════ -->
                <TextBlock Text="General" Style="{StaticResource LblSeccion}"/>
                <Separator Background="{DynamicResource ThemeBorde}" Margin="0,0,0,10"/>

                <!-- Tema -->
                <TextBlock Text="Tema:" Style="{StaticResource LblEtiqueta}"/>
                <ComboBox x:Name="CmbTema" Height="30" FontSize="12"
                          Padding="4,0" Margin="0,0,0,10"
                          SelectionChanged="CmbTema_SelectionChanged">
                    <ComboBoxItem Content="claro"/>
                    <ComboBoxItem Content="oscuro"/>
                </ComboBox>

                <!-- Botón Guardar (solo el tema) -->
                <Button x:Name="BtnGuardarTema" Content="Guardar Cambios"
                        Height="30" FontSize="12" FontWeight="SemiBold"
                        Background="#1A73E8" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Left" Padding="14,0"
                        Margin="0,0,0,10"
                        Click="BtnGuardarTema_Click"/>

                <!-- ══ Sección: Conexión SQL Server ══════════════════════════ -->
                <TextBlock Text="Conexión SQL Server" Style="{StaticResource LblSeccion}"/>
                <Separator Background="{DynamicResource ThemeBorde}" Margin="0,0,0,10"/>

                <TextBlock Text="Servidor:" Style="{StaticResource LblEtiqueta}"/>
                <TextBox x:Name="TxtConServidor" Style="{StaticResource CajaEditable}"/>

                <TextBlock Text="Base de datos:" Style="{StaticResource LblEtiqueta}"/>
                <TextBox x:Name="TxtConBaseDatos" Style="{StaticResource CajaEditable}"/>

                <TextBlock Text="Usuario SQL:" Style="{StaticResource LblEtiqueta}"/>
                <TextBox x:Name="TxtConUsuario" Style="{StaticResource CajaEditable}"/>

                <TextBlock Text="Contraseña:" Style="{StaticResource LblEtiqueta}"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="PwdConContrasena" Grid.Column="0" Height="30" FontSize="12" Padding="6,4"
                                 BorderBrush="{DynamicResource ThemeBordeInput}"/>
                    <TextBox x:Name="TxtConContrasenaVisible" Grid.Column="0" Height="30" FontSize="12" Padding="6,4"
                             BorderBrush="{DynamicResource ThemeBordeInput}" Visibility="Collapsed"/>
                    <Button x:Name="BtnMostrarConPwd" Grid.Column="1" Content="Ver" Width="50" Height="30"
                            FontSize="11"
                            Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                            BorderThickness="0" Cursor="Hand" Margin="6,0,0,0"
                            Click="BtnMostrarConPwd_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="BtnProbarConexion" Content="Probar conexión"
                            Height="30" FontSize="12" Padding="12,0"
                            Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                            Click="BtnProbarConexion_Click"/>
                    <Button x:Name="BtnGuardarConexion" Content="Guardar conexión"
                            Height="30" FontSize="12" FontWeight="SemiBold" Padding="12,0"
                            Background="#1A73E8" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnGuardarConexion_Click"/>
                </StackPanel>

                <!-- ══ Sección: Mi Cuenta ════════════════════════════════════ -->
                <TextBlock Text="Mi Cuenta" Style="{StaticResource LblSeccion}"/>
                <Separator Background="{DynamicResource ThemeBorde}" Margin="0,0,0,10"/>

                <!-- Cuenta (solo lectura) -->
                <TextBlock Text="Cuenta:" Style="{StaticResource LblEtiqueta}"/>
                <TextBox x:Name="TxtCuenta" Style="{StaticResource CajaLectura}"/>

                <!-- Nombres -->
                <TextBlock Text="Nombres:" Style="{StaticResource LblEtiqueta}"/>
                <TextBox x:Name="TxtNombres" Style="{StaticResource CajaEditable}"/>

                <!-- Apellidos -->
                <TextBlock Text="Apellidos:" Style="{StaticResource LblEtiqueta}"/>
                <TextBox x:Name="TxtApellidos" Style="{StaticResource CajaEditable}"/>

                <!-- Sucursal Activa -->
                <TextBlock Text="Sucursal Activa:" Style="{StaticResource LblEtiqueta}"/>
                <ComboBox x:Name="CmbSucursal" Height="30" FontSize="12"
                          Padding="4,0" Margin="0,0,0,10"
                          DisplayMemberPath="Descripcion"
                          SelectionChanged="CmbSucursal_SelectionChanged"/>

                <!-- Inicio de Sucursal (solo lectura) -->
                <TextBlock Text="Inicio de Sucursal:" Style="{StaticResource LblEtiqueta}"/>
                <TextBox x:Name="TxtFechaInicio" Style="{StaticResource CajaLectura}"/>

                <!-- Periodo Activo -->
                <TextBlock Text="Periodo Activo:" Style="{StaticResource LblEtiqueta}"/>
                <ComboBox x:Name="CmbPeriodo" Height="30" FontSize="12"
                          Padding="4,0" Margin="0,0,0,10"/>

                <!-- Tipo de Usuario (solo lectura) -->
                <TextBlock Text="Tipo de Usuario:" Style="{StaticResource LblEtiqueta}"/>
                <TextBox x:Name="TxtTipo" Style="{StaticResource CajaLectura}"/>

                <!-- Botón Cambiar Contraseña -->
                <Button x:Name="BtnCambiarContrasena" Content="🔑 Cambiar Contraseña"
                        Height="30" FontSize="12" Padding="12,0"
                        Background="#5C6BC0" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Left" Margin="0,6,0,10"
                        Click="BtnCambiarContrasena_Click"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Botón Guardar -->
        <Button Grid.Row="2" x:Name="BtnGuardar" Content="Guardar Cambios"
                Height="34" FontSize="13" FontWeight="SemiBold"
                Background="#1A73E8" Foreground="White"
                BorderThickness="0" Cursor="Hand"
                Margin="0,10,0,0"
                Click="BtnGuardar_Click"/>
    </Grid>
</UserControl>
