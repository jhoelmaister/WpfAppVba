<UserControl x:Class="WpfAppVba.Configuracion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="CaretBrush" Value="#4F8EF7"/>
        </Style>
        <Style x:Key="ReadOnlyInput" TargetType="TextBox" BasedOn="{StaticResource ModernInput}">
            <Setter Property="Background" Value="{DynamicResource ThemeBgReadOnly}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsEnabled" Value="False"/>
        </Style>
        <Style x:Key="ModernCombo" TargetType="ComboBox"
               BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        <Style x:Key="ServerListItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="4,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeFilaSeleccionada}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeBgReadOnly}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ServerListHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorde}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4F8EF7"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ ENCABEZADO ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="36" Height="36" CornerRadius="8"
                        Background="#1A3A6B" Margin="0,0,12,0">
                    <TextBlock Text="&#x2699;" FontSize="18" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Foreground="White"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Configuración" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTexto}"/>
                    <TextBlock Text="Preferencias, conexiones y cuenta" FontSize="11"
                               Foreground="{DynamicResource ThemeTextoSec}" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ CONTENIDO ══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ▸ CARD: MI CUENTA (fila 0) -->
                <Border Style="{StaticResource CardBorder}"
                        Grid.Column="0" Grid.Row="0" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● MI CUENTA"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="CUENTA"/>
                                <TextBox x:Name="TxtCuenta" Style="{StaticResource ReadOnlyInput}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="TIPO DE USUARIO"/>
                                <TextBox x:Name="TxtTipo" Style="{StaticResource ReadOnlyInput}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="NOMBRES"/>
                                <TextBox x:Name="TxtNombres" Style="{StaticResource ModernInput}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="APELLIDOS"/>
                                <TextBox x:Name="TxtApellidos" Style="{StaticResource ModernInput}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="EMPRESA ACTIVA"/>
                                <ComboBox x:Name="CmbEmpresa" Style="{StaticResource ModernCombo}"
                                          DisplayMemberPath="Descripcion"
                                          SelectionChanged="CmbEmpresa_SelectionChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="SUCURSAL ACTIVA"/>
                                <ComboBox x:Name="CmbSucursal" Style="{StaticResource ModernCombo}"
                                          DisplayMemberPath="Descripcion"
                                          SelectionChanged="CmbSucursal_SelectionChanged"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="INICIO DE SUCURSAL"/>
                                <TextBox x:Name="TxtFechaInicio" Style="{StaticResource ReadOnlyInput}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="PERIODO ACTIVO"/>
                                <ComboBox x:Name="CmbPeriodo" Style="{StaticResource ModernCombo}"/>
                            </StackPanel>
                        </Grid>

                        <Button x:Name="BtnGuardar" Content="&#x1F4BE; Guardar Cambios"
                                Height="34" FontSize="12" FontWeight="SemiBold" Padding="14,0"
                                Background="#1A73E8" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Left"
                                Click="BtnGuardar_Click"/>
                    </StackPanel>
                </Border>

                <Rectangle Height="16" Grid.Column="0" Grid.Row="1"/>
            </Grid>
        </ScrollViewer>

        <!-- ══ BARRA DE ACCIONES ══════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,1,0,0"
                Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnRegenerarCodigos" Content="🔢 Regenerar códigos"
                        Height="36" FontSize="13" FontWeight="SemiBold" Padding="18,0"
                        Background="#6A1B9A" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                        Click="BtnRegenerarCodigos_Click"/>
                <Button x:Name="BtnRecalcularPrecios" Content="💲 Recalcular precios"
                        Height="36" FontSize="13" FontWeight="SemiBold" Padding="18,0"
                        Background="#EF6C00" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                        Click="BtnRecalcularPrecios_Click"/>
                <Button x:Name="BtnSincronizarAppsheets" Content="🧾 Sincronizar AppSheets"
                        Height="36" FontSize="13" FontWeight="SemiBold" Padding="18,0"
                        Background="#2E7D32" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                        Click="BtnSincronizarAppsheets_Click"/>
                <Button x:Name="BtnCambiarContrasena" Content="🔑 Cambiar Contraseña"
                        Height="36" FontSize="13" FontWeight="SemiBold" Padding="18,0"
                        Background="#5C6BC0" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnCambiarContrasena_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
