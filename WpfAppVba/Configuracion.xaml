<UserControl x:Class="WpfAppVba.Configuracion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="CaretBrush" Value="#4F8EF7"/>
        </Style>
        <Style x:Key="ReadOnlyInput" TargetType="TextBox" BasedOn="{StaticResource ModernInput}">
            <Setter Property="Background" Value="{DynamicResource ThemeBgReadOnly}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsEnabled" Value="False"/>
        </Style>
        <Style x:Key="ModernCombo" TargetType="ComboBox"
               BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        <Style x:Key="ServerListItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="4,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeFilaSeleccionada}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeBgReadOnly}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ServerListHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorde}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style x:Key="SelectorBtn" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4F8EF7"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ ENCABEZADO ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="36" Height="36" CornerRadius="8"
                        Background="#1A3A6B" Margin="0,0,12,0">
                    <TextBlock Text="&#x2699;" FontSize="18" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Foreground="White"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Configuración" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTexto}"/>
                    <TextBlock Text="Preferencias, conexiones y cuenta" FontSize="11"
                               Foreground="{DynamicResource ThemeTextoSec}" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ CONTENIDO ══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ▸ CARD: GENERAL (columna izquierda, fila 0) -->
                <Border Style="{StaticResource CardBorder}"
                        Grid.Column="0" Grid.Row="0" Margin="0,0,6,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● GENERAL"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="TEMA"/>
                                <ComboBox x:Name="CmbTema" Style="{StaticResource ModernCombo}"
                                          SelectionChanged="CmbTema_SelectionChanged">
                                    <ComboBoxItem Content="claro"/>
                                    <ComboBoxItem Content="oscuro"/>
                                </ComboBox>
                            </StackPanel>

                            <Button x:Name="BtnGuardarTema" Grid.Column="2" Content="Aplicar tema"
                                    Height="36" FontSize="12" FontWeight="SemiBold"
                                    Background="#1A73E8" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" Padding="16,0"
                                    VerticalAlignment="Bottom"
                                    Click="BtnGuardarTema_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ▸ CARD: CONEXIÓN SQL SERVER (columna derecha) -->
                <Border Style="{StaticResource CardBorder}"
                        Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                        VerticalAlignment="Top" Margin="6,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource CardHeader}"
                                       Text="● CONEXIÓN SQL SERVER" Margin="0"/>
                            <Button Grid.Column="1" x:Name="BtnAgregarServidor" Content="＋ Agregar"
                                    Height="30" FontSize="12" FontWeight="SemiBold" Padding="14,0"
                                    Background="#1A73E8" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnAgregarServidor_Click"/>
                        </Grid>

                        <Border BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                                CornerRadius="6">
                            <ListView x:Name="LstServidores" Height="350"
                                      BorderThickness="0"
                                      Background="{DynamicResource ThemeInputBg}"
                                      Foreground="{DynamicResource ThemeTexto}"
                                      FontSize="12"
                                      SelectionMode="Single"
                                      ItemContainerStyle="{StaticResource ServerListItemStyle}"
                                      MouseDoubleClick="LstServidores_MouseDoubleClick"
                                      SelectionChanged="LstServidores_SelectionChanged">
                                <ListView.View>
                                    <GridView ColumnHeaderContainerStyle="{StaticResource ServerListHeaderStyle}">
                                        <GridViewColumn Header="" Width="32"
                                                        DisplayMemberBinding="{Binding Activo}"/>
                                        <GridViewColumn Header="Alias" Width="160"
                                                        DisplayMemberBinding="{Binding Nombre}"/>
                                        <GridViewColumn Header="Servidor" Width="200"
                                                        DisplayMemberBinding="{Binding Servidor}"/>
                                        <GridViewColumn Header="Base de datos" Width="200"
                                                        DisplayMemberBinding="{Binding BaseDatos}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="BtnConectarServidor" Content="🔌 Conectar"
                                    Height="32" FontSize="12" FontWeight="SemiBold" Padding="14,0"
                                    Background="#2E7D32" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                                    Click="BtnConectarServidor_Click"/>
                            <Button x:Name="BtnEditarServidor" Content="✎ Editar"
                                    Style="{StaticResource SelectorBtn}"
                                    Click="BtnEditarServidor_Click"/>
                            <Button x:Name="BtnEliminarServidor" Content="🗑 Eliminar"
                                    Height="32" FontSize="12" Padding="14,0"
                                    Background="#D93025" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnEliminarServidor_Click"/>
                        </StackPanel>

                        <TextBlock FontSize="11" Foreground="{DynamicResource ThemeTextoMuted}"
                                   TextWrapping="Wrap" Margin="0,10,0,0"
                                   Text="Los cambios de servidor activo se aplican al reiniciar la aplicación. Al editar no se muestran las credenciales guardadas."/>
                    </StackPanel>
                </Border>

                <!-- ▸ CARD: MI CUENTA (columna izquierda, fila 1) -->
                <Border Style="{StaticResource CardBorder}"
                        Grid.Column="0" Grid.Row="1" Margin="0,0,6,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● MI CUENTA"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="CUENTA"/>
                                <TextBox x:Name="TxtCuenta" Style="{StaticResource ReadOnlyInput}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="TIPO DE USUARIO"/>
                                <TextBox x:Name="TxtTipo" Style="{StaticResource ReadOnlyInput}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="NOMBRES"/>
                                <TextBox x:Name="TxtNombres" Style="{StaticResource ModernInput}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="APELLIDOS"/>
                                <TextBox x:Name="TxtApellidos" Style="{StaticResource ModernInput}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource SectionLabel}" Text="SUCURSAL ACTIVA"/>
                            <ComboBox x:Name="CmbSucursal" Style="{StaticResource ModernCombo}"
                                      DisplayMemberPath="Descripcion"
                                      SelectionChanged="CmbSucursal_SelectionChanged"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="INICIO DE SUCURSAL"/>
                                <TextBox x:Name="TxtFechaInicio" Style="{StaticResource ReadOnlyInput}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="PERIODO ACTIVO"/>
                                <ComboBox x:Name="CmbPeriodo" Style="{StaticResource ModernCombo}"/>
                            </StackPanel>
                        </Grid>

                        <Button x:Name="BtnCambiarContrasena" Content="🔑 Cambiar Contraseña"
                                Height="34" FontSize="12" Padding="14,0"
                                Background="#5C6BC0" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Left"
                                Click="BtnCambiarContrasena_Click"/>
                    </StackPanel>
                </Border>

                <Rectangle Height="16" Grid.Column="0" Grid.Row="2"/>
            </Grid>
        </ScrollViewer>

        <!-- ══ BARRA DE ACCIONES ══════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,1,0,0"
                Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnGuardar" Content="&#x1F4BE; Guardar Cambios"
                        Height="36" FontSize="13" FontWeight="SemiBold" Padding="18,0"
                        Background="#1A73E8" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnGuardar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
