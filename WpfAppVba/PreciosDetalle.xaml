<UserControl x:Class="WpfAppVba.PreciosDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LblTitulo" Grid.Row="0" FontSize="15" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Artículo (solo lectura) -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Artículo:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="Box_Articulo"
                         Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,10"
                         MaxWidth="160" HorizontalAlignment="Left"
                         IsEnabled="False"
                         Background="{DynamicResource ThemeBgReadOnly}"
                         Foreground="{DynamicResource ThemeTextoMuted}"/>

                <!-- Fecha + Hora inline -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Fecha:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <DatePicker x:Name="Box_Fecha" Width="160" Height="30" FontSize="12"
                                SelectedDateChanged="Box_Fecha_SelectedDateChanged"/>
                    <TextBlock Text="Hora:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                               VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <TextBox x:Name="Box_Hora" Width="90" Height="30" FontSize="12" Padding="6,4"
                             BorderBrush="{DynamicResource ThemeBordeInput}"
                             TextChanged="Campo_TextChanged"/>
                </StackPanel>

                <!-- Región (código + descripción inline) -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Región:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,10"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox x:Name="Box_Region_Codigo" Width="80" Height="30" FontSize="12" Padding="6,4"
                             BorderBrush="{DynamicResource ThemeBordeInput}"
                             IsEnabled="False"
                             Background="{DynamicResource ThemeBgReadOnly}"
                             Foreground="{DynamicResource ThemeTextoMuted}"
                             TextChanged="Box_Region_Codigo_TextChanged"/>
                    <TextBlock x:Name="Box_Region_Descripcion" FontSize="11"
                               Foreground="{DynamicResource ThemeTexto}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Precio -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Precio:"
                           FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="Box_Precio"
                         Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}"
                         MaxWidth="160" HorizontalAlignment="Left"
                         TextChanged="Campo_TextChanged"
                         PreviewTextInput="Box_Decimales_PreviewTextInput"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Guardar" Height="32" Padding="14,0" FontSize="12"
                    Background="#1A73E8" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                    Click="BtnGuardar_Click"/>
            <Button Content="Cancelar" Height="32" Padding="14,0" FontSize="12"
                    Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
