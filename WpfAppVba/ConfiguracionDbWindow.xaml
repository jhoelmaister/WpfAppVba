<Window x:Class="WpfAppVba.ConfiguracionDbWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración de Conexión" Height="410" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource ThemeBgPrincipal}">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Configuración de Conexión" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,6"/>

        <!-- Subtítulo -->
        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,16"
                   Text="Configure los datos de conexión a SQL Server para continuar."/>

        <!-- Campos -->
        <StackPanel Grid.Row="2">

            <TextBlock Text="Servidor:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
            <TextBox x:Name="TxtServidor" Height="30" FontSize="12" Padding="6,4"
                     BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,10"/>

            <TextBlock Text="Base de datos:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
            <TextBox x:Name="TxtBaseDatos" Height="30" FontSize="12" Padding="6,4"
                     BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,10"/>

            <TextBlock Text="Usuario:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
            <TextBox x:Name="TxtUsuario" Height="30" FontSize="12" Padding="6,4"
                     BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,10"/>

            <TextBlock Text="Contraseña:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="PwdContrasena" Grid.Column="0" Height="30" FontSize="12" Padding="6,4"
                             BorderBrush="{DynamicResource ThemeBordeInput}"/>
                <TextBox x:Name="TxtContrasenaVisible" Grid.Column="0" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Visibility="Collapsed"/>
                <Button x:Name="BtnTogglePwd" Grid.Column="1" Content="Ver" Width="50" Height="30"
                        FontSize="11"
                        Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                        BorderThickness="0" Cursor="Hand" Margin="6,0,0,0"
                        Click="BtnTogglePwd_Click"/>
            </Grid>

            <Button x:Name="BtnProbarConexion" Content="Probar conexión"
                    Height="30" FontSize="12" Padding="12,0"
                    Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                    BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"
                    Click="BtnProbarConexion_Click"/>

        </StackPanel>

        <!-- Botones inferiores -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnCancelar" Content="Cancelar"
                    Height="32" FontSize="12" Padding="16,0"
                    Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                    Click="BtnCancelar_Click"/>
            <Button x:Name="BtnGuardar" Content="Guardar"
                    Height="32" FontSize="12" FontWeight="SemiBold" Padding="16,0"
                    Background="#1A73E8" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnGuardar_Click"/>
        </StackPanel>

    </Grid>
</Window>
