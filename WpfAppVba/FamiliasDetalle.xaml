<Window x:Class="WpfAppVba.FamiliasDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Familia" Height="420" Width="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource ThemeBgPrincipal}"
        Closing="Window_Closing">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock x:Name="LblTitulo" Grid.Row="0" FontSize="15" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,12"/>

        <!-- Campos -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="Código:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Codigo" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"/>

                <TextBlock Text="Descripción:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Descripcion" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"/>

                <TextBlock Text="Producto (Código):" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Referido_Codigo" Height="30" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,0,4"
                         TextChanged="Box_Referido_Codigo_TextChanged"
                         PreviewTextInput="Box_Referido_Codigo_PreviewTextInput"/>
                <TextBlock x:Name="Box_Referido_Descripcion" FontSize="11" Foreground="{DynamicResource ThemeTexto}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Observaciones:" FontSize="11" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                <TextBox x:Name="Box_Observacion" Height="70" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource ThemeBordeInput}" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"
                         TextChanged="Campo_TextChanged"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Guardar / Cancelar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Guardar" Height="32" Padding="14,0" FontSize="12"
                    Background="#1A73E8" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0,0,8,0"
                    Click="BtnGuardar_Click"/>
            <Button Content="Cancelar" Height="32" Padding="14,0" FontSize="12"
                    Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
