<UserControl x:Class="WpfAppVba.SucursalesGeneral"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Sucursales" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,10"/>

        <!-- Buscador -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtBuscar" Grid.Column="0" Height="28" FontSize="12"
                     Padding="6,4" BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,6,0"
                     TextChanged="TxtBuscar_TextChanged"/>
            <Button Content="Buscar" Grid.Column="1"
                    Style="{StaticResource Btn}" Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeTexto}"
                    Click="BtnBuscar_Click"/>
        </Grid>

        <!-- Lista -->
        <DataGrid x:Name="Grid1" Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                  FontSize="12"
                  MouseDoubleClick="Grid1_MouseDoubleClick"
                  PreviewKeyDown="Grid1_PreviewKeyDown">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Línea"        Binding="{Binding Linea}"       Width="60"/>
                <DataGridTextColumn Header="Identificador" Binding="{Binding Id}"         Width="80"/>
                <DataGridTextColumn Header="Descripción"  Binding="{Binding Descripcion}" Width="*"/>
                <DataGridTextColumn Header="Fecha"        Binding="{Binding FechaStr}"    Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Seleccionar (izq, modo selector) + botones admin (der) -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BtnSeleccionar" Grid.Column="0" Content="Seleccionar"
                    HorizontalAlignment="Left" Visibility="Collapsed"
                    Background="#1A73E8" Foreground="White"
                    Style="{StaticResource Btn}" Click="BtnSeleccionar_Click"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnNuevo"    Content="Nuevo"      Margin="0,0,6,0" Background="#1A73E8" Foreground="White"   Click="BtnNuevo_Click"      Style="{StaticResource Btn}"/>
                <Button x:Name="BtnEditar"   Content="Editar"     Margin="0,0,6,0" Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeTexto}" Click="BtnEditar_Click"     Style="{StaticResource Btn}"/>
                <Button x:Name="BtnEliminar" Content="Eliminar"   Margin="0,0,6,0" Background="#D93025" Foreground="White"   Click="BtnEliminar_Click"   Style="{StaticResource Btn}"/>
                <Button                      Content="Actualizar" Margin="0,0,0,0" Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeTexto}" Click="BtnActualizar_Click" Style="{StaticResource Btn}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
