<UserControl x:Class="WpfAppVba.TraspasosDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>

        <!-- ── Botones ── -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimario"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"      Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ThemeBtnSecFg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
        </Style>
        <Style x:Key="BtnPeligro"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- ── Etiquetas inline ── -->
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize"           Value="11"/>
            <Setter Property="Foreground"         Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="Margin"             Value="0,0,5,0"/>
        </Style>
        <Style x:Key="LblMuted" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="Foreground"        Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,4,0"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- ── Tarjeta de métrica ── -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="10,8"/>
        </Style>

        <!-- ── Input redondeado ── -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height"                   Value="28"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="Padding"                  Value="7,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground"               Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0  Encabezado -->
            <RowDefinition Height="*"/>     <!-- 1  Artículos + panel inferior -->
            <RowDefinition Height="Auto"/>  <!-- 2  Barra de totales + Guardar/Cancelar -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- 0 · ENCABEZADO                                              -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}"
                BorderThickness="0,0,0,1"
                Padding="14,10,14,10">
            <StackPanel>

                <!-- Fila superior: título + tipo -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="LblTitulo" Grid.Column="0"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeTexto}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Tipo" Style="{StaticResource LblMuted}"/>
                        <ComboBox x:Name="CboMovimiento" Width="100" Height="28" FontSize="12"
                                  SelectionChanged="CboMovimiento_SelectionChanged">
                            <ComboBoxItem Content="Entrada"/>
                            <ComboBoxItem Content="Salida"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Fila de campos: Doc · Fecha · Hora · Estado -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="136"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Doc. Traspaso" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_DocumentoT" Style="{StaticResource ModernInput}"
                                 PreviewTextInput="Box_Numeros_PreviewTextInput"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fecha" Style="{StaticResource LblMuted}"/>
                        <DatePicker x:Name="Box_Fecha" Height="28" FontSize="12"
                                    SelectedDateChanged="Campo_DateChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Hora" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_Hora" Style="{StaticResource ModernInput}"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Estado" Style="{StaticResource LblMuted}"/>
                        <ComboBox x:Name="Box_Estado" Height="28" FontSize="12"
                                  SelectionChanged="Campo_SelectionChanged">
                            <ComboBoxItem Content="pendiente"/>
                            <ComboBoxItem Content="pendiente revisar"/>
                            <ComboBoxItem Content="entregado"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Fila: Sucursal + Referencia -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Sucursal" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_Sucursal_Identificador"
                                 Style="{StaticResource ModernInput}"
                                 PreviewTextInput="Box_Numeros_PreviewTextInput"
                                 TextChanged="Box_Sucursal_Identificador_TextChanged"/>
                    </StackPanel>

                    <Button Grid.Column="2" x:Name="BtnBuscarSucursal" Content="···"
                            Height="28" Width="30" Padding="0"
                            Style="{StaticResource BtnSecundario}"
                            Margin="0,14,0,0"
                            Click="BtnBuscarSucursal_Click"/>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text=" " Style="{StaticResource LblMuted}"/>
                        <Border Height="28" Background="{DynamicResource ThemeBgReadOnly}"
                                BorderBrush="{DynamicResource ThemeBorde}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="7,0">
                            <TextBlock x:Name="Box_Sucursal_Descripcion"
                                       FontSize="12"
                                       Foreground="{DynamicResource ThemeTextoMuted}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Referencia" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_Referencia" Style="{StaticResource ModernInput}"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Emisión / Edición -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Emisión:" Style="{StaticResource LblMuted}"/>
                    <TextBlock x:Name="TxtEmision" FontSize="10"
                               Foreground="{DynamicResource ThemeTexto}"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="Edición:" Style="{StaticResource LblMuted}"/>
                    <TextBlock x:Name="TxtEdicion" FontSize="10"
                               Foreground="{DynamicResource ThemeTexto}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- 1 · ARTÍCULOS + PANEL INFERIOR                              -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="14,10,14,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- toolbar -->
                <RowDefinition Height="*"/>     <!-- GridItems -->
                <RowDefinition Height="130"/>   <!-- Stock | Observaciones -->
            </Grid.RowDefinitions>

            <!-- Toolbar artículos -->
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Artículos del traspaso"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeTexto}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnImportarArticulos"
                            Content="Importar Artículos" Style="{StaticResource BtnPrimario}"
                            Margin="0,0,5,0" Click="BtnImportarArticulos_Click"/>
                    <Button x:Name="BtnBuscarArticulo"
                            Content="Buscar Artículo" Style="{StaticResource BtnSecundario}"
                            Margin="0,0,5,0" Click="BtnBuscarArticulo_Click"/>
                    <Button x:Name="BtnInsertar"
                            Content="Insertar" Style="{StaticResource BtnSecundario}"
                            Margin="0,0,5,0" Click="BtnInsertar_Click"/>
                    <Button x:Name="BtnNuevaLinea"
                            Content="Nueva Línea" Style="{StaticResource BtnSecundario}"
                            Margin="0,0,5,0" Click="BtnNuevaLinea_Click"/>
                    <Button x:Name="BtnEliminarLinea"
                            Content="Eliminar Línea" Style="{StaticResource BtnPeligro}"
                            Click="BtnEliminarLinea_Click"/>
                </StackPanel>
            </Grid>

            <!-- Grid principal de artículos -->
            <Border Grid.Row="1" CornerRadius="6" BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeBorde}" ClipToBounds="True">
                <DataGrid x:Name="GridItems"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          FontSize="12"
                          SelectionChanged="GridItems_SelectionChanged"
                          CellEditEnding="GridItems_CellEditEnding"
                          PreparingCellForEdit="GridItems_PreparingCellForEdit">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"       Width="48"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="Código"      Binding="{Binding Codigo}"      Width="80"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"   IsReadOnly="True"/>
                        <DataGridTextColumn Header="Cantidad"    Binding="{Binding Cantidad, StringFormat=#\,##0.##}" Width="80"
                                            ElementStyle="{StaticResource CeldaNumero}"
                                            EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Panel inferior: Stock | Observaciones -->
            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Stock del artículo seleccionado -->
                <DockPanel Grid.Column="0">
                    <TextBlock DockPanel.Dock="Top" Text="Stock"
                               Style="{StaticResource SectionHeader}"/>
                    <Border CornerRadius="6" BorderThickness="1"
                            BorderBrush="{DynamicResource ThemeBorde}" ClipToBounds="True">
                        <DataGrid x:Name="GridStock"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Artículo" Binding="{Binding Codigo}"     Width="*"/>
                                <DataGridTextColumn Header="Disp."    Binding="{Binding Disponible}" Width="60"
                                                    ElementStyle="{StaticResource CeldaNumero}"/>
                                <DataGridTextColumn Header="Stock"    Binding="{Binding Stock}"      Width="60"
                                                    ElementStyle="{StaticResource CeldaNumero}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>

                <!-- Observaciones -->
                <DockPanel Grid.Column="2">
                    <TextBlock DockPanel.Dock="Top" Text="Observaciones"
                               Style="{StaticResource SectionHeader}"/>
                    <TextBox x:Name="Box_Observaciones" FontSize="12"
                             Padding="7,5" BorderBrush="{DynamicResource ThemeBordeInput}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             TextChanged="Campo_TextChanged"/>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- 2 · BARRA DE TOTALES + GUARDAR/CANCELAR                     -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Izquierda: contadores -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Total unidades -->
                    <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Total unidades" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextoSec}"/>
                            <TextBlock x:Name="TxtTotalUnidades"
                                       FontSize="17" FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource ThemeTexto}"/>
                        </StackPanel>
                    </Border>
                    <!-- Diferentes -->
                    <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Diferentes" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextoSec}"/>
                            <TextBlock x:Name="TxtUnidadesDiferentes"
                                       FontSize="17" FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource ThemeTexto}"/>
                        </StackPanel>
                    </Border>
                    <!-- Por tamaño -->
                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Por tamaño" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Peq:" Style="{StaticResource LblMuted}"/>
                                <TextBlock x:Name="TxtTotalPeq" FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{DynamicResource ThemeTexto}"/>
                                <TextBlock Text="Med:" Style="{StaticResource LblMuted}"/>
                                <TextBlock x:Name="TxtTotalMed" FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{DynamicResource ThemeTexto}"/>
                                <TextBlock Text="Gra:" Style="{StaticResource LblMuted}"/>
                                <TextBlock x:Name="TxtTotalGra" FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{DynamicResource ThemeTexto}"/>
                                <TextBlock Text="Otros:" Style="{StaticResource LblMuted}"/>
                                <TextBlock x:Name="TxtTotalOtros" FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ThemeTexto}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Derecha: Guardar / Cancelar -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Cancelar" Style="{StaticResource BtnSecundario}"
                            Margin="0,0,8,0" Click="BtnCancelar_Click"/>
                    <Button Content="💾 Guardar" Height="30" FontWeight="SemiBold"
                            Style="{StaticResource BtnPrimario}"
                            Click="BtnGuardar_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
