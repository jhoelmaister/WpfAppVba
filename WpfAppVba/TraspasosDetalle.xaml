<Window x:Class="WpfAppVba.TraspasosDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de Traspaso" Height="740" Width="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource ThemeBgPrincipal}"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeBtnSecFg}"/>
        </Style>
        <Style x:Key="BtnPeligro" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#D93025"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
        <Style x:Key="LblMuted" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: Título -->
            <RowDefinition Height="Auto"/>   <!-- 1: Doc / Fecha / Hora / Estado -->
            <RowDefinition Height="Auto"/>   <!-- 2: Sucursal -->
            <RowDefinition Height="Auto"/>   <!-- 3: Referencia -->
            <RowDefinition Height="Auto"/>   <!-- 4: Emisión / Edición -->
            <RowDefinition Height="Auto"/>   <!-- 5: Observaciones -->
            <RowDefinition Height="Auto"/>   <!-- 6: Separador -->
            <RowDefinition Height="Auto"/>   <!-- 7: Cabecera artículos + botones -->
            <RowDefinition Height="*"/>      <!-- 8: GridItems + GridStock -->
            <RowDefinition Height="Auto"/>   <!-- 9: Totales por categoría -->
            <RowDefinition Height="Auto"/>   <!-- 10: Guardar / Cancelar -->
        </Grid.RowDefinitions>

        <!-- ── 0: Título ──────────────────────────────────────────────────── -->
        <TextBlock x:Name="LblTitulo" Grid.Row="0"
                   FontSize="15" FontWeight="Bold" Foreground="{DynamicResource ThemeTexto}"
                   Margin="0,0,0,10"/>

        <!-- ── 1: Doc · Fecha · Hora · Estado ─────────────────────────────── -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"  Text="Doc. Traspaso:" Style="{StaticResource Lbl}"/>
            <TextBox   Grid.Column="1"  x:Name="Box_DocumentoT" Height="28" FontSize="12"
                       Padding="5,4" BorderBrush="{DynamicResource ThemeBordeInput}"
                       PreviewTextInput="Box_Numeros_PreviewTextInput"
                       TextChanged="Campo_TextChanged"/>

            <TextBlock Grid.Column="3"  Text="Fecha:" Style="{StaticResource Lbl}"/>
            <DatePicker Grid.Column="4" x:Name="Box_Fecha" Height="28" FontSize="12"
                        SelectedDateChanged="Campo_DateChanged"/>

            <TextBlock Grid.Column="6"  Text="Hora:" Style="{StaticResource Lbl}"/>
            <TextBox   Grid.Column="7"  x:Name="Box_Hora" Height="28" FontSize="12"
                       Padding="5,4" BorderBrush="{DynamicResource ThemeBordeInput}"
                       TextChanged="Campo_TextChanged"/>

            <TextBlock Grid.Column="9"  Text="Estado:" Style="{StaticResource Lbl}"/>
            <ComboBox  Grid.Column="10" x:Name="Box_Estado" Height="28" FontSize="12"
                       SelectionChanged="Campo_SelectionChanged">
                <ComboBoxItem Content="pendiente"/>
                <ComboBoxItem Content="pendiente revisar"/>
                <ComboBoxItem Content="entregado"/>
            </ComboBox>
        </Grid>

        <!-- ── 2: Sucursal ──────────────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Sucursal:" Style="{StaticResource Lbl}"/>
            <TextBox   Grid.Column="1" x:Name="Box_Sucursal_Identificador"
                       Height="28" FontSize="12" Padding="5,4" BorderBrush="{DynamicResource ThemeBordeInput}"
                       PreviewTextInput="Box_Numeros_PreviewTextInput"
                       TextChanged="Box_Sucursal_Identificador_TextChanged"/>
            <Button    Grid.Column="2" x:Name="BtnBuscarSucursal"
                       Content="..." Width="30" Height="28"
                       Style="{StaticResource BtnSecundario}" Margin="2,0,0,0"
                       Click="BtnBuscarSucursal_Click"/>

            <TextBlock Grid.Column="4" x:Name="Box_Sucursal_Descripcion"
                       FontSize="12" Foreground="#333" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- ── 3: Referencia ────────────────────────────────────────────────── -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Referencia:" Style="{StaticResource Lbl}"/>
            <TextBox   Grid.Column="1" x:Name="Box_Referencia"
                       Height="28" FontSize="12" Padding="5,4" BorderBrush="{DynamicResource ThemeBordeInput}"
                       TextChanged="Campo_TextChanged"/>
        </Grid>

        <!-- ── 4: Emisión / Edición (solo lectura) ──────────────────────────── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Emisión:" Style="{StaticResource LblMuted}"/>
            <TextBlock x:Name="TxtEmision" FontSize="10" Foreground="{DynamicResource ThemeTextoSec}"
                       VerticalAlignment="Center" Margin="0,0,20,0"/>
            <TextBlock Text="Edición:" Style="{StaticResource LblMuted}"/>
            <TextBlock x:Name="TxtEdicion" FontSize="10" Foreground="{DynamicResource ThemeTextoSec}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── 5: (reservado) ───────────────────────────────────────────────── -->
        <!-- Observaciones se movió al panel inferior junto a GridStock -->


        <!-- ── 6: Separador ─────────────────────────────────────────────────── -->
        <Separator Grid.Row="6" Margin="0,0,0,8"/>

        <!-- ── 7: Cabecera artículos + botones ──────────────────────────────── -->
        <Grid Grid.Row="7" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Artículos del traspaso:"
                       FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTexto}"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BtnImportarArticulos"
                        Content="Importar Artículos" Style="{StaticResource BtnPrimario}"
                        Margin="0,0,5,0" Click="BtnImportarArticulos_Click"/>
                <Button x:Name="BtnBuscarArticulo"
                        Content="Buscar Artículo" Style="{StaticResource BtnSecundario}"
                        Margin="0,0,5,0" Click="BtnBuscarArticulo_Click"/>
                <Button x:Name="BtnInsertar"
                        Content="Insertar" Style="{StaticResource BtnSecundario}"
                        Margin="0,0,5,0" Click="BtnInsertar_Click"/>
                <Button x:Name="BtnNuevaLinea"
                        Content="Nueva Línea" Style="{StaticResource BtnSecundario}"
                        Margin="0,0,5,0" Click="BtnNuevaLinea_Click"/>
                <Button x:Name="BtnEliminarLinea"
                        Content="Eliminar Línea" Style="{StaticResource BtnPeligro}"
                        Click="BtnEliminarLinea_Click"/>
            </StackPanel>
        </Grid>

        <!-- ── 8: GridItems arriba + (GridStock | Observaciones) abajo ────── -->
        <Grid Grid.Row="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <!-- Grid principal de artículos -->
            <DataGrid x:Name="GridItems" Grid.Row="0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                      FontSize="12"
                      SelectionChanged="GridItems_SelectionChanged"
                      CellEditEnding="GridItems_CellEditEnding"
                      PreparingCellForEdit="GridItems_PreparingCellForEdit">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"       Width="48"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Código"      Binding="{Binding Codigo}"      Width="80"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"   IsReadOnly="True"/>
                    <DataGridTextColumn Header="Cantidad"    Binding="{Binding Cantidad, StringFormat=#\,##0.##}" Width="80"
                                        ElementStyle="{StaticResource CeldaNumero}"
                                        EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Panel inferior: GridStock (izquierda) + Observaciones (derecha) -->
            <Grid Grid.Row="1" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Stock del artículo seleccionado -->
                <DockPanel Grid.Column="0">
                    <TextBlock DockPanel.Dock="Top" Text="Stock"
                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextoSec}"
                               Margin="0,0,0,2"/>
                    <DataGrid x:Name="GridStock"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                              FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Artículo"   Binding="{Binding Codigo}"     Width="*"/>
                            <DataGridTextColumn Header="Disp."      Binding="{Binding Disponible}" Width="60"
                                                ElementStyle="{StaticResource CeldaNumero}"/>
                            <DataGridTextColumn Header="Stock"      Binding="{Binding Stock}"      Width="60"
                                                ElementStyle="{StaticResource CeldaNumero}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <!-- Observaciones -->
                <DockPanel Grid.Column="2">
                    <TextBlock DockPanel.Dock="Top" Text="Observaciones"
                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextoSec}"
                               Margin="0,0,0,2"/>
                    <TextBox x:Name="Box_Observaciones" FontSize="12"
                             Padding="5,4" BorderBrush="{DynamicResource ThemeBordeInput}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             TextChanged="Campo_TextChanged"/>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- ── 9: Totales por categoría ─────────────────────────────────────── -->
        <WrapPanel Grid.Row="9" Orientation="Horizontal" Margin="0,6,0,0">
            <TextBlock Text="Pequeñas:" Style="{StaticResource LblMuted}"/>
            <TextBlock x:Name="TxtTotalPeq" FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="0,0,14,0" Foreground="#333"/>
            <TextBlock Text="Medianas:" Style="{StaticResource LblMuted}"/>
            <TextBlock x:Name="TxtTotalMed" FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="0,0,14,0" Foreground="#333"/>
            <TextBlock Text="Grandes:" Style="{StaticResource LblMuted}"/>
            <TextBlock x:Name="TxtTotalGra" FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="0,0,14,0" Foreground="#333"/>
            <TextBlock Text="Otros:" Style="{StaticResource LblMuted}"/>
            <TextBlock x:Name="TxtTotalOtros" FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="0,0,18,0" Foreground="#333"/>
            <Separator Width="1" Height="14" Margin="0,0,18,0"/>
            <TextBlock Text="Total Unidades:" Style="{StaticResource LblMuted}"/>
            <TextBlock x:Name="TxtTotalUnidades" FontSize="12" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,14,0" Foreground="#1A73E8"/>
            <TextBlock Text="Dif.:" Style="{StaticResource LblMuted}"/>
            <TextBlock x:Name="TxtUnidadesDiferentes" FontSize="12" FontWeight="Bold"
                       VerticalAlignment="Center" Foreground="#1A73E8"/>
        </WrapPanel>

        <!-- ── 10: Guardar / Cancelar ────────────────────────────────────────── -->
        <StackPanel Grid.Row="10" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Guardar"  Style="{StaticResource BtnPrimario}"
                    Margin="0,0,8,0" Click="BtnGuardar_Click"/>
            <Button Content="Cancelar" Style="{StaticResource BtnSecundario}"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
