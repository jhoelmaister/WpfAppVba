<Window x:Class="WpfAppVba.TraspasosDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de Traspaso" Height="620" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F2F5"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#E8EDF5"/>
            <Setter Property="Foreground" Value="#5F6368"/>
        </Style>
        <Style x:Key="BtnPeligro" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#D93025"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- Etiqueta inline a la izquierda del control -->
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Título -->
            <RowDefinition Height="Auto"/>  <!-- Doc / Fecha / Hora / Estado -->
            <RowDefinition Height="Auto"/>  <!-- Sucursal + descripción -->
            <RowDefinition Height="Auto"/>  <!-- Referencia + Total Unidades -->
            <RowDefinition Height="Auto"/>  <!-- Observaciones -->
            <RowDefinition Height="Auto"/>  <!-- Separador -->
            <RowDefinition Height="Auto"/>  <!-- Cabecera artículos + botones -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Guardar / Cancelar -->
        </Grid.RowDefinitions>

        <!-- ── Título ──────────────────────────────────────────────────── -->
        <TextBlock x:Name="LblTitulo" Grid.Row="0"
                   FontSize="15" FontWeight="Bold" Foreground="#1A1A2E"
                   Margin="0,0,0,10"/>

        <!-- ── Fila 1: Doc · Fecha · Hora · Estado ─────────────────────── -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"  Text="Doc. Traspaso:" Style="{StaticResource Lbl}"/>
            <TextBox   Grid.Column="1"  x:Name="Box_DocumentoT" Height="28" FontSize="12"
                       Padding="5,4" BorderBrush="#CCC"
                       PreviewTextInput="Box_Numeros_PreviewTextInput"
                       TextChanged="Campo_TextChanged"/>

            <TextBlock Grid.Column="3"  Text="Fecha:" Style="{StaticResource Lbl}"/>
            <DatePicker Grid.Column="4" x:Name="Box_Fecha" Height="28" FontSize="12"
                        SelectedDateChanged="Campo_DateChanged"/>

            <TextBlock Grid.Column="6"  Text="Hora:" Style="{StaticResource Lbl}"/>
            <TextBox   Grid.Column="7"  x:Name="Box_Hora" Height="28" FontSize="12"
                       Padding="5,4" BorderBrush="#CCC"
                       TextChanged="Campo_TextChanged"/>

            <TextBlock Grid.Column="9"  Text="Estado:" Style="{StaticResource Lbl}"/>
            <ComboBox  Grid.Column="10" x:Name="Box_Estado" Height="28" FontSize="12"
                       SelectionChanged="Campo_SelectionChanged">
                <ComboBoxItem Content="pendiente"/>
                <ComboBoxItem Content="pendiente revisar"/>
                <ComboBoxItem Content="entregado"/>
            </ComboBox>
        </Grid>

        <!-- ── Fila 2: Sucursal ─────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Sucursal:" Style="{StaticResource Lbl}"/>
            <TextBox   Grid.Column="1" x:Name="Box_Sucursal_Identificador"
                       Height="28" FontSize="12" Padding="5,4" BorderBrush="#CCC"
                       PreviewTextInput="Box_Numeros_PreviewTextInput"
                       TextChanged="Box_Sucursal_Identificador_TextChanged"/>
            <Button    Grid.Column="2" Content="..." Width="30" Height="28"
                       Style="{StaticResource BtnSecundario}" Margin="2,0,0,0"
                       Click="BtnBuscarSucursal_Click"/>

            <TextBlock Grid.Column="4" x:Name="Box_Sucursal_Descripcion"
                       FontSize="12" Foreground="#333" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- ── Fila 3: Referencia + Total Unidades ──────────────────────── -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Referencia:" Style="{StaticResource Lbl}"/>
            <TextBox   Grid.Column="1" x:Name="Box_Referencia"
                       Height="28" FontSize="12" Padding="5,4" BorderBrush="#CCC"
                       TextChanged="Campo_TextChanged"/>

            <TextBlock Grid.Column="3" Text="Total Unidades:" Style="{StaticResource Lbl}"/>
            <TextBlock Grid.Column="4" x:Name="TxtTotalUnidades"
                       FontSize="13" FontWeight="Bold" Foreground="#1A73E8"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Fila 4: Observaciones ────────────────────────────────────── -->
        <Grid Grid.Row="4" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Observaciones:" Style="{StaticResource Lbl}"
                       VerticalAlignment="Top" Margin="0,5,5,0"/>
            <TextBox   Grid.Column="1" x:Name="Box_Observaciones"
                       Height="44" FontSize="12" Padding="5,4"
                       BorderBrush="#CCC" TextWrapping="Wrap" AcceptsReturn="True"
                       VerticalScrollBarVisibility="Auto"
                       TextChanged="Campo_TextChanged"/>
        </Grid>

        <!-- ── Separador ────────────────────────────────────────────────── -->
        <Separator Grid.Row="5" Margin="0,0,0,8"/>

        <!-- ── Cabecera artículos + botones ─────────────────────────────── -->
        <Grid Grid.Row="6" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Artículos del traspaso:"
                       FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Importar Artículos" Style="{StaticResource BtnPrimario}"
                        Margin="0,0,5,0" Click="BtnImportarArticulos_Click"/>
                <Button Content="Insertar"     Style="{StaticResource BtnSecundario}"
                        Margin="0,0,5,0" Click="BtnInsertar_Click"/>
                <Button Content="Nueva Línea"  Style="{StaticResource BtnSecundario}"
                        Margin="0,0,5,0" Click="BtnNuevaLinea_Click"/>
                <Button Content="Eliminar Línea" Style="{StaticResource BtnPeligro}"
                        Click="BtnEliminarLinea_Click"/>
            </StackPanel>
        </Grid>

        <!-- ── DataGrid artículos ────────────────────────────────────────── -->
        <DataGrid x:Name="GridItems" Grid.Row="7"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#DDD" BorderThickness="1"
                  FontSize="12"
                  CellEditEnding="GridItems_CellEditEnding"
                  PreparingCellForEdit="GridItems_PreparingCellForEdit">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"       Width="48"  IsReadOnly="True"/>
                <DataGridTextColumn Header="Código"      Binding="{Binding Codigo}"      Width="80"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"   IsReadOnly="True"/>
                <DataGridTextColumn Header="Cantidad"    Binding="{Binding Cantidad}"    Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Guardar / Cancelar ────────────────────────────────────────── -->
        <StackPanel Grid.Row="8" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Guardar"  Style="{StaticResource BtnPrimario}"
                    Margin="0,0,8,0" Click="BtnGuardar_Click"/>
            <Button Content="Cancelar" Style="{StaticResource BtnSecundario}"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
