<Window x:Class="WpfAppVba.ConsolaMovimientos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfAppVba"
        Title="Sistema de Gestión"
        WindowState="Maximized"
        MinWidth="960" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemeBgPrincipal}"
        Icon="icono.ico"
        Closing="ConsolaMovimientos_Closing">

    <Window.Resources>

        <!-- ── Ítem de navegación lateral ─────────────────────────────── -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0,12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Borde"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Borde" Property="Background" Value="{DynamicResource ThemeTabHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Borde" Property="Background" Value="{DynamicResource ThemeTabSelBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botón de acceso rápido (top bar) ───────────────────────── -->
        <Style x:Key="QuickBtn" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TabControl de sub-pestañas ─────────────────────────────── -->
        <Style x:Key="ModernTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource ThemeBgContenido}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="TabStripPlacement" Value="Top"/>
        </Style>

        <!-- ── TabItem de sub-pestañas ────────────────────────────────── -->
        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9AA3B8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="TabText"
                                       Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#4A6FE3"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ThemeTabSelBg}"/>
                                <Setter TargetName="TabText"   Property="Foreground"  Value="#4A6FE3"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ThemeTabHoverBg}"/>
                                <Setter TargetName="TabText"   Property="Foreground"  Value="#4A6FE3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- Top bar -->
            <RowDefinition Height="*"/>    <!-- Sidebar + Contenido -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- TOP BAR                                                      -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeBgTopBar}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo y título -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="8"
                            Background="#4A6FE3" Margin="0,0,10,0">
                        <TextBlock Text="SG" FontSize="13" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Sistema de Gestión"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTexto}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Accesos rápidos + Usuario -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnQuick_Venta" Content="🛒  Venta"
                            Style="{StaticResource QuickBtn}" Background="#E53935"
                            Click="BtnQuick_Venta_Click"/>
                    <Button x:Name="BtnQuick_Compra" Content="📥  Compra"
                            Style="{StaticResource QuickBtn}" Background="#1E88E5"
                            Click="BtnQuick_Compra_Click"/>
                    <Button x:Name="BtnQuick_Salida" Content="📤  Salida"
                            Style="{StaticResource QuickBtn}" Background="#FB8C00"
                            Click="BtnQuick_Salida_Click"/>
                    <Button x:Name="BtnQuick_Entrada" Content="📦  Entrada"
                            Style="{StaticResource QuickBtn}" Background="#43A047"
                            Click="BtnQuick_Entrada_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource ThemeBorde}" Margin="10,0"/>

                    <TextBlock x:Name="LblUsuario"
                               FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                               VerticalAlignment="Center"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource ThemeBorde}" Margin="10,0"/>

                    <TextBlock x:Name="LblSucursal"
                               FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                               VerticalAlignment="Center"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource ThemeBorde}" Margin="10,0"/>

                    <TextBlock x:Name="LblEmpresa"
                               FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                               VerticalAlignment="Center"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource ThemeBorde}" Margin="10,0"/>

                    <!-- ── Actualización de la app (manual / opt-in) ──────────── -->
                    <!-- Oculto mientras no haya versión nueva. 3 estados visuales. -->
                    <Border x:Name="BloqueActualizar" Visibility="Collapsed"
                            VerticalAlignment="Center" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <!-- Estado A: hay versión nueva (el usuario decide) -->
                            <Button x:Name="BtnActualizar" Visibility="Collapsed"
                                    Content="🔄  Actualizar"
                                    Style="{StaticResource QuickBtn}" Background="#6C4AE3"
                                    ToolTip="Hay una nueva versión disponible"
                                    Click="BtnActualizar_Click"/>

                            <!-- Estado B: descargando en segundo plano -->
                            <StackPanel x:Name="PanelDescarga" Orientation="Horizontal"
                                        Visibility="Collapsed" VerticalAlignment="Center">
                                <TextBlock x:Name="LblDescarga" Text="Descargando…"
                                           FontSize="11" Foreground="#9AA3B8"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ProgressBar x:Name="BarraDescarga" Width="120" Height="8"
                                             Minimum="0" Maximum="100" Value="0"
                                             Background="#1A1E2E" Foreground="#6C4AE3"
                                             BorderThickness="0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Estado C: lista para reiniciar (el usuario decide cuándo) -->
                            <Button x:Name="BtnReiniciar" Visibility="Collapsed"
                                    Content="✅  Reiniciar para actualizar"
                                    Style="{StaticResource QuickBtn}" Background="#2E7D32"
                                    ToolTip="La actualización está lista"
                                    Click="BtnReiniciar_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Estado de conexión -->
                    <Border x:Name="PillConexion"
                            VerticalAlignment="Center"
                            CornerRadius="10" Padding="12,4" Background="#2E7D32">
                        <TextBlock x:Name="LblConexion" Text="●  En línea"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- SIDEBAR + CONTENIDO                                         -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── BARRA LATERAL ──────────────────────────────────── -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeBgSidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Ítems de navegación -->
                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,8,0,8">

                            <Button x:Name="BtnNav_Dashboard"
                                    Content="📊  Dashboard"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Dashboard_Click"/>
                            <Button x:Name="BtnNav_Articulos"
                                    Content="📋  Artículos"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Articulos_Click"/>
                            <Button x:Name="BtnNav_Pedidos"
                                    Content="📑  Pedidos"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Pedidos_Click"/>
                            <Button x:Name="BtnNav_Traspasos"
                                    Content="🔄  Traspasos"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Traspasos_Click"/>
                            <Button x:Name="BtnNav_Correcciones"
                                    Content="🔧  Correcciones"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Correcciones_Click"/>
                            <Button x:Name="BtnNav_Movimientos"
                                    Content="📈  Movimientos"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Movimientos_Click"/>

                            <Rectangle Height="1" Fill="{DynamicResource ThemeBorde}" Margin="12,8"/>

                            <Button x:Name="BtnNav_Terceros"
                                    Content="👥  Terceros"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Terceros_Click"/>
                            <Button x:Name="BtnNav_Sucursales"
                                    Content="🏢  Sucursales"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Sucursales_Click"/>
                            <Button x:Name="BtnNav_Familias"
                                    Content="🗂  Familias"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Familias_Click"/>
                            <Button x:Name="BtnNav_Productos"
                                    Content="📦  Productos"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Productos_Click"/>
                            <Button x:Name="BtnNav_Industrias"
                                    Content="🏭  Industrias"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Industrias_Click"/>
                            <Button x:Name="BtnNav_Categorias"
                                    Content="🏷  Categorías"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Categorias_Click"/>
                            <Button x:Name="BtnNav_Inventarios"
                                    Content="📊  Inventarios"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Inventarios_Click"/>
                            <Button x:Name="BtnNav_Regiones"
                                    Content="🌐  Regiones"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Regiones_Click"/>
                            <Button x:Name="BtnNav_Precios"
                                    Content="💲  Precios"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Precios_Click"/>
                            <Button x:Name="BtnNav_Empresas"
                                    Content="🏢  Empresas"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Empresas_Click"/>
                            <Button x:Name="BtnNav_Usuarios"
                                    Content="👤  Usuarios"
                                    Style="{StaticResource NavBtn}"
                                    Visibility="Collapsed"
                                    Click="BtnNav_Usuarios_Click"/>
                            <Button x:Name="BtnNav_Configuracion"
                                    Content="⚙  Configuración"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Configuracion_Click"/>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Cerrar sesión (fijo al fondo) -->
                    <Border Grid.Row="1"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource ThemeBorde}">
                        <Button Content="⏻  Cerrar Sesión"
                                Style="{StaticResource NavBtn}"
                                Foreground="#EF5350"
                                Click="BtnCerrarSesion_Click"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── ÁREA DE CONTENIDO ──────────────────── -->
            <TabControl x:Name="TabContenido" Grid.Column="1"
                        Background="{DynamicResource ThemeBgContenido}"
                        BorderThickness="0" Padding="0">
                <!-- Pestaña fija: título y contenido cambian según el menú lateral -->
                <TabItem x:Name="TabFijo">
                    <TabItem.Header>
                        <TextBlock x:Name="TabFijoTitulo" Text="Artículos"
                                   VerticalAlignment="Center"/>
                    </TabItem.Header>
                    <ContentControl x:Name="TabFijoContenido"/>
                </TabItem>
            </TabControl>
        </Grid>

    </Grid>

</Window>
