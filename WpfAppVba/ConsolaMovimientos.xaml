<Window x:Class="WpfAppVba.ConsolaMovimientos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfAppVba"
        Title="Sistema de Gestión"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1E2235">

    <Window.Resources>

        <!-- ── Estilo de botón de acción rápida (toolbar) ─────────────── -->
        <Style x:Key="BtnAccion" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Borde"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Borde" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Borde" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Estilo del TabControl ──────────────────────────────────── -->
        <Style x:Key="ModernTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="#F4F6FB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="TabStripPlacement" Value="Top"/>
        </Style>

        <!-- ── Estilo del TabItem ─────────────────────────────────────── -->
        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9AA3B8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="TabText"
                                       Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#4A6FE3"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="#EEF2FF"/>
                                <Setter TargetName="TabText"   Property="Foreground"  Value="#4A6FE3"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#E8ECF8"/>
                                <Setter TargetName="TabText"   Property="Foreground"  Value="#4A6FE3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Contenido principal -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- HEADER                                                       -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#252A40">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- Logo + título -->
                    <ColumnDefinition Width="*"/>      <!-- Botones de acción rápida -->
                    <ColumnDefinition Width="Auto"/>   <!-- Info usuario + Salir -->
                </Grid.ColumnDefinitions>

                <!-- Logo y título -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="#4A6FE3" Margin="0,0,10,0">
                        <TextBlock Text="SG" FontSize="14" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Sistema de Gestión"
                               FontSize="15" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Botones de acción rápida -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="＋ Venta Rápida"  Margin="4,0"
                            Background="#2E7D32"
                            Style="{StaticResource BtnAccion}"
                            Click="BtnVentaRapida_Click"/>
                    <Button Content="＋ Entrada Rápida" Margin="4,0"
                            Background="#1565C0"
                            Style="{StaticResource BtnAccion}"
                            Click="BtnEntradaRapida_Click"/>
                    <Button Content="＋ Salida Rápida"  Margin="4,0"
                            Background="#6A1B9A"
                            Style="{StaticResource BtnAccion}"
                            Click="BtnSalidaRapida_Click"/>
                </StackPanel>

                <!-- Info usuario + botones + Cerrar sesión -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="LblUsuario"
                               FontSize="11" Foreground="#9AA3B8"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="📊 Inventarios"
                            Background="#0277BD" Margin="0,0,6,0"
                            Style="{StaticResource BtnAccion}"
                            Click="BtnInventarios_Click"/>
                    <Button Content="⚙ Configuración"
                            Background="#4527A0" Margin="0,0,6,0"
                            Style="{StaticResource BtnAccion}"
                            Click="BtnMiCuenta_Click"/>
                    <Button Content="Cerrar Sesión"
                            Background="#C62828"
                            Style="{StaticResource BtnAccion}"
                            Click="BtnCerrarSesion_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- ÁREA PRINCIPAL CON TABS                                     -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#F4F6FB">
            <TabControl x:Name="MainTabs"
                        Style="{StaticResource ModernTabControl}"
                        Background="#F4F6FB"
                        BorderThickness="0">

                <!-- ── Pestaña Ventas ──────────────────────────────── -->
                <TabItem Header="💰 Ventas" Style="{StaticResource ModernTabItem}">
                    <local:PedidosGeneral x:Name="TabVentas" TipoMovimiento="venta"/>
                </TabItem>

                <!-- ── Pestaña Compras ─────────────────────────────── -->
                <TabItem Header="🛒 Compras" Style="{StaticResource ModernTabItem}">
                    <local:PedidosGeneral x:Name="TabCompras" TipoMovimiento="compra"/>
                </TabItem>

                <!-- ── Pestaña Entradas ────────────────────────────── -->
                <TabItem Header="📦 Entradas" Style="{StaticResource ModernTabItem}">
                    <local:TraspasosGeneral x:Name="TabEntradas" TipoMovimiento="entrada"/>
                </TabItem>

                <!-- ── Pestaña Salidas ─────────────────────────────── -->
                <TabItem Header="📤 Salidas" Style="{StaticResource ModernTabItem}">
                    <local:TraspasosGeneral x:Name="TabSalidas" TipoMovimiento="salida"/>
                </TabItem>

                <!-- ── Pestaña Artículos ───────────────────────────── -->
                <TabItem Header="📋 Artículos" Style="{StaticResource ModernTabItem}">
                    <local:ArticulosGeneral x:Name="TabArticulos"/>
                </TabItem>

            </TabControl>
        </Border>

    </Grid>
</Window>
