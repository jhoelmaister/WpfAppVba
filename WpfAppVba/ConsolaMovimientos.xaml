<Window x:Class="WpfAppVba.ConsolaMovimientos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfAppVba"
        Title="Sistema de Gestión"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1E2235">

    <Window.Resources>

        <!-- ── Botón de acción rápida (top bar) ───────────────────────── -->
        <Style x:Key="BtnAccion" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Borde"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Borde" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Borde" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ítem de navegación lateral ─────────────────────────────── -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0,12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#9AA3B8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Borde"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Borde" Property="Background" Value="#232840"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Borde" Property="Background" Value="#2D3350"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TabControl de sub-pestañas ─────────────────────────────── -->
        <Style x:Key="ModernTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource ThemeBgContenido}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="TabStripPlacement" Value="Top"/>
        </Style>

        <!-- ── TabItem de sub-pestañas ────────────────────────────────── -->
        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9AA3B8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="TabText"
                                       Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#4A6FE3"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ThemeTabSelBg}"/>
                                <Setter TargetName="TabText"   Property="Foreground"  Value="#4A6FE3"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ThemeTabHoverBg}"/>
                                <Setter TargetName="TabText"   Property="Foreground"  Value="#4A6FE3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- Top bar -->
            <RowDefinition Height="*"/>    <!-- Sidebar + Contenido -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- TOP BAR                                                      -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#252A40">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo y título -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="8"
                            Background="#4A6FE3" Margin="0,0,10,0">
                        <TextBlock Text="SG" FontSize="13" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Sistema de Gestión"
                               FontSize="15" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Usuario + botones de acción rápida -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblUsuario"
                               FontSize="11" Foreground="#9AA3B8"
                               VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="＋ Venta Rápida"
                            Background="#2E7D32" Margin="0,0,6,0"
                            Style="{StaticResource BtnAccion}"
                            Click="BtnVentaRapida_Click"/>
                    <Button Content="＋ Entrada Rápida"
                            Background="#1565C0" Margin="0,0,6,0"
                            Style="{StaticResource BtnAccion}"
                            Click="BtnEntradaRapida_Click"/>
                    <Button Content="＋ Salida Rápida"
                            Background="#6A1B9A"
                            Style="{StaticResource BtnAccion}"
                            Click="BtnSalidaRapida_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- SIDEBAR + CONTENIDO                                         -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── BARRA LATERAL ──────────────────────────────────── -->
            <Border Grid.Column="0" Background="#1A1E2E">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Ítems de navegación -->
                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,8,0,8">

                            <Button x:Name="BtnNav_Articulos"
                                    Content="📋  Artículos"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Articulos_Click"/>
                            <Button x:Name="BtnNav_Pedidos"
                                    Content="📑  Pedidos"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Pedidos_Click"/>
                            <Button x:Name="BtnNav_Traspasos"
                                    Content="🔄  Traspasos"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Traspasos_Click"/>
                            <Button x:Name="BtnNav_Correcciones"
                                    Content="🔧  Correcciones"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Correcciones_Click"/>

                            <Rectangle Height="1" Fill="#252A40" Margin="12,8"/>

                            <Button x:Name="BtnNav_Inventarios"
                                    Content="📊  Inventarios"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Inventarios_Click"/>
                            <Button x:Name="BtnNav_Precios"
                                    Content="💲  Precios"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Precios_Click"/>
                            <Button x:Name="BtnNav_Configuracion"
                                    Content="⚙  Configuración"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Configuracion_Click"/>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Cerrar sesión (fijo al fondo) -->
                    <Border Grid.Row="1"
                            BorderThickness="0,1,0,0"
                            BorderBrush="#252A40">
                        <Button Content="⏻  Cerrar Sesión"
                                Style="{StaticResource NavBtn}"
                                Foreground="#EF5350"
                                Click="BtnCerrarSesion_Click"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── ÁREA DE CONTENIDO (paneles apilados) ───────────── -->
            <Grid Grid.Column="1" Background="{DynamicResource ThemeBgContenido}">

                <!-- Panel Artículos -->
                <local:ArticulosGeneral x:Name="TabArticulos" Visibility="Visible"/>

                <local:PedidosGeneral      x:Name="TabPedidos"
                                           Visibility="Collapsed"/>
                <local:TraspasosGeneral    x:Name="TabTraspasos"
                                           Visibility="Collapsed"/>
                <local:CorreccionesGeneral x:Name="TabCorrecciones"
                                           Visibility="Collapsed"/>

            </Grid>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- OVERLAY MODAL                                                -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid x:Name="OverlayFondo" Visibility="Collapsed" Grid.RowSpan="2"
              Panel.ZIndex="100" Background="#BB000000">
            <Border Background="{DynamicResource ThemeBgPrincipal}"
                    CornerRadius="10" Margin="40"
                    MaxWidth="960" MaxHeight="840"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra superior del overlay con botón cerrar -->
                    <Grid Grid.Row="0" Background="#252A40" x:Name="OverlayTopBar">
                        <Button Content="✕" HorizontalAlignment="Right"
                                Margin="8,4" Padding="10,4"
                                FontSize="13" FontWeight="Bold"
                                Background="Transparent" Foreground="#9AA3B8"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnCerrarOverlay_Click"/>
                    </Grid>

                    <ContentControl x:Name="OverlayContenido" Grid.Row="1"/>
                </Grid>
            </Border>
        </Grid>

    </Grid>

</Window>
