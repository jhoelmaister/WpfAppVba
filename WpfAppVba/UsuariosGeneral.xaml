<UserControl x:Class="WpfAppVba.UsuariosGeneral"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Usuarios" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,10"/>

        <!-- Búsqueda -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtBuscar" Grid.Column="0" Height="30" FontSize="12"
                     Padding="8,0" VerticalContentAlignment="Center"
                     Background="{DynamicResource ThemeInputBg}"
                     Foreground="{DynamicResource ThemeTexto}"
                     BorderBrush="{DynamicResource ThemeBordeInput}"
                     TextChanged="TxtBuscar_TextChanged"/>
            <Button Grid.Column="1" Content="Buscar" Margin="6,0,0,0"
                    Background="{DynamicResource ThemeBtnSecBg}"
                    Foreground="{DynamicResource ThemeTexto}"
                    Click="BtnBuscar_Click" Style="{StaticResource Btn}"/>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="2" CornerRadius="6" ClipToBounds="True"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                Background="{DynamicResource ThemeBgSurface}">
            <DataGrid x:Name="Grid1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      FontSize="12"
                      MouseDoubleClick="Grid1_MouseDoubleClick"
                      PreviewKeyDown="Grid1_PreviewKeyDown">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Línea"     Binding="{Binding Linea}"     Width="60"/>
                    <DataGridTextColumn Header="Código"    Binding="{Binding Codigo}"    Width="70"/>
                    <DataGridTextColumn Header="Cuenta"    Binding="{Binding Cuenta}"    Width="140"/>
                    <DataGridTextColumn Header="Nombres"   Binding="{Binding Nombres}"   Width="*"/>
                    <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="*"/>
                    <DataGridTextColumn Header="Tipo"      Binding="{Binding Tipo}"      Width="80"/>
                    <DataGridTextColumn Header="Estado"    Binding="{Binding EstadoU}"   Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Botones -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="BtnNuevo"    Content="Nuevo Usuario"    Margin="0,0,6,0" Background="#1A73E8" Foreground="White"   Click="BtnNuevo_Click"    Style="{StaticResource Btn}"/>
            <Button x:Name="BtnEditar"   Content="Editar Usuario"   Margin="0,0,6,0" Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeTexto}" Click="BtnEditar_Click"   Style="{StaticResource Btn}"/>
            <Button x:Name="BtnEliminar" Content="Eliminar Usuario" Margin="0,0,6,0" Background="#D93025" Foreground="White"   Click="BtnEliminar_Click" Style="{StaticResource Btn}"/>
            <Button Content="Actualizar"                             Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeTexto}" Click="BtnActualizar_Click" Style="{StaticResource Btn}"/>
        </StackPanel>
    </Grid>
</UserControl>
