<UserControl x:Class="WpfAppVba.FacturasDetalle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfAppVba"
             Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>

        <!-- ── Botones con esquinas redondeadas ── -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimario"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"      Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ThemeBtnSecFg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
        </Style>
        <Style x:Key="BtnPeligro" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- ── Input redondeado ── -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height"                   Value="28"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="Padding"                  Value="7,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground"               Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Etiquetas ── -->
        <Style x:Key="LblMuted" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="Foreground"        Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,4,0"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="10,8"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0  Encabezado -->
            <RowDefinition Height="*"/>     <!-- 1  TabControl -->
            <RowDefinition Height="90"/>    <!-- 2  Observación -->
            <RowDefinition Height="Auto"/>  <!-- 3  Totales -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- 0 · ENCABEZADO                                          -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <StackPanel>

                <!-- Fila 1: ícono + título + doc + badges + Guardar/Cancelar -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="#EDE9FE" Margin="0,0,10,0">
                            <TextBlock Text="🧾" FontSize="15"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="LblTitulo"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTexto}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="Documento "
                                           FontSize="11"
                                           Foreground="{DynamicResource ThemeTextoSec}"/>
                                <TextBlock x:Name="LblDocNum"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThemeTexto}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Badges de estado + cuenta -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="Estado:" Style="{StaticResource LblMuted}"/>
                        <Border x:Name="BadgeEstado"
                                CornerRadius="10" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock x:Name="TxtBadgeEstado"
                                       FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="Estado de cuenta:" Style="{StaticResource LblMuted}" Margin="12,0,4,0"/>
                        <Border x:Name="BadgeEstadoC"
                                CornerRadius="10" Padding="8,3">
                            <TextBlock x:Name="TxtBadgeEstadoC"
                                       FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Guardar / Cancelar -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Cancelar" Style="{StaticResource BtnSecundario}"
                                Margin="0,0,6,0" Click="BtnCancelar_Click"/>
                        <Button Content="💾 Guardar"
                                Height="30" Padding="14,0"
                                FontSize="12" FontWeight="SemiBold"
                                Style="{StaticResource BtnPrimario}"
                                Click="BtnGuardar_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Fila 2: campos en línea -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="134"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="8"/>
                        <!-- Tercero: código + descripción + botón -->
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <!-- Referencia -->
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="8"/>
                        <!-- Estado -->
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>

                    <!-- Doc. Factura -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Doc. Factura" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_DocumentoF" Style="{StaticResource ModernInput}"
                                 IsEnabled="False"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <!-- Fecha -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fecha" Style="{StaticResource LblMuted}"/>
                        <DatePicker x:Name="Box_Fecha" Height="28" FontSize="12"
                                    SelectedDateChanged="Campo_DateChanged"/>
                    </StackPanel>

                    <!-- Hora -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Hora" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_Hora" Style="{StaticResource ModernInput}"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <!-- Tercero: código -->
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Tercero" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_Tercero_Identificador"
                                 Style="{StaticResource ModernInput}"
                                 PreviewTextInput="Box_Numeros_PreviewTextInput"
                                 TextChanged="Box_Tercero_Identificador_TextChanged"/>
                    </StackPanel>

                    <!-- Botón buscar tercero -->
                    <Button Grid.Column="8" Content="···"
                            Height="28" Width="30" Padding="0"
                            Style="{StaticResource BtnSecundario}"
                            Margin="0,14,0,0"
                            Click="BtnBuscarTercero_Click"/>

                    <!-- Descripción tercero -->
                    <StackPanel Grid.Column="10">
                        <TextBlock Text=" " Style="{StaticResource LblMuted}"/>
                        <Border Height="28" Background="{DynamicResource ThemeBgReadOnly}"
                                BorderBrush="{DynamicResource ThemeBorde}"
                                BorderThickness="1" CornerRadius="5"
                                Padding="7,0">
                            <TextBlock x:Name="Box_Tercero_Descripcion"
                                       FontSize="12"
                                       Foreground="{DynamicResource ThemeTextoMuted}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </StackPanel>

                    <!-- Referencia -->
                    <StackPanel Grid.Column="12">
                        <TextBlock Text="Referencia" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_Referencia" Style="{StaticResource ModernInput}"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <!-- Estado (manual) -->
                    <StackPanel Grid.Column="14">
                        <TextBlock Text="Estado" Style="{StaticResource LblMuted}"/>
                        <ComboBox x:Name="Box_Estado" Height="28" FontSize="12"
                                  SelectionChanged="Box_Estado_SelectionChanged">
                            <ComboBoxItem Content="pendiente"/>
                            <ComboBoxItem Content="entregado"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Emisión / edición (readonly) -->
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="Emisión:" Style="{StaticResource LblMuted}"/>
                    <TextBlock x:Name="Box_Emision"
                               FontSize="10" Foreground="{DynamicResource ThemeTexto}"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="Edición:" Style="{StaticResource LblMuted}"/>
                    <TextBlock x:Name="Box_Edicion"
                               FontSize="10" Foreground="{DynamicResource ThemeTexto}"
                               VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- 1 · TABCONTROL                                          -->
        <!-- ════════════════════════════════════════════════════════ -->
        <TabControl x:Name="TabControl1" Grid.Row="1"
                    Background="{DynamicResource ThemeBgContenido}"
                    BorderThickness="0" Padding="0">

            <!-- ──────────────────────────────────────────────────── -->
            <!-- TAB 1: LÍNEAS DE LA FACTURA                          -->
            <!-- ──────────────────────────────────────────────────── -->
            <TabItem Header="Líneas de la factura">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar líneas -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource ThemeBgSurface}"
                            BorderBrush="{DynamicResource ThemeBorde}"
                            BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Insertar" Margin="0,0,5,0"
                                    Style="{StaticResource BtnSecundario}"
                                    Click="BtnInsertar_Click"/>
                            <Button Content="Nueva línea" Margin="0,0,5,0"
                                    Style="{StaticResource BtnSecundario}"
                                    Click="BtnNuevaLinea_Click"/>
                            <Button Content="Duplicar" Margin="0,0,5,0"
                                    Style="{StaticResource BtnSecundario}"
                                    Click="BtnDuplicarLinea_Click"/>
                            <Button Content="Eliminar línea"
                                    Style="{StaticResource BtnPeligro}"
                                    Click="BtnEliminarLinea_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Grid líneas -->
                    <DataGrid x:Name="GridItems" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="{DynamicResource ThemeBorde}"
                              BorderThickness="0"
                              FontSize="12"
                              RowHeight="32"
                              CellEditEnding="GridItems_CellEditEnding"
                              PreparingCellForEdit="GridItems_PreparingCellForEdit"
                              ScrollViewer.PanningMode="VerticalOnly">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
                                <Setter Property="Foreground"      Value="{DynamicResource ThemeTextoSec}"/>
                                <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding"         Value="8,5"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Lín." Binding="{Binding Linea}"
                                                Width="42" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"        Value="{DynamicResource ThemeTextoSec}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin"            Value="8,0,0,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Concepto" Binding="{Binding Concepto}" Width="*"/>
                            <DataGridTemplateColumn Header="Categoría" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CategoriaDescripcion}"
                                                   Margin="6,0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{x:Static local:FacturasDetalle.CategoriasCombo}"
                                                  DisplayMemberPath="Descripcion"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding CategoriaId, UpdateSourceTrigger=PropertyChanged}"
                                                  FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Importe"
                                                Binding="{Binding Importe, StringFormat=#\,##0.00}"
                                                Width="100"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ──────────────────────────────────────────────────── -->
            <!-- TAB 2: COBROS                                        -->
            <!-- ──────────────────────────────────────────────────── -->
            <TabItem x:Name="TabCobros" Header="Cobros">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar cobros -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource ThemeBgSurface}"
                            BorderBrush="{DynamicResource ThemeBorde}"
                            BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Nueva línea"
                                    Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0"
                                    Click="BtnNuevaLineaCobro_Click"/>
                            <Button Content="Insertar"
                                    Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0"
                                    Click="BtnInsertarCobro_Click"/>
                            <Button Content="Eliminar línea"
                                    Style="{StaticResource BtnPeligro}"
                                    Margin="0,0,5,0"
                                    Click="BtnEliminarLineaCobro_Click"/>
                            <Button x:Name="BtnCobrarDocumento"
                                    Content="Cobrar documento"
                                    Style="{StaticResource BtnPrimario}"
                                    Click="BtnCobrarDocumento_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Grid cobros (transaccionesF) -->
                    <DataGrid x:Name="GridCobros" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="{DynamicResource ThemeBorde}"
                              BorderThickness="0"
                              FontSize="12"
                              RowHeight="32"
                              CellEditEnding="GridCobros_CellEditEnding"
                              PreparingCellForEdit="GridCobros_PreparingCellForEdit"
                              ScrollViewer.PanningMode="VerticalOnly">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
                                <Setter Property="Foreground"      Value="{DynamicResource ThemeTextoSec}"/>
                                <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding"         Value="8,5"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Lín."
                                                Binding="{Binding Linea}"
                                                Width="46" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Fecha" Width="108">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FechaStr}"
                                                   Margin="6,0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <DatePicker SelectedDate="{Binding FechaDate, UpdateSourceTrigger=PropertyChanged}"
                                                    FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Hora"
                                                Binding="{Binding HoraStr}"   Width="74"/>
                            <DataGridTextColumn Header="Descripción"
                                                Binding="{Binding Descripcion}" Width="*"/>
                            <DataGridTemplateColumn Header="Forma" Width="108">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Forma}"
                                                   Margin="6,0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding Forma, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{x:Static local:PedidosDetalle.FormasTrasaccion}"
                                                  FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Importe"
                                                Binding="{Binding Importe, StringFormat=#\,##0.##}"
                                                Width="90"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- 2 · OBSERVACIÓN                                         -->
        <!-- ════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Row="2"
                   Background="{DynamicResource ThemeBgSurface}"
                   Margin="14,8">
            <TextBlock DockPanel.Dock="Top" Text="Observación"
                       Style="{StaticResource SectionHeader}"/>
            <Border CornerRadius="6" BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeBordeInput}" ClipToBounds="True">
                <TextBox x:Name="Box_Observacion" FontSize="12"
                         Padding="7,5"
                         BorderThickness="0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="Campo_TextChanged"/>
            </Border>
        </DockPanel>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- 3 · BARRA DE TOTALES                                    -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Total importe -->
                <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Importe total" FontSize="10"
                                   Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtTotalImporte"
                                   FontSize="17" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" Text="0.00"
                                   Foreground="#065F46"/>
                    </StackPanel>
                </Border>

                <!-- Cobrado -->
                <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Cobrado" FontSize="10"
                                   Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtTotalCobrado"
                                   FontSize="17" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" Text="0.00"
                                   Foreground="#1E40AF"/>
                    </StackPanel>
                </Border>

                <!-- Saldo -->
                <Border Style="{StaticResource MetricCard}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Saldo" FontSize="10"
                                   Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtTotalSaldo"
                                   FontSize="17" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" Text="0.00"
                                   Foreground="#991B1B"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
