<UserControl x:Class="WpfAppVba.MovimientosGeneral"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"      Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ThemeBtnSecFg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
        </Style>

        <!-- Input redondeado -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height"                   Value="30"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground"               Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Búsqueda + descripción -->
            <RowDefinition Height="*"/>       <!-- DataGrid -->
            <RowDefinition Height="Auto"/>    <!-- Totales -->
            <RowDefinition Height="Auto"/>    <!-- Botón procesar -->
        </Grid.RowDefinitions>

        <!-- ── Búsqueda ──────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Código:" VerticalAlignment="Center"
                       FontSize="12" Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,6,0"/>
            <TextBox x:Name="TxtCodigo" Grid.Column="1"
                     Style="{StaticResource ModernInput}" Margin="0,0,6,0"
                     KeyDown="TxtCodigo_KeyDown"/>
            <Button x:Name="BtnBuscar" Grid.Column="2" Content="🔍 Buscar artículo"
                    Style="{StaticResource BtnPrimario}" Margin="0,0,12,0"
                    Click="BtnBuscar_Click"/>
            <TextBlock x:Name="LblDescripcion" Grid.Column="3"
                       VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeTexto}" TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- ── DataGrid ──────────────────────────────────────── -->
        <DataGrid x:Name="Grid1" Grid.Row="1"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                  FontSize="11">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Línea"      Binding="{Binding Linea}"       Width="50"/>
                <DataGridTextColumn Header="Fecha"      Binding="{Binding FechaStr}"     Width="130"/>
                <DataGridTextColumn Header="Movimiento" Binding="{Binding Movimiento}"   Width="*"/>
                <DataGridTextColumn Header="Forma"      Binding="{Binding Forma}"        Width="70"/>
                <DataGridTextColumn Header="Contable"   Binding="{Binding Contable, StringFormat=#\,##0.##}"  Width="70"
                                    ElementStyle="{StaticResource CeldaNumero}"/>
                <DataGridTextColumn Header="Cantidad"   Binding="{Binding Cantidad, StringFormat=#\,##0.##}"  Width="70"
                                    ElementStyle="{StaticResource CeldaNumero}"/>
                <DataGridTextColumn Header="Unitario"   Binding="{Binding Unitario, StringFormat=#\,##0.##}"  Width="70"
                                    ElementStyle="{StaticResource CeldaNumero}"/>
                <DataGridTextColumn Header="SubTotal"   Binding="{Binding SubTotal, StringFormat=#\,##0.##}"  Width="80"
                                    ElementStyle="{StaticResource CeldaNumero}"/>
                <DataGridTextColumn Header="Stock"      Binding="{Binding Stock,    StringFormat=#\,##0.##}"  Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource CeldaNumero}">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Totales ───────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                CornerRadius="6" Margin="0,8,0,0" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Total Compras:"  FontSize="12" Foreground="{DynamicResource ThemeTextoSec}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalCompras"  FontSize="12" FontWeight="Bold" Foreground="#1A73E8"  VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Total Ventas:"   FontSize="12" Foreground="{DynamicResource ThemeTextoSec}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalVentas"   FontSize="12" FontWeight="Bold" Foreground="#D93025"  VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Total Entradas:" FontSize="12" Foreground="{DynamicResource ThemeTextoSec}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalEntradas" FontSize="12" FontWeight="Bold" Foreground="#2E7D32"  VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Total Salidas:"  FontSize="12" Foreground="{DynamicResource ThemeTextoSec}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalSalidas"  FontSize="12" FontWeight="Bold" Foreground="#E65100"  VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Total Ingresos:" FontSize="12" Foreground="{DynamicResource ThemeTextoSec}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalIngresos" FontSize="12" FontWeight="Bold" Foreground="#00897B"  VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Total Egresos:"  FontSize="12" Foreground="{DynamicResource ThemeTextoSec}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalEgresos"  FontSize="12" FontWeight="Bold" Foreground="#6A1B9A"  VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Botón Procesar ────────────────────────────────── -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Procesar / Actualizar" Style="{StaticResource BtnSecundario}"
                    Click="BtnProcesar_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
