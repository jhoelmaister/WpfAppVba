<Window x:Class="WpfAppVba.InventariosDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventario / Apertura" Height="580" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource ThemeBgPrincipal}"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock x:Name="LblTitulo" Grid.Row="0" FontSize="15" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,12"/>

        <!-- Fila de cabecera: Doc. Inventario / Fecha / Hora -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="95"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Doc. Inventario:" Style="{StaticResource Lbl}"
                       VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="Box_DocumentoI" Grid.Column="1" Height="28" FontSize="12"
                     Padding="6,4" BorderBrush="{DynamicResource ThemeBordeInput}"
                     TextChanged="Campo_TextChanged"
                     PreviewTextInput="Box_Numeros_PreviewTextInput"/>

            <TextBlock Grid.Column="3" Text="Fecha:" Style="{StaticResource Lbl}"
                       VerticalAlignment="Center" Margin="0,0,6,0"/>
            <DatePicker x:Name="Box_Fecha" Grid.Column="4" Height="28" FontSize="12"
                        SelectedDateChanged="Campo_DateChanged"/>

            <TextBlock Grid.Column="6" Text="Hora (HH:mm:ss):" Style="{StaticResource Lbl}"
                       VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="Box_Hora" Grid.Column="7" Height="28" FontSize="12"
                     Padding="6,4" BorderBrush="{DynamicResource ThemeBordeInput}"
                     TextChanged="Campo_TextChanged"/>
        </Grid>

        <!-- Observaciones -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Observaciones:" Style="{StaticResource Lbl}"
                       VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="Box_Observacion" Grid.Column="1" Height="28" FontSize="12"
                     Padding="6,4" BorderBrush="{DynamicResource ThemeBordeInput}"
                     TextChanged="Campo_TextChanged"/>
        </Grid>

        <!-- Total unidades -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Total Unidades:" FontSize="12" Foreground="{DynamicResource ThemeTextoSec}"
                       VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock x:Name="TxtTotalUnidades" FontSize="12" FontWeight="SemiBold"
                       VerticalAlignment="Center" Text="0.00"/>
        </StackPanel>

        <!-- Separador -->
        <Separator Grid.Row="4" Margin="0,0,0,8"/>

        <!-- Encabezado artículos + botones de línea -->
        <Grid Grid.Row="5" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Artículos del inventario:" FontSize="12"
                       FontWeight="SemiBold" Foreground="{DynamicResource ThemeTexto}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Buscar Artículos" Margin="0,0,6,0"
                        Background="#1A73E8" Foreground="White"
                        Style="{StaticResource Btn}"
                        Click="BtnBuscarArticulos_Click"/>
                <Button Content="Buscar Artículo" Margin="0,0,6,0"
                        Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                        Style="{StaticResource Btn}"
                        Click="BtnBuscarArticulo_Click"/>
                <Button Content="Insertar" Margin="0,0,6,0"
                        Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                        Style="{StaticResource Btn}"
                        Click="BtnInsertar_Click"/>
                <Button Content="Nueva Línea" Margin="0,0,6,0"
                        Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeBtnSecFg}"
                        Style="{StaticResource Btn}"
                        Click="BtnNuevaLinea_Click"/>
                <Button Content="Eliminar Línea"
                        Background="#D93025" Foreground="White"
                        Style="{StaticResource Btn}"
                        Click="BtnEliminarLinea_Click"/>
            </StackPanel>
        </Grid>

        <!-- DataGrid de ítems -->
        <DataGrid x:Name="GridItems" Grid.Row="6"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                  FontSize="12"
                  CellEditEnding="GridItems_CellEditEnding"
                  PreparingCellForEdit="GridItems_PreparingCellForEdit">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"       Width="50"  IsReadOnly="True"/>
                <DataGridTextColumn Header="Código"      Binding="{Binding Codigo}"      Width="80"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"   IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Cantidad" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Cantidad, StringFormat=#\,##0.##}"
                                       HorizontalAlignment="Right" TextAlignment="Right"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Cantidad, UpdateSourceTrigger=PropertyChanged, StringFormat=#\,##0.##}"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Right"
                                     TextAlignment="Right"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Botón guardar -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Guardar" Background="#1A73E8" Foreground="White"
                    Style="{StaticResource Btn}"
                    Click="BtnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Window>
