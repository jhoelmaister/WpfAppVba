<UserControl x:Class="WpfAppVba.PreciosGeneral"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchInput" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeBtnSecFg}"/>
        </Style>
        <Style x:Key="BtnPeligro" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#D93025"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo: TreeView -->
        <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="6" ClipToBounds="True"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1" Background="{DynamicResource ThemeBgSurface}">
            <TreeView x:Name="Tree1"
                      SelectedItemChanged="Tree1_SelectedItemChanged"
                      PreviewMouseLeftButtonDown="Tree1_PreviewMouseLeftButtonDown"
                      FontSize="12"/>
        </Border>

        <!-- Panel derecho -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Buscador / filtro región -->
                <RowDefinition Height="*"/>      <!-- Grid artículos / Grid precios -->
                <RowDefinition Height="Auto"/>   <!-- Botones -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Buscador -->
            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtBuscar" Grid.Column="0" Style="{StaticResource SearchInput}" Margin="0,0,6,0"
                         KeyDown="TxtBuscar_KeyDown"/>
                <Button Content="Buscar" Grid.Column="1"
                        Style="{StaticResource BtnSecundario}"
                        Click="BtnBuscar_Click"/>
            </Grid>

            <!-- Filtro de región (arriba de GridPrecios) -->
            <Grid Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Región:" VerticalAlignment="Center"
                               FontSize="12" Margin="0,0,6,0"
                               Foreground="{DynamicResource ThemeTextoSec}"/>
                    <ComboBox x:Name="CmbRegion" Width="200" Height="26" FontSize="12"
                              DisplayMemberPath="Descripcion" SelectedValuePath="Id"
                              SelectionChanged="CmbRegion_SelectionChanged"/>
                </StackPanel>
            </Grid>

            <!-- Grid de artículos -->
            <Border Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" CornerRadius="6" ClipToBounds="True"
                    BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                    Background="{DynamicResource ThemeBgSurface}">
            <DataGrid x:Name="Grid1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      FontSize="12"
                      SelectionChanged="Grid1_SelectionChanged"
                      MouseDoubleClick="Grid1_MouseDoubleClick"
                      PreviewKeyDown="Grid1_PreviewKeyDown">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"       Width="55"/>
                    <DataGridTextColumn Header="Código"      Binding="{Binding Codigo}"      Width="80"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                    <DataGridTextColumn Header="Estado"      Binding="{Binding Estado}"      Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
            </Border>

            <!-- Grid de precios (historial) -->
            <Border Grid.Row="1" Grid.Column="1" Margin="8,0,0,0" CornerRadius="6" ClipToBounds="True"
                    BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                    Background="{DynamicResource ThemeBgSurface}">
            <DataGrid x:Name="GridPrecios"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      FontSize="12"
                      MouseDoubleClick="GridPrecios_MouseDoubleClick"
                      PreviewKeyDown="GridPrecios_PreviewKeyDown">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Línea"  Binding="{Binding Linea}"    Width="55"/>
                    <DataGridTextColumn Header="Código" Binding="{Binding Codigo}"   Width="80"/>
                    <DataGridTextColumn Header="Fecha"  Binding="{Binding FechaStr}" Width="160"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding Precio, StringFormat=#\,##0.##}" Width="120"
                                        ElementStyle="{StaticResource CeldaNumero}"/>
                </DataGrid.Columns>
            </DataGrid>
            </Border>

            <!-- Botones -->
            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnListaPreciosPdf" Content="📄 Lista de Precios PDF" Grid.Column="0"
                        HorizontalAlignment="Left" Style="{StaticResource BtnSecundario}"
                        Click="BtnListaPreciosPdf_Click"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnNuevoPrecio"    Content="Nuevo Precio"    Margin="0,0,6,0" Style="{StaticResource BtnPrimario}"   Click="BtnNuevoPrecio_Click"/>
                    <Button x:Name="BtnEditarPrecio"   Content="Editar Precio"   Margin="0,0,6,0" Style="{StaticResource BtnSecundario}" Click="BtnEditarPrecio_Click"/>
                    <Button x:Name="BtnEliminarPrecio" Content="Eliminar Precio" Margin="0,0,6,0" Style="{StaticResource BtnPeligro}"    Click="BtnEliminarPrecio_Click"/>
                    <Button Content="Cambiar Estado"  Margin="0,0,6,0" Style="{StaticResource BtnSuccess}"    Click="BtnCambiarEstado_Click"/>
                    <Button Content="Actualizar"      Margin="0,0,0,0" Style="{StaticResource BtnSecundario}" Click="BtnActualizar_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
