<Window x:Class="WpfAppVba.PreciosGeneral"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Precios de Artículos" Height="640" Width="900"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource ThemeBgPrincipal}">

    <Window.Resources>
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeBtnSecFg}"/>
        </Style>
        <Style x:Key="BtnPeligro" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#D93025"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo: TreeView -->
        <Border Grid.Column="0" Margin="0,0,8,0" BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1" Background="{DynamicResource ThemeBgSurface}">
            <TreeView x:Name="Tree1"
                      SelectedItemChanged="Tree1_SelectedItemChanged"
                      PreviewMouseLeftButtonDown="Tree1_PreviewMouseLeftButtonDown"
                      FontSize="12"/>
        </Border>

        <!-- Panel derecho -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Buscador -->
                <RowDefinition Height="*"/>      <!-- Grid artículos -->
                <RowDefinition Height="Auto"/>   <!-- Etiqueta historial -->
                <RowDefinition Height="*"/>      <!-- Grid precios -->
                <RowDefinition Height="Auto"/>   <!-- Botones -->
            </Grid.RowDefinitions>

            <!-- Buscador -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtBuscar" Grid.Column="0" Height="28" FontSize="12"
                         Padding="6,4" BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,6,0"
                         KeyDown="TxtBuscar_KeyDown"/>
                <Button Content="Buscar" Grid.Column="1"
                        Style="{StaticResource BtnSecundario}"
                        Click="BtnBuscar_Click"/>
            </Grid>

            <!-- Grid de artículos -->
            <DataGrid x:Name="Grid1" Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                      FontSize="12"
                      SelectionChanged="Grid1_SelectionChanged"
                      MouseDoubleClick="Grid1_MouseDoubleClick"
                      PreviewKeyDown="Grid1_PreviewKeyDown">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"       Width="55"/>
                    <DataGridTextColumn Header="Código"      Binding="{Binding Codigo}"      Width="80"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                    <DataGridTextColumn Header="Estado"      Binding="{Binding Estado}"      Width="90"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Filtro de región + etiqueta historial -->
            <Grid Grid.Row="2" Margin="0,8,0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Fila 0: selector de región -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,4">
                    <TextBlock Text="Región:" VerticalAlignment="Center"
                               FontSize="12" Margin="0,0,6,0"
                               Foreground="{DynamicResource ThemeTextoSec}"/>
                    <ComboBox x:Name="CmbRegion" Width="200" Height="26" FontSize="12"
                              DisplayMemberPath="Descripcion" SelectedValuePath="Id"
                              SelectionChanged="CmbRegion_SelectionChanged"/>
                    <Button Content="Gestionar Regiones" Margin="6,0,0,0" Height="26"
                            Padding="10,0" FontSize="11" BorderThickness="0" Cursor="Hand"
                            Background="#0277BD" Foreground="White"
                            Click="BtnGestionarRegiones_Click"/>
                </StackPanel>

                <!-- Fila 1: etiqueta historial (ancho completo, blanco) -->
                <TextBlock x:Name="LblHistorial" Grid.Row="1"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="White"
                           Text="Historial de precios:"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>

            <!-- Grid de precios (historial) -->
            <DataGrid x:Name="GridPrecios" Grid.Row="3"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                      FontSize="12"
                      MouseDoubleClick="GridPrecios_MouseDoubleClick"
                      PreviewKeyDown="GridPrecios_PreviewKeyDown">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Línea"  Binding="{Binding Linea}"    Width="55"/>
                    <DataGridTextColumn Header="Fecha"  Binding="{Binding FechaStr}" Width="160"/>
                    <DataGridTextColumn Header="Región" Binding="{Binding Region}"   Width="*"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding Precio, StringFormat=#\,##0.##}" Width="120"
                                        ElementStyle="{StaticResource CeldaNumero}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Botones -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Nuevo Precio"    Margin="0,0,6,0" Style="{StaticResource BtnPrimario}"   Click="BtnNuevoPrecio_Click"/>
                <Button Content="Editar Precio"   Margin="0,0,6,0" Style="{StaticResource BtnSecundario}" Click="BtnEditarPrecio_Click"/>
                <Button Content="Eliminar Precio" Margin="0,0,6,0" Style="{StaticResource BtnPeligro}"    Click="BtnEliminarPrecio_Click"/>
                <Button Content="Cambiar Estado"  Margin="0,0,6,0" Style="{StaticResource BtnSuccess}"    Click="BtnCambiarEstado_Click"/>
                <Button Content="Actualizar"      Margin="0,0,0,0" Style="{StaticResource BtnSecundario}" Click="BtnActualizar_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
