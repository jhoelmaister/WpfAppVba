<UserControl x:Class="WpfAppVba.ArticulosDetalle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="CaretBrush" Value="#4F8EF7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReadOnlyInput" TargetType="TextBox" BasedOn="{StaticResource ModernInput}">
            <Setter Property="Background" Value="{DynamicResource ThemeBgReadOnly}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsEnabled" Value="False"/>
        </Style>

        <Style x:Key="SelectorBtn" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeBtnSecFg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorde}"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4F8EF7"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ ENCABEZADO ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="#1A3A6B" Margin="0,0,12,0">
                        <TextBlock Text="&#x1F4E6;" FontSize="18" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="LblTitulo" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeTexto}"/>
                        <TextBlock Text="Gestión de Artículos" FontSize="11"
                                   Foreground="{DynamicResource ThemeTextoSec}" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- ID interno (oculto): no se muestra al usuario, pero Box_Identificador
                     se conserva porque el code-behind lo usa para guardar el GUID. -->
                <Border Grid.Column="1" CornerRadius="6" Background="{DynamicResource ThemeBgReadOnly}"
                        Padding="10,4" VerticalAlignment="Center"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ID" FontSize="10" Foreground="{DynamicResource ThemeTextoMuted}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"/>
                        <TextBox x:Name="Box_Identificador" Width="48" Height="24"
                                 FontSize="12" FontWeight="Bold" Padding="4,0"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#4F8EF7"
                                 IsEnabled="False"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ CONTENIDO ══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,16"
                      PanningMode="VerticalOnly">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ▸ CARD: IDENTIFICACIÓN  (col izq, fila 1) -->
                <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● IDENTIFICACIÓN"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="CÓDIGO"/>
                                <TextBox x:Name="Box_Codigo" Style="{StaticResource ModernInput}"
                                         MaxLength="20"
                                         TextChanged="Campo_TextChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="ÍNDICE"/>
                                <TextBox x:Name="Box_Indice" Style="{StaticResource ModernInput}"
                                         TextChanged="Campo_TextChanged"
                                         PreviewTextInput="Box_Numeros_PreviewTextInput"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ▸ CARD: CLASIFICACIÓN  (col der, filas 1-2) -->
                <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource CardBorder}" Margin="0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● CLASIFICACIÓN"/>

                        <!-- Familia -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource SectionLabel}" Text="FAMILIA"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="Box_Identificador_Familia" Grid.Column="0"
                                         Style="{StaticResource ModernInput}"
                                         TextChanged="Box_Familia_TextChanged"
                                         PreviewTextInput="Box_Numeros_PreviewTextInput"/>
                                <Border Grid.Column="2" CornerRadius="6"
                                        Background="{DynamicResource ThemeBgReadOnly}"
                                        Padding="8,0">
                                    <TextBlock x:Name="Box_Familia_Descripcion"
                                               VerticalAlignment="Center" FontSize="12"
                                               Foreground="{DynamicResource ThemeTextoMuted}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                                <Button x:Name="BtnVerFamilias" Grid.Column="4"
                                        Style="{StaticResource SelectorBtn}"
                                        Content="&#x1F50D; Familias"
                                        Click="BtnVerFamilias_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- Industria -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource SectionLabel}" Text="INDUSTRIA"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="Box_Identificador_Industria" Grid.Column="0"
                                         Style="{StaticResource ModernInput}"
                                         TextChanged="Box_Industria_TextChanged"
                                         PreviewTextInput="Box_Numeros_PreviewTextInput"/>
                                <Border Grid.Column="2" CornerRadius="6"
                                        Background="{DynamicResource ThemeBgReadOnly}"
                                        Padding="8,0">
                                    <TextBlock x:Name="Box_Industria_Descripcion"
                                               VerticalAlignment="Center" FontSize="12"
                                               Foreground="{DynamicResource ThemeTextoMuted}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                                <Button x:Name="BtnVerIndustrias" Grid.Column="4"
                                        Style="{StaticResource SelectorBtn}"
                                        Content="&#x1F50D; Industrias"
                                        Click="BtnVerIndustrias_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- Categoría -->
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabel}" Text="CATEGORÍA"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="Box_Identificador_Categoria" Grid.Column="0"
                                         Style="{StaticResource ModernInput}"
                                         TextChanged="Box_Categoria_TextChanged"
                                         PreviewTextInput="Box_Numeros_PreviewTextInput"/>
                                <Border Grid.Column="2" CornerRadius="6"
                                        Background="{DynamicResource ThemeBgReadOnly}"
                                        Padding="8,0">
                                    <TextBlock x:Name="Box_Categoria_Descripcion"
                                               VerticalAlignment="Center" FontSize="12"
                                               Foreground="{DynamicResource ThemeTextoMuted}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                                <Button x:Name="BtnVerCategorias" Grid.Column="4"
                                        Style="{StaticResource SelectorBtn}"
                                        Content="&#x1F50D; Categorías"
                                        Click="BtnVerCategorias_Click"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ▸ CARD: DETALLES DEL ARTÍCULO  (col izq, fila 2) -->
                <Border Grid.Column="0" Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● DETALLES DEL ARTÍCULO"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource SectionLabel}" Text="DESCRIPCIÓN"/>
                            <TextBox x:Name="Box_Descripcion" Style="{StaticResource ModernInput}"
                                     TextChanged="Campo_TextChanged"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabel}" Text="MODELO"/>
                            <TextBox x:Name="Box_Modelo" Style="{StaticResource ModernInput}"
                                     TextChanged="Campo_TextChanged"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ▸ CARD: OBSERVACIONES  (ancho completo, fila 3) -->
                <Border Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="3"
                        Style="{StaticResource CardBorder}" Margin="0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● OBSERVACIONES"/>
                        <Border BorderBrush="{DynamicResource ThemeBordeInput}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource ThemeInputBg}">
                            <TextBox x:Name="Box_Observacion"
                                     MinHeight="80" FontSize="13" Padding="10,8"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource ThemeTexto}"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="Campo_TextChanged"/>
                        </Border>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>

        <!-- ══ BARRA DE ACCIONES ══════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnVerMovimientos" Grid.Column="0"
                        HorizontalAlignment="Left"
                        Content="&#x1F4CA; Ver Movimientos"
                        Padding="16,0" FontSize="12"
                        Background="{DynamicResource ThemeBgReadOnly}"
                        Foreground="#4F8EF7"
                        BorderThickness="1" BorderBrush="#1A3A6B"
                        Visibility="Collapsed"
                        Style="{StaticResource BtnBase}"
                        Click="BtnVerMovimientos_Click"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Cancelar"
                            Padding="18,0" Margin="0,0,10,0"
                            Style="{StaticResource BtnSecundario}"
                            Click="BtnCancelar_Click"/>
                    <Button Content="&#x1F4BE; Guardar"
                            Padding="18,0"
                            Style="{StaticResource BtnPrimario}"
                            Click="BtnGuardar_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
