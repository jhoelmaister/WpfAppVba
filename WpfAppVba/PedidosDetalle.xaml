<UserControl x:Class="WpfAppVba.PedidosDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfAppVba"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <!-- ── Botones ─────────────────────────────────────────────────────── -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeBtnSecFg}"/>
        </Style>
        <Style x:Key="BtnPeligro" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#D93025"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnAmarillo" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#F4B400"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- ── Etiqueta inline ────────────────────────────────────────────── -->
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize"           Value="11"/>
            <Setter Property="Foreground"         Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="Margin"             Value="0,0,5,0"/>
        </Style>

        <!-- ── Etiqueta muted (emision/edicion) ─────────────────────────── -->
        <Style x:Key="LblMuted" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="Foreground"        Value="#999"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,4,0"/>
        </Style>

        <!-- ── Alineación derecha en celdas ──────────────────────────────── -->
        <Style x:Key="RightCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- ── Diseño moderno (cards / inputs) ───────────────────────────── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="CaretBrush" Value="#4F8EF7"/>
        </Style>

        <Style x:Key="ReadOnlyInput" TargetType="TextBox" BasedOn="{StaticResource ModernInput}">
            <Setter Property="Background" Value="{DynamicResource ThemeBgReadOnly}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
        </Style>

        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4F8EF7"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Encabezado -->
            <RowDefinition Height="Auto"/>  <!-- 1: Card de cabecera -->
            <RowDefinition Height="*"/>     <!-- 2: TabControl -->
            <RowDefinition Height="Auto"/>  <!-- 3: Totales + acciones -->
        </Grid.RowDefinitions>

        <!-- ══ ENCABEZADO ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="#1A3A6B" Margin="0,0,12,0">
                        <TextBlock Text="&#x1F9FE;" FontSize="18" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="LblTitulo" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeTexto}"/>
                        <TextBlock Text="Gestión de Pedidos" FontSize="11"
                                   Foreground="{DynamicResource ThemeTextoSec}" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Tipo de movimiento -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TIPO" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeTextoMuted}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CboMovimiento" Width="110" Height="30" FontSize="12"
                              SelectionChanged="CboMovimiento_SelectionChanged">
                        <ComboBoxItem Content="Venta"/>
                        <ComboBoxItem Content="Compra"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ CARD DE CABECERA ════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="16,16,16,0">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <!-- Doc. Pedido -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="DOC. PEDIDO"/>
                        <TextBox x:Name="Box_DocumentoP" Style="{StaticResource ModernInput}"
                                 PreviewTextInput="Box_Numeros_PreviewTextInput"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <!-- Fecha -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="FECHA"/>
                        <DatePicker x:Name="Box_Fecha" Height="34" FontSize="13"
                                    VerticalContentAlignment="Center"
                                    SelectedDateChanged="Campo_DateChanged"/>
                    </StackPanel>

                    <!-- Hora -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="HORA"/>
                        <TextBox x:Name="Box_Hora" Style="{StaticResource ModernInput}"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <!-- Estado -->
                    <StackPanel Grid.Column="6">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="ESTADO"/>
                        <TextBox x:Name="Box_Estado" Style="{StaticResource ReadOnlyInput}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tercero -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="TERCERO"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="Box_Tercero_Identificador"
                                     Style="{StaticResource ModernInput}"
                                     PreviewTextInput="Box_Numeros_PreviewTextInput"
                                     TextChanged="Box_Tercero_Identificador_TextChanged"/>
                            <Button Grid.Column="1" Content="&#x1F50D;" Width="34" Height="34"
                                    FontSize="13" BorderThickness="1"
                                    BorderBrush="{DynamicResource ThemeBordeInput}"
                                    Background="{DynamicResource ThemeBgSurface}"
                                    Foreground="{DynamicResource ThemeTextoSec}"
                                    Cursor="Hand" Margin="4,0,0,0"
                                    Click="BtnBuscarTercero_Click"/>
                            <Border Grid.Column="3" CornerRadius="6"
                                    Background="{DynamicResource ThemeBgReadOnly}" Padding="10,0">
                                <TextBlock x:Name="Box_Tercero_Descripcion"
                                           FontSize="12" Foreground="{DynamicResource ThemeTexto}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Referencia -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="REFERENCIA"/>
                        <TextBox x:Name="Box_Referencia" Style="{StaticResource ModernInput}"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cuenta -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="CUENTA"/>
                        <TextBox x:Name="Box_Cuenta" Style="{StaticResource ReadOnlyInput}"/>
                    </StackPanel>

                    <!-- Emisión / Edición -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom"
                                Margin="0,0,0,8">
                        <TextBlock Text="Emisión:" Style="{StaticResource LblMuted}"/>
                        <TextBlock x:Name="Box_Emision" Style="{StaticResource LblMuted}" Margin="0,0,16,0"/>
                        <TextBlock Text="Edición:" Style="{StaticResource LblMuted}"/>
                        <TextBlock x:Name="Box_Edicion" Style="{StaticResource LblMuted}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ══ TabControl ══════════════════════════════════════════════ -->
        <TabControl x:Name="TabControl1" Grid.Row="2" Margin="16,12,16,0"
                    Background="Transparent" BorderThickness="0">

            <!-- ── Tab 1: Artículos ────────────────────────────────────── -->
            <TabItem Header="Artículos del Pedido">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="120"/>
                    </Grid.RowDefinitions>

                    <!-- Botones artículos -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,4,0,4">
                        <Button Content="Importar Artículos" Style="{StaticResource BtnPrimario}"
                                Margin="0,0,5,0" Click="BtnImportarArticulos_Click"/>
                        <Button Content="Buscar Artículo" Style="{StaticResource BtnSecundario}"
                                Margin="0,0,5,0" Click="BtnBuscarArticulo_Click"/>
                        <Button Content="Insertar"       Style="{StaticResource BtnSecundario}"
                                Margin="0,0,5,0" Click="BtnInsertar_Click"/>
                        <Button Content="Nueva Línea"    Style="{StaticResource BtnSecundario}"
                                Margin="0,0,5,0" Click="BtnNuevaLinea_Click"/>
                        <Button Content="Eliminar Línea" Style="{StaticResource BtnPeligro}"
                                Margin="0,0,5,0" Click="BtnEliminarLinea_Click"/>
                        <Button Content="Actualizar Precios" Style="{StaticResource BtnAmarillo}"
                                Click="BtnActualizarPrecios_Click"/>
                    </StackPanel>

                    <!-- DataGrid artículos -->
                    <DataGrid x:Name="GridItems" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                              FontSize="12"
                              CellEditEnding="GridItems_CellEditEnding"
                              PreparingCellForEdit="GridItems_PreparingCellForEdit"
                              BeginningEdit="GridItems_BeginningEdit"
                              SelectionChanged="GridItems_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Línea"    Binding="{Binding Linea}"       Width="48"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Código"   Binding="{Binding Codigo}"      Width="80"/>
                            <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad, StringFormat=#\,##0.##}" Width="70"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>

                            <!-- Forma (ComboBox) -->
                            <DataGridTemplateColumn Header="Forma" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Forma}" Margin="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding Forma, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{x:Static local:PedidosDetalle.FormasPedido}"
                                                  FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Contable" Binding="{Binding Contable, StringFormat=#\,##0.##}" Width="70"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                            <DataGridTextColumn Header="Precio"   Binding="{Binding Precio,   StringFormat=#\,##0.##}" Width="75"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                            <DataGridTextColumn Header="Importe"  Binding="{Binding Importe,  StringFormat=#\,##0.##}" Width="80"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Paneles inferiores: precios + stock + observaciones -->
                    <Grid Grid.Row="2" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Historial de Precios -->
                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top" Text="Historial de Precios"
                                       FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextoSec}"
                                       Margin="0,0,0,2"/>
                            <DataGrid x:Name="GridPrecios"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                                      FontSize="11"
                                      MouseDoubleClick="GridPrecios_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="70"/>
                                    <DataGridTextColumn Header="Fecha"  Binding="{Binding Fecha}"  Width="*"/>
                                    <DataGridTextColumn Header="Precio" Binding="{Binding Precio, StringFormat=#\,##0.##}" Width="70"
                                                        ElementStyle="{StaticResource CeldaNumero}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>

                        <!-- Stock -->
                        <DockPanel Grid.Column="2">
                            <TextBlock DockPanel.Dock="Top" Text="Stock"
                                       FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextoSec}"
                                       Margin="0,0,0,2"/>
                            <DataGrid x:Name="GridStock"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                                      FontSize="11">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Código"     Binding="{Binding Codigo}"     Width="*"/>
                                    <DataGridTextColumn Header="Disponible" Binding="{Binding Disponible, StringFormat=#\,##0.##}" Width="80"
                                                        ElementStyle="{StaticResource CeldaNumero}"/>
                                    <DataGridTextColumn Header="Stock"      Binding="{Binding Stock,      StringFormat=#\,##0.##}" Width="80"
                                                        ElementStyle="{StaticResource CeldaNumero}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>

                        <!-- Observaciones -->
                        <DockPanel Grid.Column="4">
                            <TextBlock DockPanel.Dock="Top" Text="Observaciones"
                                       FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextoSec}"
                                       Margin="0,0,0,2"/>
                            <TextBox x:Name="Box_Observaciones" FontSize="12"
                                     Padding="5,4" BorderBrush="{DynamicResource ThemeBorde}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="Box_Observaciones_TextChanged"/>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ── Tab 2: Cobros/Pagos ─────────────────────────────────── -->
            <TabItem x:Name="TabCobros" Header="Cobros/Pagos">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Cabecera -->
                    <Grid Grid.Row="0" Margin="0,4,0,4">
                        <TextBlock Text="Transacciones:" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTexto}" VerticalAlignment="Center"
                                   HorizontalAlignment="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Nueva Línea"    Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0" Click="BtnNuevaLineaTrasaccion_Click"/>
                            <Button Content="Insertar"       Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0" Click="BtnInsertarTrasaccion_Click"/>
                            <Button Content="Eliminar Línea" Style="{StaticResource BtnPeligro}"
                                    Margin="0,0,5,0" Click="BtnEliminarLineaTrasaccion_Click"/>
                            <Button x:Name="BtnCobrarDocumento" Content="Cobrar Documento"
                                    Style="{StaticResource BtnPrimario}"
                                    Click="BtnCobrarDocumento_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- DataGrid transacciones -->
                    <DataGrid x:Name="GridTrasacciones" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                              FontSize="12"
                              CellEditEnding="GridTrasacciones_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"       Width="50"  IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Fecha" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FechaStr}" Margin="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <DatePicker SelectedDate="{Binding FechaDate, UpdateSourceTrigger=PropertyChanged}"
                                                    FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Hora"        Binding="{Binding HoraStr}"     Width="75"/>
                            <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>

                            <!-- Forma (ComboBox) -->
                            <DataGridTemplateColumn Header="Forma" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Forma}" Margin="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding Forma, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{x:Static local:PedidosDetalle.FormasTrasaccion}"
                                                  FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Importe" Binding="{Binding Importe, StringFormat=#\,##0.##}" Width="85"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ── Tab 3: Entregas ─────────────────────────────────────── -->
            <TabItem x:Name="TabEntregas" Header="Entregas">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Cabecera -->
                    <Grid Grid.Row="0" Margin="0,4,0,4">
                        <TextBlock Text="Entregas:" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTexto}" VerticalAlignment="Center"
                                   HorizontalAlignment="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Importar Artículos"  Style="{StaticResource BtnPrimario}"
                                    Margin="0,0,5,0" Click="BtnImportarArticulosEntregas_Click"/>
                            <Button Content="Buscar Artículo"     Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0" Click="BtnBuscarArticuloEntregas_Click"/>
                            <Button Content="Insertar"            Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0" Click="BtnInsertarEntrega_Click"/>
                            <Button Content="Nueva Línea"         Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0" Click="BtnNuevaLineaEntrega_Click"/>
                            <Button Content="Eliminar Línea"      Style="{StaticResource BtnPeligro}"
                                    Margin="0,0,5,0" Click="BtnEliminarLineaEntrega_Click"/>
                            <Button Content="Registrar Entregas"  Style="{StaticResource BtnAmarillo}"
                                    Click="BtnRegistrarEntregas_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- DataGrid entregas -->
                    <DataGrid x:Name="GridEntregas" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                              FontSize="12"
                              CellEditEnding="GridEntregas_CellEditEnding"
                              PreparingCellForEdit="GridEntregas_PreparingCellForEdit">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"       Width="50"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Código"      Binding="{Binding Codigo}"      Width="80"/>
                            <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"   IsReadOnly="True"/>
                            <DataGridTextColumn Header="Cantidad"    Binding="{Binding Cantidad, StringFormat=#\,##0.##}" Width="70"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                            <DataGridTemplateColumn Header="Fecha" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FechaStr}" Margin="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <DatePicker SelectedDate="{Binding FechaDate, UpdateSourceTrigger=PropertyChanged}"
                                                    FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Hora"        Binding="{Binding HoraStr}"     Width="75"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ══ BARRA INFERIOR: Totales + Acciones ══════════════════════ -->
        <Border Grid.Row="3" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,1,0,0"
                Padding="20,10">
            <StackPanel>
                <!-- Totales -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Totales unidades -->
                    <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Total:" Style="{StaticResource Lbl}"/>
                        <TextBlock x:Name="TxtTotalUnidades" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A73E8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="Diferentes:" Style="{StaticResource Lbl}"/>
                        <TextBlock x:Name="TxtUnidadesDiferentes" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A73E8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="Peq:" Style="{StaticResource Lbl}"/>
                        <TextBlock x:Name="TxtTotalPeq" FontSize="12" Foreground="{DynamicResource ThemeTextoSec}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Med:" Style="{StaticResource Lbl}"/>
                        <TextBlock x:Name="TxtTotalMed" FontSize="12" Foreground="{DynamicResource ThemeTextoSec}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Gra:" Style="{StaticResource Lbl}"/>
                        <TextBlock x:Name="TxtTotalGra" FontSize="12" Foreground="{DynamicResource ThemeTextoSec}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Otros:" Style="{StaticResource Lbl}"/>
                        <TextBlock x:Name="TxtTotalOtros" FontSize="12" Foreground="{DynamicResource ThemeTextoSec}"
                                   VerticalAlignment="Center"/>
                    </WrapPanel>

                    <!-- Totales divisas -->
                    <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Importe:" Style="{StaticResource Lbl}"/>
                        <TextBlock x:Name="TxtTotalImporte" FontSize="12" FontWeight="Bold"
                                   Foreground="#2E7D32" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="Cuenta:" Style="{StaticResource Lbl}"/>
                        <TextBlock x:Name="TxtTotalCuenta" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A73E8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="Saldo:" Style="{StaticResource Lbl}"/>
                        <TextBlock x:Name="TxtTotalSaldo" FontSize="12" FontWeight="Bold"
                                   Foreground="#D93025" VerticalAlignment="Center"/>
                    </WrapPanel>
                </Grid>

                <!-- Acciones -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar"
                            Height="36" Padding="18,0" FontSize="13"
                            Background="{DynamicResource ThemeBtnSecBg}"
                            Foreground="{DynamicResource ThemeBtnSecFg}"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                            Click="BtnCancelar_Click"/>
                    <Button Content="&#x1F4BE; Guardar"
                            Height="36" Padding="18,0" FontSize="13" FontWeight="SemiBold"
                            Background="#1A73E8" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnGuardar_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
