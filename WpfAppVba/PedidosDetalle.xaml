<Window x:Class="WpfAppVba.PedidosDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de Pedido" Height="620" Width="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F2F5"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#E8EDF5"/>
            <Setter Property="Foreground" Value="#5F6368"/>
        </Style>
        <Style x:Key="BtnPeligro" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#D93025"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="LblCampo" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="TxtCampo" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock x:Name="LblTitulo" Grid.Row="0"
                   FontSize="15" FontWeight="Bold" Foreground="#1A1A2E"
                   Margin="0,0,0,10"/>

        <!-- Campos de cabecera -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Columna izquierda -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Doc. Pedido:" Style="{StaticResource LblCampo}"/>
                <TextBox x:Name="Box_DocumentoP" Style="{StaticResource TxtCampo}"
                         PreviewTextInput="Box_Numeros_PreviewTextInput"
                         TextChanged="Campo_TextChanged"/>

                <TextBlock Text="Fecha:" Style="{StaticResource LblCampo}"/>
                <DatePicker x:Name="Box_Fecha" Height="28" FontSize="12"
                            Margin="0,0,0,6"
                            SelectedDateChanged="Campo_DateChanged"/>

                <TextBlock Text="Hora (HH:mm:ss):" Style="{StaticResource LblCampo}"/>
                <TextBox x:Name="Box_Hora" Style="{StaticResource TxtCampo}"
                         TextChanged="Campo_TextChanged"/>

                <TextBlock Text="Estado:" Style="{StaticResource LblCampo}"/>
                <ComboBox x:Name="Box_Estado" Height="28" FontSize="12"
                          Margin="0,0,0,6"
                          SelectionChanged="Campo_SelectionChanged">
                    <ComboBoxItem Content="pendiente"/>
                    <ComboBoxItem Content="entregado"/>
                    <ComboBoxItem Content="entrega parcial"/>
                </ComboBox>
            </StackPanel>

            <!-- Columna derecha -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Cliente/Proveedor (Código):" Style="{StaticResource LblCampo}"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="Box_Tercero_Identificador"
                             Height="28" FontSize="12" Padding="6,4" BorderBrush="#CCC"
                             PreviewTextInput="Box_Numeros_PreviewTextInput"
                             TextChanged="Box_Tercero_Identificador_TextChanged"/>
                    <Button Content="..." Grid.Column="1" Width="36" Height="28"
                            Style="{StaticResource BtnSecundario}"
                            Margin="4,0,0,0"
                            Click="BtnBuscarTercero_Click"/>
                </Grid>

                <TextBlock Text="Descripción:" Style="{StaticResource LblCampo}"/>
                <TextBlock x:Name="Box_Tercero_Descripcion"
                           FontSize="12" Foreground="#333"
                           Margin="0,0,0,6" MinHeight="20"/>

                <TextBlock Text="Total Cantidad:" Style="{StaticResource LblCampo}"/>
                <TextBlock x:Name="TxtTotalCantidad" FontSize="13" FontWeight="SemiBold"
                           Foreground="#1A73E8" Margin="0,2,0,4"/>

                <TextBlock Text="Total Importe:" Style="{StaticResource LblCampo}"/>
                <TextBlock x:Name="TxtTotalImporte" FontSize="13" FontWeight="SemiBold"
                           Foreground="#2E7D32" Margin="0,2,0,6"/>
            </StackPanel>
        </Grid>

        <!-- Observaciones -->
        <StackPanel Grid.Row="2" Margin="0,0,0,6">
            <TextBlock Text="Observaciones:" Style="{StaticResource LblCampo}"/>
            <TextBox x:Name="Box_Observaciones" Height="50" FontSize="12" Padding="6,4"
                     BorderBrush="#CCC" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextChanged="Campo_TextChanged"/>
        </StackPanel>

        <!-- Separador -->
        <Separator Grid.Row="3" Margin="0,4,0,8"/>

        <!-- Sección artículos -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Artículos del pedido:"
                       FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"
                       Margin="0,0,0,6"/>

            <!-- Botones artículos -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                <Button Content="Importar Artículos" Style="{StaticResource BtnPrimario}"
                        Margin="0,0,6,0" Click="BtnImportarArticulos_Click"/>
                <Button Content="Nueva Línea" Style="{StaticResource BtnSecundario}"
                        Margin="0,0,6,0" Click="BtnNuevaLinea_Click"/>
                <Button Content="Eliminar Línea" Style="{StaticResource BtnPeligro}"
                        Click="BtnEliminarLinea_Click"/>
            </StackPanel>

            <!-- Grid artículos -->
            <DataGrid x:Name="GridItems" Grid.Row="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="#DDD" BorderThickness="1"
                      FontSize="12"
                      CellEditEnding="GridItems_CellEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"       Width="50"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Código"      Binding="{Binding Codigo}"      Width="70"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"   IsReadOnly="True"/>
                    <DataGridTextColumn Header="Cantidad"    Binding="{Binding Cantidad}"    Width="80"/>
                    <DataGridTextColumn Header="Precio"      Binding="{Binding Precio}"      Width="90"/>
                    <DataGridTextColumn Header="Total"       Binding="{Binding Total}"       Width="90"  IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Botones guardar -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Guardar" Style="{StaticResource BtnPrimario}"
                    Margin="0,0,8,0" Click="BtnGuardar_Click"/>
            <Button Content="Cancelar" Style="{StaticResource BtnSecundario}"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
