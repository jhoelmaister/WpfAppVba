<UserControl x:Class="WpfAppVba.PedidosDetalle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfAppVba"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>

        <!-- ── Botones ── -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimario"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"      Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ThemeBtnSecFg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
        </Style>
        <Style x:Key="BtnPeligro"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnAmarillo"  TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- ── Etiquetas inline ── -->
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize"           Value="11"/>
            <Setter Property="Foreground"         Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="Margin"             Value="0,0,5,0"/>
        </Style>
        <Style x:Key="LblMuted" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="Foreground"        Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,4,0"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- ── Tarjeta de métrica ── -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="10,8"/>
        </Style>

        <!-- ── Alineación numérica ── -->
        <Style x:Key="RightCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- ── Input redondeado ── -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height"                   Value="28"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="Padding"                  Value="7,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground"               Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0  Encabezado (título + campos) -->
            <RowDefinition Height="*"/>     <!-- 1  TabControl -->
            <RowDefinition Height="Auto"/>  <!-- 2  Barra de totales + Guardar/Cancelar -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- 0 · ENCABEZADO                                              -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}"
                BorderThickness="0,0,0,1"
                Padding="14,10,14,10">
            <StackPanel>

                <!-- Fila superior: ícono + título + badges + acciones -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ícono + Título -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,14,0">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="#DBEAFE" Margin="0,0,10,0">
                            <TextBlock x:Name="LblIconoTipo"
                                       Text="V" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#1E40AF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="LblTitulo"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTexto}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="Documento "
                                           FontSize="11"
                                           Foreground="{DynamicResource ThemeTextoSec}"/>
                                <TextBlock x:Name="LblDocBadge"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThemeTexto}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Badges de estado + cuenta -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="Estado de entrega:" Style="{StaticResource LblMuted}"/>
                        <Border x:Name="BadgeEstado"
                                CornerRadius="10" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock x:Name="TxtBadgeEstado"
                                       FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="Estado de cuenta:" Style="{StaticResource LblMuted}" Margin="12,0,4,0"/>
                        <Border x:Name="BadgeCuenta"
                                CornerRadius="10" Padding="8,3">
                            <TextBlock x:Name="TxtBadgeCuenta"
                                       FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Guardar / Cancelar (siempre visibles aquí) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="Cancelar"
                                Style="{StaticResource BtnSecundario}"
                                Margin="0,0,6,0"
                                Click="BtnCancelar_Click"/>
                        <Button Content="💾 Guardar"
                                Height="30" FontWeight="SemiBold"
                                Style="{StaticResource BtnPrimario}"
                                Click="BtnGuardar_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Fila de campos de cabecera -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="136"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="96"/>
                        <ColumnDefinition Width="8"/>
                        <!-- Tercero: código + descripción + botón -->
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <!-- Referencia -->
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="8"/>
                        <!-- Tipo -->
                        <ColumnDefinition Width="96"/>
                    </Grid.ColumnDefinitions>

                    <!-- Doc. Pedido -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Doc. Pedido" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_DocumentoP"
                                 Style="{StaticResource ModernInput}"
                                 PreviewTextInput="Box_Numeros_PreviewTextInput"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <!-- Fecha -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fecha" Style="{StaticResource LblMuted}"/>
                        <DatePicker x:Name="Box_Fecha" Height="28" FontSize="12"
                                    SelectedDateChanged="Campo_DateChanged"/>
                    </StackPanel>

                    <!-- Hora -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Hora" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_Hora"
                                 Style="{StaticResource ModernInput}"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <!-- Tercero: código -->
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Tercero" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_Tercero_Identificador"
                                 Style="{StaticResource ModernInput}"
                                 PreviewTextInput="Box_Numeros_PreviewTextInput"
                                 TextChanged="Box_Tercero_Identificador_TextChanged"/>
                    </StackPanel>

                    <!-- Botón buscar tercero -->
                    <Button Grid.Column="8" Content="···"
                            Height="28" Width="30" Padding="0"
                            Style="{StaticResource BtnSecundario}"
                            Margin="0,14,0,0"
                            Click="BtnBuscarTercero_Click"/>

                    <!-- Descripción tercero -->
                    <StackPanel Grid.Column="10">
                        <TextBlock Text=" " Style="{StaticResource LblMuted}"/>
                        <Border Height="28" Background="{DynamicResource ThemeBgReadOnly}"
                                BorderBrush="{DynamicResource ThemeBorde}"
                                BorderThickness="1" CornerRadius="5"
                                Padding="7,0">
                            <TextBlock x:Name="Box_Tercero_Descripcion"
                                       FontSize="12"
                                       Foreground="{DynamicResource ThemeTextoMuted}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </StackPanel>

                    <!-- Referencia -->
                    <StackPanel Grid.Column="12">
                        <TextBlock Text="Referencia" Style="{StaticResource LblMuted}"/>
                        <TextBox x:Name="Box_Referencia"
                                 Style="{StaticResource ModernInput}"
                                 TextChanged="Campo_TextChanged"/>
                    </StackPanel>

                    <!-- Tipo (ComboBox Venta/Compra) -->
                    <StackPanel Grid.Column="14">
                        <TextBlock Text="Tipo" Style="{StaticResource LblMuted}"/>
                        <ComboBox x:Name="CboMovimiento" Height="28" FontSize="12"
                                  SelectionChanged="CboMovimiento_SelectionChanged">
                            <ComboBoxItem Content="Venta"/>
                            <ComboBoxItem Content="Compra"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Emisión / edición (readonly, fila secundaria) -->
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="Emisión:" Style="{StaticResource LblMuted}"/>
                    <TextBlock x:Name="Box_Emision"
                               FontSize="10" Foreground="{DynamicResource ThemeTexto}"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="Edición:" Style="{StaticResource LblMuted}"/>
                    <TextBlock x:Name="Box_Edicion"
                               FontSize="10" Foreground="{DynamicResource ThemeTexto}"
                               VerticalAlignment="Center"/>
                    <!-- Ocultos: usados por code-behind, visualmente en badges -->
                    <TextBox x:Name="Box_Estado" Visibility="Collapsed" IsReadOnly="True"/>
                    <TextBox x:Name="Box_Cuenta" Visibility="Collapsed" IsReadOnly="True"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- 1 · TABCONTROL                                              -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <TabControl x:Name="TabControl1" Grid.Row="1"
                    Background="{DynamicResource ThemeBgContenido}"
                    BorderThickness="0" Padding="0">

            <!-- ──────────────────────────────────────────────────────── -->
            <!-- TAB 1: ARTÍCULOS                                         -->
            <!-- ──────────────────────────────────────────────────────── -->
            <TabItem Header="Artículos del pedido">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- toolbar -->
                        <RowDefinition Height="*"/>     <!-- tabla -->
                        <RowDefinition Height="110"/>   <!-- precios + stock + obs -->
                    </Grid.RowDefinitions>

                    <!-- Toolbar artículos -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource ThemeBgSurface}"
                            BorderBrush="{DynamicResource ThemeBorde}"
                            BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Importar artículos"
                                    Style="{StaticResource BtnPrimario}"
                                    Margin="0,0,5,0"
                                    Click="BtnImportarArticulos_Click"/>
                            <Button Content="Buscar artículo"
                                    Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0"
                                    Click="BtnBuscarArticulo_Click"/>
                            <Button Content="Insertar"
                                    Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0"
                                    Click="BtnInsertar_Click"/>
                            <Button Content="Nueva línea"
                                    Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0"
                                    Click="BtnNuevaLinea_Click"/>
                            <Button Content="Eliminar línea"
                                    Style="{StaticResource BtnPeligro}"
                                    Margin="0,0,5,0"
                                    Click="BtnEliminarLinea_Click"/>
                            <Button Content="Actualizar precios"
                                    Style="{StaticResource BtnAmarillo}"
                                    Click="BtnActualizarPrecios_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid artículos -->
                    <DataGrid x:Name="GridItems" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="{DynamicResource ThemeBorde}"
                              BorderThickness="0"
                              FontSize="12"
                              RowHeight="32"
                              CellEditEnding="GridItems_CellEditEnding"
                              PreparingCellForEdit="GridItems_PreparingCellForEdit"
                              BeginningEdit="GridItems_BeginningEdit"
                              SelectionChanged="GridItems_SelectionChanged">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
                                <Setter Property="Foreground"      Value="{DynamicResource ThemeTextoSec}"/>
                                <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding"         Value="8,5"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Lín."
                                                Binding="{Binding Linea}"
                                                Width="40" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"        Value="{DynamicResource ThemeTextoSec}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin"            Value="8,0,0,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Código"
                                                Binding="{Binding Codigo}"
                                                Width="76"/>
                            <DataGridTextColumn Header="Descripción"
                                                Binding="{Binding Descripcion}"
                                                Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Cantidad"
                                                Binding="{Binding Cantidad, StringFormat=#\,##0.##}"
                                                Width="70"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                            <!-- Forma (ComboBox) -->
                            <DataGridTemplateColumn Header="Forma" Width="96">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource ThemeBgReadOnly}"
                                                CornerRadius="4" Padding="5,1"
                                                HorizontalAlignment="Left" Margin="4,0">
                                            <TextBlock Text="{Binding Forma}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextoSec}"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding Forma, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{x:Static local:PedidosDetalle.FormasPedido}"
                                                  FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Contable"
                                                Binding="{Binding Contable, StringFormat=#\,##0.##}"
                                                Width="70"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                            <DataGridTextColumn Header="Precio"
                                                Binding="{Binding Precio, StringFormat=#\,##0.##}"
                                                Width="76"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                            <DataGridTextColumn Header="Importe"
                                                Binding="{Binding Importe, StringFormat=#\,##0.##}"
                                                Width="82"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Panel inferior: Precios | Stock | Observaciones -->
                    <Grid Grid.Row="2" Background="{DynamicResource ThemeBgSurface}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Historial de precios -->
                        <DockPanel Grid.Column="0" Margin="10,8,10,8">
                            <TextBlock DockPanel.Dock="Top"
                                       Style="{StaticResource SectionHeader}"
                                       Text="Historial de precios"/>
                            <DataGrid x:Name="GridPrecios"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderBrush="{DynamicResource ThemeBorde}"
                                      BorderThickness="1"
                                      FontSize="11"
                                      MouseDoubleClick="GridPrecios_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Código"
                                                        Binding="{Binding Codigo}" Width="70"/>
                                    <DataGridTextColumn Header="Fecha"
                                                        Binding="{Binding Fecha}"  Width="*"/>
                                    <DataGridTextColumn Header="Precio"
                                                        Binding="{Binding Precio, StringFormat=#\,##0.##}"
                                                        Width="70"
                                                        ElementStyle="{StaticResource CeldaNumero}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>

                        <Rectangle Grid.Column="1" Fill="{DynamicResource ThemeBorde}"/>

                        <!-- Stock -->
                        <DockPanel Grid.Column="2" Margin="10,8,10,8">
                            <TextBlock DockPanel.Dock="Top"
                                       Style="{StaticResource SectionHeader}"
                                       Text="Stock actual"/>
                            <DataGrid x:Name="GridStock"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderBrush="{DynamicResource ThemeBorde}"
                                      BorderThickness="1"
                                      FontSize="11">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Código"
                                                        Binding="{Binding Codigo}"    Width="*"/>
                                    <DataGridTextColumn Header="Disponible"
                                                        Binding="{Binding Disponible}"
                                                        Width="74"
                                                        ElementStyle="{StaticResource CeldaNumero}"/>
                                    <DataGridTextColumn Header="Stock"
                                                        Binding="{Binding Stock}"
                                                        Width="70"
                                                        ElementStyle="{StaticResource CeldaNumero}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>

                        <Rectangle Grid.Column="3" Fill="{DynamicResource ThemeBorde}"/>

                        <!-- Observaciones -->
                        <DockPanel Grid.Column="4" Margin="10,8,10,8">
                            <TextBlock DockPanel.Dock="Top"
                                       Style="{StaticResource SectionHeader}"
                                       Text="Observaciones"/>
                            <TextBox x:Name="Box_Observaciones"
                                     FontSize="12" Padding="7,5"
                                     BorderBrush="{DynamicResource ThemeBordeInput}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="Box_Observaciones_TextChanged"/>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ──────────────────────────────────────────────────────── -->
            <!-- TAB 2: COBROS / PAGOS                                    -->
            <!-- ──────────────────────────────────────────────────────── -->
            <TabItem x:Name="TabCobros" Header="Cobros / Pagos">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar cobros -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource ThemeBgSurface}"
                            BorderBrush="{DynamicResource ThemeBorde}"
                            BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Nueva línea"
                                    Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0"
                                    Click="BtnNuevaLineaTrasaccion_Click"/>
                            <Button Content="Insertar"
                                    Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0"
                                    Click="BtnInsertarTrasaccion_Click"/>
                            <Button Content="Eliminar línea"
                                    Style="{StaticResource BtnPeligro}"
                                    Margin="0,0,5,0"
                                    Click="BtnEliminarLineaTrasaccion_Click"/>
                            <Button x:Name="BtnCobrarDocumento"
                                    Content="Cobrar documento"
                                    Style="{StaticResource BtnPrimario}"
                                    Click="BtnCobrarDocumento_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Grid transacciones -->
                    <DataGrid x:Name="GridTrasacciones" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="{DynamicResource ThemeBorde}"
                              BorderThickness="0"
                              FontSize="12"
                              RowHeight="32"
                              CellEditEnding="GridTrasacciones_CellEditEnding">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
                                <Setter Property="Foreground"      Value="{DynamicResource ThemeTextoSec}"/>
                                <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding"         Value="8,5"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Lín."
                                                Binding="{Binding Linea}"
                                                Width="46" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Fecha" Width="108">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FechaStr}"
                                                   Margin="6,0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <DatePicker SelectedDate="{Binding FechaDate, UpdateSourceTrigger=PropertyChanged}"
                                                    FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Hora"
                                                Binding="{Binding HoraStr}"   Width="74"/>
                            <DataGridTextColumn Header="Descripción"
                                                Binding="{Binding Descripcion}" Width="*"/>
                            <DataGridTemplateColumn Header="Forma" Width="108">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Forma}"
                                                   Margin="6,0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding Forma, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{x:Static local:PedidosDetalle.FormasTrasaccion}"
                                                  FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Importe"
                                                Binding="{Binding Importe, StringFormat=#\,##0.##}"
                                                Width="90"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ──────────────────────────────────────────────────────── -->
            <!-- TAB 3: ENTREGAS                                          -->
            <!-- ──────────────────────────────────────────────────────── -->
            <TabItem x:Name="TabEntregas" Header="Entregas">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar entregas -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource ThemeBgSurface}"
                            BorderBrush="{DynamicResource ThemeBorde}"
                            BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Importar artículos"
                                    Style="{StaticResource BtnPrimario}"
                                    Margin="0,0,5,0"
                                    Click="BtnImportarArticulosEntregas_Click"/>
                            <Button Content="Buscar artículo"
                                    Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0"
                                    Click="BtnBuscarArticuloEntregas_Click"/>
                            <Button Content="Insertar"
                                    Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0"
                                    Click="BtnInsertarEntrega_Click"/>
                            <Button Content="Nueva línea"
                                    Style="{StaticResource BtnSecundario}"
                                    Margin="0,0,5,0"
                                    Click="BtnNuevaLineaEntrega_Click"/>
                            <Button Content="Eliminar línea"
                                    Style="{StaticResource BtnPeligro}"
                                    Margin="0,0,5,0"
                                    Click="BtnEliminarLineaEntrega_Click"/>
                            <Button Content="Registrar entregas"
                                    Style="{StaticResource BtnAmarillo}"
                                    Click="BtnRegistrarEntregas_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Grid entregas -->
                    <DataGrid x:Name="GridEntregas" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="{DynamicResource ThemeBorde}"
                              BorderThickness="0"
                              FontSize="12"
                              RowHeight="32"
                              CellEditEnding="GridEntregas_CellEditEnding"
                              PreparingCellForEdit="GridEntregas_PreparingCellForEdit">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
                                <Setter Property="Foreground"      Value="{DynamicResource ThemeTextoSec}"/>
                                <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding"         Value="8,5"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Lín."
                                                Binding="{Binding Linea}"
                                                Width="46" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Código"
                                                Binding="{Binding Codigo}"      Width="80"/>
                            <DataGridTextColumn Header="Descripción"
                                                Binding="{Binding Descripcion}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Cantidad"
                                                Binding="{Binding Cantidad, StringFormat=#\,##0.##}"
                                                Width="70"
                                                ElementStyle="{StaticResource CeldaNumero}"
                                                EditingElementStyle="{StaticResource CeldaNumeroEditar}"/>
                            <DataGridTemplateColumn Header="Fecha" Width="108">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FechaStr}"
                                                   Margin="6,0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <DatePicker SelectedDate="{Binding FechaDate, UpdateSourceTrigger=PropertyChanged}"
                                                    FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Hora"
                                                Binding="{Binding HoraStr}"     Width="74"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- 2 · BARRA DE TOTALES                                        -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Izquierda: grupos Pedidos + Entregas -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">

                    <!-- ── Grupo PEDIDOS ── -->
                    <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                        <TextBlock Text="Pedidos" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal">
                            <!-- Total unidades -->
                            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Total unidades" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextoSec}"/>
                                    <TextBlock x:Name="TxtTotalUnidades"
                                               FontSize="17" FontWeight="SemiBold"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource ThemeTexto}"/>
                                </StackPanel>
                            </Border>
                            <!-- Diferentes -->
                            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Diferentes" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextoSec}"/>
                                    <TextBlock x:Name="TxtUnidadesDiferentes"
                                               FontSize="17" FontWeight="SemiBold"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource ThemeTexto}"/>
                                </StackPanel>
                            </Border>
                            <!-- Categorías -->
                            <Border Style="{StaticResource MetricCard}" Padding="6,4" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Categorías" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                                    <DataGrid x:Name="GridCategorias"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              BorderThickness="0"
                                              FontSize="10"
                                              Width="170" MaxHeight="78">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Categoría"
                                                                Binding="{Binding Categoria}" Width="*"/>
                                            <DataGridTextColumn Header="Cant."
                                                                Binding="{Binding Cantidad}" Width="50"
                                                                ElementStyle="{StaticResource CeldaNumero}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Rectangle Width="1" Fill="{DynamicResource ThemeBorde}" Margin="2,4"/>

                    <!-- ── Grupo ENTREGAS ── -->
                    <StackPanel Orientation="Vertical" Margin="10,0,0,0">
                        <TextBlock Text="Entregas" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal">
                            <!-- Total unidades entregadas -->
                            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Total unidades" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextoSec}"/>
                                    <TextBlock x:Name="TxtTotalUnidadesE"
                                               FontSize="17" FontWeight="SemiBold"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource ThemeTexto}"/>
                                </StackPanel>
                            </Border>
                            <!-- Diferentes entregadas -->
                            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Diferentes" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextoSec}"/>
                                    <TextBlock x:Name="TxtUnidadesDiferentesE"
                                               FontSize="17" FontWeight="SemiBold"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource ThemeTexto}"/>
                                </StackPanel>
                            </Border>
                            <!-- Categorías entregadas -->
                            <Border Style="{StaticResource MetricCard}" Padding="6,4" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Categorías" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextoSec}" Margin="0,0,0,2"/>
                                    <DataGrid x:Name="GridCategoriasE"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              BorderThickness="0"
                                              FontSize="10"
                                              Width="170" MaxHeight="78">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Categoría"
                                                                Binding="{Binding Categoria}" Width="*"/>
                                            <DataGridTextColumn Header="Cant."
                                                                Binding="{Binding Cantidad}" Width="50"
                                                                ElementStyle="{StaticResource CeldaNumero}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Derecha: totales de importe -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Importe -->
                    <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Importe total" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextoSec}"/>
                            <TextBlock x:Name="TxtTotalImporte"
                                       FontSize="17" FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Foreground="#065F46"/>
                        </StackPanel>
                    </Border>
                    <!-- Cuenta -->
                    <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Pagado / Cobrado" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextoSec}"/>
                            <TextBlock x:Name="TxtTotalCuenta"
                                       FontSize="17" FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Foreground="#1E40AF"/>
                        </StackPanel>
                    </Border>
                    <!-- Saldo -->
                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Saldo" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextoSec}"/>
                            <TextBlock x:Name="TxtTotalSaldo"
                                       FontSize="17" FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Foreground="#991B1B"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</UserControl>
