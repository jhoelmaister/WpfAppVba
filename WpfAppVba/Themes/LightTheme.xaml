<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Fondos ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ThemeBgPrincipal"  Color="#F0F2F5"/>
    <SolidColorBrush x:Key="ThemeBgSurface"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeBgContenido"  Color="#F4F6FB"/>
    <SolidColorBrush x:Key="ThemeBgReadOnly"   Color="#F5F5F5"/>
    <SolidColorBrush x:Key="ThemeInputBg"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeBgTopBar"     Color="#E9ECF2"/>
    <SolidColorBrush x:Key="ThemeBgSidebar"    Color="#ECEEF3"/>

    <!-- ── Texto ────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ThemeTexto"        Color="#1A1A2E"/>
    <SolidColorBrush x:Key="ThemeTextoSec"     Color="#555555"/>
    <SolidColorBrush x:Key="ThemeTextoMuted"   Color="#999999"/>

    <!-- ── Bordes ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ThemeBorde"        Color="#DDDDDD"/>
    <SolidColorBrush x:Key="ThemeBordeInput"   Color="#CCCCCC"/>

    <!-- ── Botones secundarios ─────────────────────────────────────── -->
    <SolidColorBrush x:Key="ThemeBtnSecBg"     Color="#E8EDF5"/>
    <SolidColorBrush x:Key="ThemeBtnSecFg"     Color="#5F6368"/>

    <!-- ── Tabs ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ThemeTabSelBg"     Color="#EEF2FF"/>
    <SolidColorBrush x:Key="ThemeTabHoverBg"   Color="#E8ECF8"/>
    <SolidColorBrush x:Key="ThemeNavActivoBg"  Color="#CFE4FF"/>

    <!-- ── DataGrid ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ThemeDataGridBg"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeDataGridAltBg"   Color="#F8F9FC"/>
    <SolidColorBrush x:Key="ThemeFilaSeleccionada" Color="#E8F5E9"/>
    <SolidColorBrush x:Key="ThemeFilaSelGrid"      Color="#D7E5FF"/>

    <!-- ── ScrollBar ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ThemeScrollBg"          Color="#E4E7EF"/>
    <SolidColorBrush x:Key="ThemeScrollThumb"       Color="#AAAAAA"/>
    <SolidColorBrush x:Key="ThemeScrollThumbHover"  Color="#888888"/>

</ResourceDictionary>
