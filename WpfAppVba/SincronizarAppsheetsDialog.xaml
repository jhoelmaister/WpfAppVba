<Window x:Class="WpfAppVba.SincronizarAppsheetsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sincronizar AppSheets" Height="210" Width="540"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource ThemeBgPrincipal}">

    <Window.Resources>
        <Style x:Key="BtnDialogo" TargetType="Button">
            <Setter Property="Height"          Value="36"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Margin"          Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Sincronizar AppSheets" FontSize="15" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource ThemeTextoSec}"
                   Text="Elegí el alcance de la sincronización. &#x201C;Sincronizar todo&#x201D; procesa todas las sucursales de la empresa activa; &#x201C;Sincronizar sucursal activa&#x201D; solo la sucursal en uso."/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button x:Name="BtnTodo" Content="Sincronizar todo"
                    Style="{StaticResource BtnDialogo}" Background="#2E7D32"
                    Click="BtnTodo_Click"/>
            <Button x:Name="BtnSucursal" Content="Sincronizar sucursal activa"
                    Style="{StaticResource BtnDialogo}" Background="#1A73E8"
                    Click="BtnSucursal_Click"/>
            <Button x:Name="BtnCancelar" Content="Cancelar"
                    Style="{StaticResource BtnDialogo}" Background="#5F6368" Margin="0"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
