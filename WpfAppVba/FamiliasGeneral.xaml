<Window x:Class="WpfAppVba.FamiliasGeneral"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Familias" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource ThemeBgPrincipal}">

    <Window.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Familias de Productos" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeTexto}" Margin="0,0,0,10"/>

        <!-- Buscador -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtBuscar" Grid.Column="0" Height="28" FontSize="12"
                     Padding="6,4" BorderBrush="{DynamicResource ThemeBordeInput}" Margin="0,0,6,0"
                     TextChanged="TxtBuscar_TextChanged"/>
            <Button Content="Buscar" Grid.Column="1"
                    Style="{StaticResource Btn}" Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeTexto}"
                    Click="BtnBuscar_Click"/>
        </Grid>

        <!-- Lista -->
        <DataGrid x:Name="Grid1" Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="1"
                  FontSize="12"
                  MouseDoubleClick="Grid1_MouseDoubleClick"
                  PreviewKeyDown="Grid1_PreviewKeyDown">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Línea"       Binding="{Binding Linea}"       Width="60"/>
                <DataGridTextColumn Header="Código"      Binding="{Binding Id}"          Width="80"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                <DataGridTextColumn Header="Producto"    Binding="{Binding Producto}"    Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Botones admin -->
        <StackPanel x:Name="PanelAdmin" Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Nuevo"      Margin="0,0,6,0" Background="#1A73E8" Foreground="White"   Click="BtnNuevo_Click"      Style="{StaticResource Btn}"/>
            <Button Content="Editar"     Margin="0,0,6,0" Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeTexto}" Click="BtnEditar_Click"     Style="{StaticResource Btn}"/>
            <Button Content="Eliminar"   Margin="0,0,6,0" Background="#D93025" Foreground="White"   Click="BtnEliminar_Click"   Style="{StaticResource Btn}"/>
            <Button Content="Actualizar" Margin="0,0,0,0" Background="{DynamicResource ThemeBtnSecBg}" Foreground="{DynamicResource ThemeTexto}" Click="BtnActualizar_Click" Style="{StaticResource Btn}"/>
        </StackPanel>
    </Grid>
</Window>
