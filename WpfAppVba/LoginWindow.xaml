<Window x:Class="WpfAppVba.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inicio de Sesión" Height="320" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F2F5">

    <Grid>
        <Border Background="White" CornerRadius="8" Margin="30,30,30,30"
                Effect="{DynamicResource {x:Static SystemParameters.DropShadowKey}}">
            <StackPanel Margin="30,25,30,25" VerticalAlignment="Center">

                <!-- Título -->
                <TextBlock Text="Iniciar Sesión" FontSize="20" FontWeight="Bold"
                           Foreground="#1A1A2E" HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Usuario -->
                <TextBlock Text="Usuario" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtCuenta" Height="34" FontSize="13"
                         Padding="8,6" BorderBrush="#CCC" BorderThickness="1"
                         Margin="0,0,0,12"/>

                <!-- Contraseña -->
                <TextBlock Text="Contraseña" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtContrasena" Height="34" FontSize="13"
                             Padding="8,6" BorderBrush="#CCC" BorderThickness="1"
                             Margin="0,0,0,16"
                             KeyDown="TxtContrasena_KeyDown"/>

                <!-- Botón -->
                <Button x:Name="BtnIngresar" Content="Ingresar" Height="36"
                        FontSize="13" FontWeight="SemiBold"
                        Background="#1A73E8" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnIngresar_Click"/>

                <!-- Estado -->
                <TextBlock x:Name="LblEstado" FontSize="11" Margin="0,10,0,0"
                           HorizontalAlignment="Center" TextWrapping="Wrap"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
