<Window x:Class="WpfAppVba.ArticulosGeneral"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Artículos" Height="560" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#E8EDF5"/>
            <Setter Property="Foreground" Value="#5F6368"/>
        </Style>
        <Style x:Key="BtnPeligro" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#D93025"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo: TreeView -->
        <Border Grid.Column="0" Margin="0,0,8,0" BorderBrush="#DDD" BorderThickness="1" Background="White">
            <TreeView x:Name="Tree1"
                      SelectedItemChanged="Tree1_SelectedItemChanged"
                      FontSize="12"/>
        </Border>

        <!-- Panel derecho -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Buscador -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtBuscar" Grid.Column="0" Height="28" FontSize="12"
                         Padding="6,4" BorderBrush="#CCC" Margin="0,0,6,0"
                         TextChanged="TxtBuscar_TextChanged"/>
                <Button Content="Buscar" Grid.Column="1"
                        Style="{StaticResource BtnSecundario}"
                        Click="BtnBuscar_Click"/>
            </Grid>

            <!-- DataGrid -->
            <DataGrid x:Name="Grid1" Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="#DDD" BorderThickness="1"
                      FontSize="12"
                      MouseDoubleClick="Grid1_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Línea"               Binding="{Binding Linea}"       Width="60"/>
                    <DataGridTextColumn Header="Código"              Binding="{Binding Codigo}"      Width="80"/>
                    <DataGridTextColumn Header="Descripción Completa" Binding="{Binding Descripcion}" Width="*"/>
                    <DataGridTextColumn Header="Disponible"          Binding="{Binding Disponible}"  Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Stock"               Binding="{Binding Stock}"       Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Fila de totales -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                <TextBlock Text="Total Disponible:" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalDisponible" VerticalAlignment="Center" FontSize="12"
                           FontWeight="SemiBold" Margin="0,0,16,0"/>
                <TextBlock Text="Total Stock:" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtTotalStock" VerticalAlignment="Center" FontSize="12"
                           FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Botones + modo exportar -->
            <Grid Grid.Row="3" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Panel exportar (oculto por defecto) -->
                <StackPanel x:Name="PanelExportar" Grid.Column="0" Orientation="Horizontal"
                            Visibility="Collapsed" VerticalAlignment="Center">
                    <Button Content="Exportar Seleccionados" Style="{StaticResource BtnSuccess}"
                            Margin="0,0,8,0" Click="BtnExportar_Click"/>
                    <TextBlock x:Name="LblSeleccionados" VerticalAlignment="Center" FontSize="12"
                               Foreground="#2E7D32"/>
                </StackPanel>

                <!-- Botones de gestión -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Nuevo"      Margin="0,0,6,0" Style="{StaticResource BtnPrimario}"  Click="BtnNuevo_Click"/>
                    <Button Content="Editar"     Margin="0,0,6,0" Style="{StaticResource BtnSecundario}" Click="BtnEditar_Click"/>
                    <Button Content="Eliminar"   Margin="0,0,6,0" Style="{StaticResource BtnPeligro}"   Click="BtnEliminar_Click"/>
                    <Button Content="Actualizar" Margin="0,0,0,0" Style="{StaticResource BtnSecundario}" Click="BtnActualizar_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
