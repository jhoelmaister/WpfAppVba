<UserControl x:Class="WpfAppVba.ArticulosGeneral"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>

        <!-- ── Botones base ── -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="11,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"    Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground"    Value="{DynamicResource ThemeBtnSecFg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource ThemeBorde}"/>
        </Style>
        <Style x:Key="BtnPeligro" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- ── Tarjeta métrica ── -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"    Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource ThemeBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"  Value="8"/>
            <Setter Property="Padding"       Value="12,10"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- SIDEBAR (árbol productos / familias)                      -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="CATÁLOGO"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeTextoSec}"
                           Margin="12,8,0,6"/>

                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource ThemeBorde}"
                        BorderThickness="1" Margin="8,0,8,8">
                    <TreeView x:Name="Tree1"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectedItemChanged="Tree1_SelectedItemChanged"
                              PreviewMouseLeftButtonDown="Tree1_PreviewMouseLeftButtonDown"
                              FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- ÁREA PRINCIPAL                                           -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Top bar: título -->
                <RowDefinition Height="Auto"/>  <!-- Métricas -->
                <RowDefinition Height="Auto"/>  <!-- Búsqueda + botones gestión -->
                <RowDefinition Height="*"/>     <!-- DataGrid principal -->
                <RowDefinition Height="Auto"/>  <!-- Barra inferior: Excel / exportar -->
            </Grid.RowDefinitions>

            <!-- ── Top bar ── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource ThemeBgSurface}"
                    BorderBrush="{DynamicResource ThemeBorde}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Artículos"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeTexto}"/>
                    <TextBlock x:Name="LblSubtitulo"
                               FontSize="11"
                               Foreground="{DynamicResource ThemeTextoSec}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Métricas ── -->
            <Grid Grid.Row="1" Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="Artículos"
                                   FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtTotalArticulos"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTexto}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="Total disponible"
                                   FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtTotalDisponible"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="#10B981"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="Total stock"
                                   FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtTotalStock"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTexto}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Búsqueda + botones gestión ── -->
            <Border Grid.Row="2"
                    Background="{DynamicResource ThemeBgSurface}"
                    BorderBrush="{DynamicResource ThemeBorde}"
                    BorderThickness="0,1,0,1"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Buscador con ícono embebido -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource ThemeInputBg}"
                            BorderBrush="{DynamicResource ThemeBordeInput}"
                            BorderThickness="1" CornerRadius="6"
                            Margin="0,0,10,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍"
                                       FontSize="12" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeTextoSec}"
                                       IsHitTestVisible="False"/>
                            <TextBox x:Name="TxtBuscar"
                                     Grid.Column="1"
                                     Height="30" FontSize="12"
                                     Padding="4,0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     KeyDown="TxtBuscar_KeyDown"/>
                            <Button Grid.Column="2" Content="Buscar"
                                    Height="30" Padding="10,0" FontSize="12"
                                    Background="#3B82F6" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnBuscar_Click"/>
                        </Grid>
                    </Border>

                    <!-- Botones de gestión -->
                    <StackPanel x:Name="PanelBotonesGestion" Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnNuevo"
                                Content="Nuevo Artículo"
                                Style="{StaticResource BtnPrimario}"
                                Margin="0,0,6,0"
                                Click="BtnNuevo_Click"/>
                        <Button x:Name="BtnInsertar"
                                Content="Insertar Artículo"
                                Style="{StaticResource BtnPrimario}"
                                Margin="0,0,6,0"
                                Click="BtnInsertar_Click"/>
                        <Rectangle Width="1" Fill="{DynamicResource ThemeBorde}"
                                   VerticalAlignment="Stretch" Margin="2,4,8,4"/>
                        <Button x:Name="BtnEditar"
                                Content="Editar"
                                Style="{StaticResource BtnSecundario}"
                                Margin="0,0,6,0"
                                Click="BtnEditar_Click"/>
                        <Button x:Name="BtnEliminar"
                                Content="Eliminar"
                                Style="{StaticResource BtnPeligro}"
                                Margin="0,0,6,0"
                                Click="BtnEliminar_Click"/>
                        <Button Content="Actualizar"
                                Style="{StaticResource BtnSecundario}"
                                Click="BtnActualizar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── DataGrid ── -->
            <DataGrid x:Name="Grid1" Grid.Row="3"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="{DynamicResource ThemeBorde}"
                      BorderThickness="0"
                      FontSize="12"
                      RowHeight="34"
                      VirtualizingPanel.VirtualizationMode="Standard"
                      MouseDoubleClick="Grid1_MouseDoubleClick"
                      PreviewKeyDown="Grid1_PreviewKeyDown">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
                        <Setter Property="Foreground"      Value="{DynamicResource ThemeTextoSec}"/>
                        <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding"         Value="12,6"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- Color de selección propio (azul consistente, sin depender del
                     resaltado del sistema que cambiaba de tono al perder el foco)
                     + verde cuando está marcado con checkbox (gana sobre el azul).
                     Alto FIJO de fila (Height=34) para que la selección NO cambie el
                     tamaño de las filas, y SIN cambiar el FontWeight (que forzaba a WPF
                     a re-medir la fila y producía el "salto" con la virtualización). -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Height" Value="34"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeFilaSelGrid}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Seleccionado}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeFilaSeleccionada}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <!-- Checkbox visual (solo lectura) -->
                    <DataGridTemplateColumn Header="✓" Width="34">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Seleccionado, Mode=OneWay}"
                                          IsHitTestVisible="False" Focusable="False"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Orden de selección -->
                    <DataGridTextColumn Header="#" Binding="{Binding OrdenStr}" Width="36">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#EF4444"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Línea"               Binding="{Binding Linea}"       Width="55"/>
                    <DataGridTextColumn Header="Código"              Binding="{Binding Codigo}"      Width="80"/>
                    <DataGridTextColumn Header="Categoría"           Binding="{Binding Categoria}"   Width="120"/>
                    <DataGridTextColumn Header="Descripción Completa" Binding="{Binding Descripcion}" Width="*"/>
                    <DataGridTextColumn Header="Disponible"          Binding="{Binding Disponible, StringFormat=#\,##0.##}"  Width="90"
                                        ElementStyle="{StaticResource CeldaNumero}"/>
                    <DataGridTextColumn Header="Stock"               Binding="{Binding Stock,      StringFormat=#\,##0.##}"  Width="90"
                                        ElementStyle="{StaticResource CeldaNumero}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── Barra inferior: Informe Excel / exportar ── -->
            <Border Grid.Row="4"
                    Background="{DynamicResource ThemeBgSurface}"
                    BorderBrush="{DynamicResource ThemeBorde}"
                    BorderThickness="0,1,0,0"
                    Padding="14,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnInformeExcel" Content="Informe Excel"
                            Style="{StaticResource BtnSecundario}"
                            Margin="0,0,8,0" Click="BtnInformeExcel_Click"/>
                    <!-- Panel exportar (oculto por defecto) -->
                    <StackPanel x:Name="PanelExportar" Orientation="Horizontal"
                                Visibility="Collapsed" VerticalAlignment="Center">
                        <Button Content="Exportar Seleccionados" Style="{StaticResource BtnSuccess}"
                                Margin="0,0,8,0" Click="BtnExportar_Click"/>
                        <TextBlock x:Name="LblSeleccionados" VerticalAlignment="Center" FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#10B981"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
