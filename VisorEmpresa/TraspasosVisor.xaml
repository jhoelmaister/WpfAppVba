<UserControl x:Class="VisorEmpresa.TraspasosVisor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style x:Key="FiltroLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- ── Filtros ────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="🔄  Traspasos — toda la empresa (solo visualización)"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTexto}"/>
                    <TextBlock x:Name="LblResumen" Text=""
                               FontSize="11" Margin="0,2,0,0"
                               Foreground="{DynamicResource ThemeTextoSec}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Sucursal:" Style="{StaticResource FiltroLabel}"/>
                    <ComboBox x:Name="CmbSucursal" Width="220" Height="32" Margin="0,0,16,0"
                              SelectionChanged="Filtro_SelectionChanged"/>
                    <Button x:Name="BtnActualizar" Content="↻ Actualizar"
                            Height="32" FontSize="12" FontWeight="SemiBold" Padding="16,0"
                            Background="#1A73E8" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnActualizar_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Documentos ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <DataGrid x:Name="Grid1" IsReadOnly="True" AutoGenerateColumns="False"
                      HeadersVisibility="Column" CanUserAddRows="False"
                      GridLinesVisibility="Horizontal" RowHeight="28"
                      Background="Transparent" BorderThickness="0"
                      SelectionMode="Single"
                      SelectionChanged="Grid1_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Num}" Width="44"/>
                    <DataGridTextColumn Header="Documento" Binding="{Binding Codigo}" Width="95"/>
                    <DataGridTextColumn Header="Fecha" Binding="{Binding FechaTexto}" Width="90"/>
                    <DataGridTextColumn Header="Origen" Binding="{Binding Origen}" Width="*"/>
                    <DataGridTextColumn Header="Destino" Binding="{Binding Destino}" Width="*"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                    <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadTexto}" Width="90"
                                        ElementStyle="{StaticResource CeldaNumero}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── Líneas del documento seleccionado ──────────────────────── -->
        <Border Grid.Row="4" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="LblLineas" Grid.Row="0"
                           Text="Líneas del documento seleccionado"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource ThemeTextoSec}"/>
                <DataGrid x:Name="Grid2" Grid.Row="1" IsReadOnly="True" AutoGenerateColumns="False"
                          HeadersVisibility="Column" CanUserAddRows="False"
                          GridLinesVisibility="Horizontal" RowHeight="26"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Lín." Binding="{Binding Lin}" Width="50"/>
                        <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="95"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadTexto}" Width="90"
                                            ElementStyle="{StaticResource CeldaNumero}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
