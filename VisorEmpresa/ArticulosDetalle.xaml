<UserControl x:Class="VisorEmpresa.ArticulosDetalle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ReadOnlyBox" TargetType="Border">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBgReadOnly}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBordeInput}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="ReadOnlyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoMuted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeBtnSecFg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorde}"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4F8EF7"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ ENCABEZADO ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="36" Height="36" CornerRadius="8"
                        Background="#1A3A6B" Margin="0,0,12,0">
                    <TextBlock Text="&#x1F4E6;" FontSize="18" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="LblTitulo" Text="Artículo" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTexto}"/>
                    <TextBlock Text="Vista de solo lectura" FontSize="11"
                               Foreground="{DynamicResource ThemeTextoSec}" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ CONTENIDO ══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,16"
                      PanningMode="VerticalOnly">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ▸ CARD: IDENTIFICACIÓN  (col izq, fila 1) -->
                <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● IDENTIFICACIÓN"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="CÓDIGO"/>
                                <Border Style="{StaticResource ReadOnlyBox}">
                                    <TextBlock x:Name="Box_Codigo" Style="{StaticResource ReadOnlyText}"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="ÍNDICE"/>
                                <Border Style="{StaticResource ReadOnlyBox}">
                                    <TextBlock x:Name="Box_Indice" Style="{StaticResource ReadOnlyText}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ▸ CARD: CLASIFICACIÓN  (col der, filas 1-2) -->
                <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource CardBorder}" Margin="0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● CLASIFICACIÓN"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource SectionLabel}" Text="FAMILIA"/>
                            <Border Style="{StaticResource ReadOnlyBox}">
                                <TextBlock x:Name="Box_Familia" Style="{StaticResource ReadOnlyText}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource SectionLabel}" Text="INDUSTRIA"/>
                            <Border Style="{StaticResource ReadOnlyBox}">
                                <TextBlock x:Name="Box_Industria" Style="{StaticResource ReadOnlyText}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabel}" Text="CATEGORÍA"/>
                            <Border Style="{StaticResource ReadOnlyBox}">
                                <TextBlock x:Name="Box_Categoria" Style="{StaticResource ReadOnlyText}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ▸ CARD: DETALLES DEL ARTÍCULO  (col izq, fila 2) -->
                <Border Grid.Column="0" Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● DETALLES DEL ARTÍCULO"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource SectionLabel}" Text="DESCRIPCIÓN"/>
                            <Border Style="{StaticResource ReadOnlyBox}">
                                <TextBlock x:Name="Box_Descripcion" Style="{StaticResource ReadOnlyText}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabel}" Text="MODELO"/>
                            <Border Style="{StaticResource ReadOnlyBox}">
                                <TextBlock x:Name="Box_Modelo" Style="{StaticResource ReadOnlyText}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ▸ CARD: OBSERVACIONES  (ancho completo, fila 3) -->
                <Border Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="3"
                        Style="{StaticResource CardBorder}" Margin="0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="● OBSERVACIONES"/>
                        <Border MinHeight="70"
                                Background="{DynamicResource ThemeBgReadOnly}"
                                BorderBrush="{DynamicResource ThemeBordeInput}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="10,8">
                            <TextBlock x:Name="Box_Observacion"
                                       FontSize="13"
                                       Foreground="{DynamicResource ThemeTextoMuted}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>

        <!-- ══ BARRA DE ACCIONES ══════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,1,0,0"
                Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cerrar" Padding="18,0"
                        Style="{StaticResource BtnSecundario}"
                        Click="BtnCerrar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
