<Window x:Class="WpfAppVba.ConsolaMovimientos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visor Empresa"
        WindowState="Maximized"
        MinWidth="960" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemeBgPrincipal}"
        Closing="ConsolaVisor_Closing">

    <!-- NOTA: esta es la consola PROPIA del visor, pero declara la clase
         WpfAppVba.ConsolaMovimientos a propósito: los formularios vinculados de la
         app principal (PreciosGeneral, SucursalesGeneral, etc.) abren sus pestañas
         haciendo `Window.GetWindow(this) as ConsolaMovimientos` — al compilar esta
         clase (y NO vincular la consola original) dentro del ensamblado del visor,
         esos formularios funcionan sin tocar una línea de la app principal. -->

    <Window.Resources>

        <!-- ── Ítem de navegación lateral (mismo estilo que la app principal) ── -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0,12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Borde"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Borde" Property="Background" Value="{DynamicResource ThemeNavHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Borde" Property="Background" Value="{DynamicResource ThemeNavActivoBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- Top bar -->
            <RowDefinition Height="*"/>    <!-- Sidebar + Contenido -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- TOP BAR                                                      -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeBgTopBar}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo y título -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="8"
                            Background="#1A3A6B" Margin="0,0,10,0">
                        <TextBlock Text="VE" FontSize="13" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Visor Empresa"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeTexto}"/>
                        <TextBlock Text="Todas las sucursales de la empresa"
                                   FontSize="10" Foreground="{DynamicResource ThemeTextoSec}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Filtros globales / usuario / empresa / tema / conexión -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Herramientas de administración (mismas de Configuración en la
                         app principal): toda cuenta que entra al visor ya es admin,
                         así que se muestran siempre, sin gating adicional. -->
                    <Button x:Name="BtnRegenerarCodigos" Content="🔢 Regenerar códigos"
                            Height="30" FontSize="11" FontWeight="SemiBold" Padding="10,0"
                            Background="#6A1B9A" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                            Click="BtnRegenerarCodigos_Click"/>
                    <Button x:Name="BtnRecalcularPrecios" Content="💲 Recalcular precios"
                            Height="30" FontSize="11" FontWeight="SemiBold" Padding="10,0"
                            Background="#EF6C00" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                            Click="BtnRecalcularPrecios_Click"/>
                    <Button x:Name="BtnSincronizarAppsheets" Content="🧾 Sincronizar AppSheets"
                            Height="30" FontSize="11" FontWeight="SemiBold" Padding="10,0"
                            Background="#2E7D32" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,14,0"
                            Click="BtnSincronizarAppsheets_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource ThemeBorde}" Margin="0,0,14,0"/>

                    <!-- Empresa y Año: filtros GLOBALES — el dashboard y las vistas
                         de documentos cargan según estos dos combos. -->
                    <TextBlock Text="Empresa:" FontSize="11"
                               Foreground="{DynamicResource ThemeTextoSec}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CmbEmpresaTop" Width="200" Height="30"
                              VerticalAlignment="Center"
                              SelectionChanged="CmbEmpresaTop_SelectionChanged"/>

                    <TextBlock Text="Año:" FontSize="11"
                               Foreground="{DynamicResource ThemeTextoSec}"
                               VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <ComboBox x:Name="CmbAnioTop" Width="80" Height="30"
                              VerticalAlignment="Center"
                              SelectionChanged="CmbAnioTop_SelectionChanged"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource ThemeBorde}" Margin="10,0"/>

                    <TextBlock x:Name="LblUsuario"
                               FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"
                               VerticalAlignment="Center"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource ThemeBorde}" Margin="10,0"/>

                    <Button x:Name="BtnTema" Content="🌙"
                            Width="36" Height="30" FontSize="13"
                            Background="{DynamicResource ThemeBtnSecBg}"
                            Foreground="{DynamicResource ThemeBtnSecFg}"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                            ToolTip="Cambiar tema claro / oscuro"
                            Click="BtnTema_Click"/>

                    <!-- Estado de conexión -->
                    <Border x:Name="PillConexion"
                            VerticalAlignment="Center"
                            CornerRadius="10" Padding="12,4" Background="#2E7D32">
                        <TextBlock x:Name="LblConexion" Text="●  En línea"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- SIDEBAR + CONTENIDO                                         -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── BARRA LATERAL ──────────────────────────────────── -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeBgSidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Ítems de navegación -->
                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalOnly">
                        <StackPanel Margin="0,8,0,8">

                            <Button x:Name="BtnNav_Dashboard"
                                    Content="📊  Dashboard"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Dashboard_Click"/>
                            <Button x:Name="BtnNav_Articulos"
                                    Content="📋  Artículos"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Articulos_Click"/>

                            <Rectangle Height="1" Fill="{DynamicResource ThemeBorde}" Margin="12,8"/>

                            <!-- Documentos: solo visualización (sin filtro por sucursal) -->
                            <Button x:Name="BtnNav_Pedidos"
                                    Content="📑  Pedidos"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Pedidos_Click"/>
                            <Button x:Name="BtnNav_Traspasos"
                                    Content="🔄  Traspasos"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Traspasos_Click"/>
                            <Button x:Name="BtnNav_Correcciones"
                                    Content="🔧  Correcciones"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Correcciones_Click"/>
                            <Button x:Name="BtnNav_Facturas"
                                    Content="🧾  Facturas"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Facturas_Click"/>

                            <Rectangle Height="1" Fill="{DynamicResource ThemeBorde}" Margin="12,8"/>

                            <!-- Catálogos de empresa: edición completa -->
                            <Button x:Name="BtnNav_Precios"
                                    Content="💲  Precios"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Precios_Click"/>
                            <Button x:Name="BtnNav_Empresas"
                                    Content="🏢  Empresas"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Empresas_Click"/>
                            <Button x:Name="BtnNav_Sucursales"
                                    Content="🏪  Sucursales"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Sucursales_Click"/>
                            <Button x:Name="BtnNav_Regiones"
                                    Content="🌐  Regiones"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Regiones_Click"/>
                            <Button x:Name="BtnNav_Usuarios"
                                    Content="👤  Usuarios"
                                    Style="{StaticResource NavBtn}"
                                    Click="BtnNav_Usuarios_Click"/>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Cerrar sesión (fijo al fondo) -->
                    <Border Grid.Row="1"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource ThemeBorde}">
                        <Button Content="⏻  Cerrar Sesión"
                                Style="{StaticResource NavBtn}"
                                Foreground="#EF5350"
                                Click="BtnCerrarSesion_Click"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── ÁREA DE CONTENIDO ──────────────────── -->
            <TabControl x:Name="TabContenido" Grid.Column="1"
                        Background="{DynamicResource ThemeBgContenido}"
                        BorderThickness="0" Padding="0">
                <!-- Pestaña fija: título y contenido cambian según el menú lateral -->
                <TabItem x:Name="TabFijo">
                    <TabItem.Header>
                        <TextBlock x:Name="TabFijoTitulo" Text="Dashboard"
                                   VerticalAlignment="Center"/>
                    </TabItem.Header>
                    <ContentControl x:Name="TabFijoContenido"/>
                </TabItem>
            </TabControl>
        </Grid>

    </Grid>

</Window>
