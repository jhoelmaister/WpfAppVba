<UserControl x:Class="VisorEmpresa.FacturasGeneral"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>

        <!-- ── Botones base ── -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="11,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"    Value="{DynamicResource ThemeBtnSecBg}"/>
            <Setter Property="Foreground"    Value="{DynamicResource ThemeBtnSecFg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource ThemeBorde}"/>
        </Style>

        <!-- ── Tarjeta métrica ── -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"    Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource ThemeBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"  Value="8"/>
            <Setter Property="Padding"       Value="12,10"/>
        </Style>

        <!-- ── Radio de filtro (sidebar) ── -->
        <Style x:Key="FilterRadio" TargetType="RadioButton">
            <Setter Property="FontSize"                Value="11"/>
            <Setter Property="Margin"                  Value="0,1"/>
            <Setter Property="Foreground"              Value="{DynamicResource ThemeTextoSec}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── Badge de estado (entrega) en DataGrid ── -->
        <DataTemplate x:Key="BadgeEstado">
            <Border Padding="6,2" CornerRadius="10" HorizontalAlignment="Left">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Estado}" Value="entregado">
                                <Setter Property="Background" Value="#D1FAE5"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="pendiente">
                                <Setter Property="Background" Value="#FEE2E2"/>
                            </DataTrigger>
                        </Style.Triggers>
                        <Setter Property="Background" Value="{DynamicResource ThemeBgReadOnly}"/>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Estado}" Value="entregado">
                                    <Setter Property="Foreground" Value="#065F46"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Estado}" Value="pendiente">
                                    <Setter Property="Foreground" Value="#991B1B"/>
                                </DataTrigger>
                            </Style.Triggers>
                            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>

        <!-- ── Badge de estado de cuenta (cobro) en DataGrid ── -->
        <DataTemplate x:Key="BadgeEstadoC">
            <Border Padding="6,2" CornerRadius="10" HorizontalAlignment="Left">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EstadoC}" Value="cancelado">
                                <Setter Property="Background" Value="#D1FAE5"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding EstadoC}" Value="pendiente">
                                <Setter Property="Background" Value="#FEE2E2"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding EstadoC}" Value="pendiente parcial">
                                <Setter Property="Background" Value="#FEF3C7"/>
                            </DataTrigger>
                        </Style.Triggers>
                        <Setter Property="Background" Value="{DynamicResource ThemeBgReadOnly}"/>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding EstadoC}" FontSize="11" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EstadoC}" Value="cancelado">
                                    <Setter Property="Foreground" Value="#065F46"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EstadoC}" Value="pendiente">
                                    <Setter Property="Foreground" Value="#991B1B"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EstadoC}" Value="pendiente parcial">
                                    <Setter Property="Foreground" Value="#92400E"/>
                                </DataTrigger>
                            </Style.Triggers>
                            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>

        <!-- ── Badge de movimiento (venta/compra) en DataGrid ── -->
        <DataTemplate x:Key="BadgeMovimiento">
            <Border Padding="6,2" CornerRadius="4" HorizontalAlignment="Left">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Movimiento}" Value="venta">
                                <Setter Property="Background" Value="#FEE2E2"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Movimiento}" Value="compra">
                                <Setter Property="Background" Value="#D1FAE5"/>
                            </DataTrigger>
                        </Style.Triggers>
                        <Setter Property="Background" Value="{DynamicResource ThemeBgReadOnly}"/>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Movimiento}" FontSize="11" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Movimiento}" Value="venta">
                                    <Setter Property="Foreground" Value="#991B1B"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Movimiento}" Value="compra">
                                    <Setter Property="Foreground" Value="#065F46"/>
                                </DataTrigger>
                            </Style.Triggers>
                            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="152"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- SIDEBAR                                                   -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,8,0,12">

                    <!-- Árbol de meses -->
                    <TextBlock Text="PERIODO"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeTextoSec}"
                               Margin="12,0,0,6"/>
                    <Border BorderBrush="{DynamicResource ThemeBorde}"
                            BorderThickness="1" Margin="8,0">
                        <TreeView x:Name="Tree1"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  SelectedItemChanged="Tree1_SelectedItemChanged"
                                  PreviewMouseLeftButtonDown="Tree1_PreviewMouseLeftButtonDown"
                                  FontSize="12"/>
                    </Border>

                    <!-- Separador -->
                    <Rectangle Height="1" Fill="{DynamicResource ThemeBorde}" Margin="8,10"/>

                    <!-- Filtro Estado -->
                    <TextBlock Text="ESTADO"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeTextoSec}"
                               Margin="12,0,0,6"/>
                    <StackPanel Margin="12,0">
                        <RadioButton x:Name="BtnFiltroTodos"
                                     Content="Todos" IsChecked="True"
                                     GroupName="EstadoF"
                                     Style="{StaticResource FilterRadio}"
                                     Checked="FiltroEstado_Checked"/>
                        <RadioButton x:Name="BtnFiltroPendiente"
                                     Content="Pendiente"
                                     GroupName="EstadoF"
                                     Style="{StaticResource FilterRadio}"
                                     Checked="FiltroEstado_Checked"/>
                        <RadioButton x:Name="BtnFiltroEntregado"
                                     Content="Entregado"
                                     GroupName="EstadoF"
                                     Style="{StaticResource FilterRadio}"
                                     Checked="FiltroEstado_Checked"/>
                    </StackPanel>

                    <!-- Separador -->
                    <Rectangle Height="1" Fill="{DynamicResource ThemeBorde}" Margin="8,10"/>

                    <!-- Filtro Cuenta -->
                    <TextBlock Text="CUENTA"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeTextoSec}"
                               Margin="12,0,0,6"/>
                    <StackPanel Margin="12,0">
                        <RadioButton x:Name="BtnCuentaTodos"
                                     Content="Todos" IsChecked="True"
                                     GroupName="CuentaF"
                                     Style="{StaticResource FilterRadio}"
                                     Checked="FiltroCuenta_Checked"/>
                        <RadioButton x:Name="BtnCuentaPendiente"
                                     Content="Pendiente"
                                     GroupName="CuentaF"
                                     Style="{StaticResource FilterRadio}"
                                     Checked="FiltroCuenta_Checked"/>
                        <RadioButton x:Name="BtnCuentaCancelado"
                                     Content="Cancelado"
                                     GroupName="CuentaF"
                                     Style="{StaticResource FilterRadio}"
                                     Checked="FiltroCuenta_Checked"/>
                        <RadioButton x:Name="BtnCuentaParcial"
                                     Content="Pendiente parcial"
                                     GroupName="CuentaF"
                                     Style="{StaticResource FilterRadio}"
                                     Checked="FiltroCuenta_Checked"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- ÁREA PRINCIPAL                                           -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Top bar -->
                <RowDefinition Height="Auto"/>  <!-- Métricas -->
                <RowDefinition Height="Auto"/>  <!-- Búsqueda + botones -->
                <RowDefinition Height="*"/>     <!-- DataGrid principal -->
                <RowDefinition Height="Auto"/>  <!-- Panel detalle líneas -->
            </Grid.RowDefinitions>

            <!-- ── Top bar ── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource ThemeBgSurface}"
                    BorderBrush="{DynamicResource ThemeBorde}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Facturas"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTexto}"/>
                        <TextBlock x:Name="LblSubtitulo"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeTextoSec}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Sucursal:"
                                   FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextoSec}"
                                   Margin="0,0,6,0"/>
                        <ComboBox x:Name="CmbSucursal"
                                  Width="180" Height="28" FontSize="12" Margin="0,0,16,0"
                                  SelectionChanged="Filtro_SelectionChanged"/>
                        <TextBlock Text="Movimiento:"
                                   FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextoSec}"
                                   Margin="0,0,6,0"/>
                        <ComboBox x:Name="CboTipoMovimiento"
                                  Width="100" Height="28" FontSize="12"
                                  SelectionChanged="CboTipoMovimiento_SelectionChanged">
                            <ComboBoxItem Content="Todos" IsSelected="True"/>
                            <ComboBoxItem Content="Ventas"/>
                            <ComboBoxItem Content="Compras"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Métricas ── -->
            <Grid Grid.Row="1" Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="Total importe"
                                   FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtTotalImporte"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTexto}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="Documentos"
                                   FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtTotalDocumentos"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTexto}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="Estados pendientes"
                                   FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtEstadosPendientes"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="#EF4444"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="Cuentas pendientes"
                                   FontSize="11" Foreground="{DynamicResource ThemeTextoSec}"/>
                        <TextBlock x:Name="TxtCuentasPendientes"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="#F59E0B"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Búsqueda + botones ── -->
            <Border Grid.Row="2"
                    Background="{DynamicResource ThemeBgSurface}"
                    BorderBrush="{DynamicResource ThemeBorde}"
                    BorderThickness="0,1,0,1"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Buscador con ícono embebido -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource ThemeInputBg}"
                            BorderBrush="{DynamicResource ThemeBordeInput}"
                            BorderThickness="1" CornerRadius="6"
                            Margin="0,0,10,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍"
                                       FontSize="12" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeTextoSec}"
                                       IsHitTestVisible="False"/>
                            <TextBox x:Name="TxtBuscar"
                                     Grid.Column="1"
                                     Height="30" FontSize="12"
                                     Padding="4,0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     KeyDown="TxtBuscar_KeyDown"/>
                            <Button Grid.Column="2" Content="Buscar"
                                    Height="30" Padding="10,0" FontSize="12"
                                    Background="#3B82F6" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnBuscar_Click"/>
                        </Grid>
                    </Border>

                    <!-- Solo lectura: sin Nueva/Editar/Eliminar, únicamente Actualizar -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Actualizar"
                                Style="{StaticResource BtnSecundario}"
                                Click="BtnActualizar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── DataGrid principal ── -->
            <DataGrid x:Name="Grid1" Grid.Row="3"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="{DynamicResource ThemeBorde}"
                      BorderThickness="0"
                      FontSize="12"
                      RowHeight="34"
                      SelectionChanged="Grid1_SelectionChanged"
                      MouseDoubleClick="Grid1_MouseDoubleClick"
                      PreviewKeyDown="Grid1_PreviewKeyDown">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="{DynamicResource ThemeBgSurface}"/>
                        <Setter Property="Foreground"      Value="{DynamicResource ThemeTextoSec}"/>
                        <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorde}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding"         Value="12,6"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"
                                        Binding="{Binding Linea}"
                                        Width="46">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"         Value="{DynamicResource ThemeTextoSec}"/>
                                <Setter Property="VerticalAlignment"  Value="Center"/>
                                <Setter Property="Margin"             Value="12,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Documento"
                                        Binding="{Binding Codigo}"
                                        Width="88">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight"        Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin"            Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Columna Movimiento con badge -->
                    <DataGridTemplateColumn Header="Movimiento" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ContentPresenter Content="{Binding}"
                                                  ContentTemplate="{StaticResource BadgeMovimiento}"
                                                  Margin="4,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Fecha"
                                        Binding="{Binding FechaStr}"
                                        Width="148"/>

                    <DataGridTextColumn Header="Sucursal"
                                        Binding="{Binding SucursalDesc}"
                                        Width="130"/>

                    <DataGridTextColumn Header="Cliente / Proveedor"
                                        Binding="{Binding TerceroDesc}"
                                        Width="*"/>

                    <!-- Columna Estado (entrega) con badge -->
                    <DataGridTemplateColumn Header="Estado" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ContentPresenter Content="{Binding}"
                                                  ContentTemplate="{StaticResource BadgeEstado}"
                                                  Margin="4,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Columna Estado de cuenta (cobro) con badge -->
                    <DataGridTemplateColumn Header="Cuenta" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ContentPresenter Content="{Binding}"
                                                  ContentTemplate="{StaticResource BadgeEstadoC}"
                                                  Margin="4,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Importe"
                                        Binding="{Binding ImporteTotal, StringFormat=#\,##0.00}"
                                        Width="100"
                                        ElementStyle="{StaticResource CeldaNumero}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── Panel detalle líneas (siempre visible) ── -->
            <Border x:Name="PanelDetalle" Grid.Row="4"
                    Background="{DynamicResource ThemeBgSurface}"
                    BorderBrush="#7C3AED"
                    BorderThickness="0,2,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="120"/>
                    </Grid.RowDefinitions>

                    <!-- Cabecera panel detalle con fondo violeta -->
                    <Border Grid.Row="0"
                            Background="#7C3AED"
                            Padding="14,7">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▸"
                                       FontSize="12" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="LblDetalleHeader"
                                       Text="Líneas del documento"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Grid detalle -->
                    <DataGrid x:Name="Lista2" Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Background="Transparent"
                              FontSize="11">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="#5B21B6"/>
                                <Setter Property="Foreground"      Value="White"/>
                                <Setter Property="BorderBrush"     Value="#7C3AED"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="Padding"         Value="12,5"/>
                                <Setter Property="FontSize"        Value="10"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Lín."
                                                Binding="{Binding Linea}"       Width="40"/>
                            <DataGridTextColumn Header="Concepto"
                                                Binding="{Binding Concepto}"    Width="*"/>
                            <DataGridTextColumn Header="Categoría"
                                                Binding="{Binding Categoria}"   Width="140"/>
                            <DataGridTextColumn Header="Importe"
                                                Binding="{Binding Importe, StringFormat=#\,##0.00}"
                                                Width="90"
                                                ElementStyle="{StaticResource CeldaNumero}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
