<UserControl x:Class="VisorEmpresa.DashboardVisor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource ThemeBgPrincipal}">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4F8EF7"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeBgSurface}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
        </Style>

        <!-- Chip segmentador (selección única, RadioButton): color lleno cuando
             está activo, atenuado cuando está inactivo. Color por instancia. -->
        <Style x:Key="Segmentador" TargetType="ToggleButton">
            <Setter Property="Height" Value="62"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chip" CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                Padding="16,8">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Chip" Property="Opacity" Value="0.32"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chip" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipTitulo" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Opacity" Value="0.92"/>
        </Style>
        <Style x:Key="ChipValor" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="KpiTitulo" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextoSec}"/>
        </Style>
        <Style x:Key="KpiValor" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTexto}"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ BARRA DE FILTROS ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeBgSurface}"
                BorderBrush="{DynamicResource ThemeBorde}" BorderThickness="0,0,0,1"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Totales en cantidad de toda la empresa"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeTextoSec}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnActualizar" Content="↻ Actualizar"
                            Height="32" FontSize="12" FontWeight="SemiBold" Padding="16,0"
                            Background="#1A73E8" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnActualizar_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ CONTENIDO: escala como zoom (Viewbox) según el tamaño de la ventana ══ -->
        <Viewbox Grid.Row="1" Margin="20,16,20,16" Stretch="Fill">
            <!-- Tamaño de diseño fijo: el Viewbox escala TODO el conjunto de forma
                 proporcional; nada se recorta al achicar la ventana. -->
            <Grid Width="1600" Height="860">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Segmentadores + KPIs -->
                    <RowDefinition Height="*"/>      <!-- Gráficos -->
                </Grid.RowDefinitions>

                <!-- ▸ SEGMENTADORES (izquierda) + KPIs (derecha) -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Segmentadores -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="● SEGMENTADORES"/>
                        <WrapPanel>
                            <RadioButton x:Name="TglVentas" GroupName="segVisor" IsChecked="True"
                                         Style="{StaticResource Segmentador}" Background="#E53935"
                                         Checked="Segmentador_Changed">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource ChipTitulo}" Text="🛒  Ventas"/>
                                    <TextBlock x:Name="LblVentasVal" Style="{StaticResource ChipValor}" Text="0"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="TglCompras" GroupName="segVisor"
                                         Style="{StaticResource Segmentador}" Background="#1E88E5"
                                         Checked="Segmentador_Changed">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource ChipTitulo}" Text="📥  Compras"/>
                                    <TextBlock x:Name="LblComprasVal" Style="{StaticResource ChipValor}" Text="0"/>
                                </StackPanel>
                            </RadioButton>
                        </WrapPanel>
                    </StackPanel>

                    <!-- KPIs (a la derecha de los segmentadores) -->
                    <Grid Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource KpiTitulo}" Text="UNIDADES (SEGMENTO ACTIVO)"/>
                                <TextBlock x:Name="LblUnidadesSeg" Style="{StaticResource KpiValor}" Text="0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource KpiTitulo}" Text="DOCUMENTOS"/>
                                <TextBlock x:Name="LblDocumentos" Style="{StaticResource KpiValor}" Text="0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource KpiTitulo}" Text="ARTÍCULOS DISTINTOS"/>
                                <TextBlock x:Name="LblArticulos" Style="{StaticResource KpiValor}" Text="0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="6" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource KpiTitulo}" Text="SUCURSALES CON MOVIMIENTO"/>
                                <TextBlock x:Name="LblSucursalesMov" Style="{StaticResource KpiValor}" Text="0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="8" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource KpiTitulo}" Text="TRASPASOS INTERNOS (UNID.)"/>
                                <TextBlock x:Name="LblTraspasos" Style="{StaticResource KpiValor}" Text="0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ▸ GRÁFICOS · Col1: mes+categoría (arriba) + categoría (abajo)
                                · Col2: participación por sucursal (columna completa) -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <!-- Col 1 · Fila 1: CANTIDAD POR MES Y CATEGORÍA -->
                    <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}" Text="● CANTIDAD POR MES Y CATEGORÍA"/>
                            <WrapPanel Grid.Row="1" x:Name="PanelLeyenda" Margin="0,0,0,10"/>
                            <Grid Grid.Row="2">
                                <TextBlock x:Name="LblMesesVacio" Text="Sin datos para el segmento activo."
                                           FontSize="12" Foreground="{DynamicResource ThemeTextoSec}"
                                           Visibility="Collapsed"/>
                                <Grid x:Name="ZonaMeses">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Canvas x:Name="PanelEjeY" Grid.Column="0" Width="48"
                                            VerticalAlignment="Top"/>
                                    <!-- Scroll horizontal si los meses no caben; el eje Y queda fijo. -->
                                    <ScrollViewer Grid.Column="1"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled">
                                        <Grid x:Name="PanelPlot" SizeChanged="PanelPlot_SizeChanged">
                                            <Canvas x:Name="PanelGrid"/>
                                            <StackPanel x:Name="PanelMeses" Orientation="Horizontal"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Col 1 · Fila 3: TOTAL POR CATEGORÍA -->
                    <Border Grid.Column="0" Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Style="{StaticResource SectionHeader}" Text="● TOTAL POR CATEGORÍA"/>
                                <TextBlock x:Name="LblCategoriasVacio" Text="Sin datos para el segmento activo."
                                           FontSize="12" Foreground="{DynamicResource ThemeTextoSec}"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="PanelCategorias"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Col 2 · Filas 1-3: PARTICIPACIÓN POR SUCURSAL -->
                    <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="3"
                            Style="{StaticResource CardBorder}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Style="{StaticResource SectionHeader}" Text="● PARTICIPACIÓN POR SUCURSAL"/>
                                <TextBlock x:Name="LblSucursalesVacio" Text="Sin datos para el segmento activo."
                                           FontSize="12" Foreground="{DynamicResource ThemeTextoSec}"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="PanelSucursales"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>
