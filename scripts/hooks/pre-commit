#!/bin/sh
# Bloquea commits en ramas que empiezan con "claude/".
branch=$(git symbolic-ref --short HEAD 2>/dev/null)

case "$branch" in
  claude/*)
    echo "ERROR: no se permiten commits en ramas 'claude/*' (rama actual: $branch)." >&2
    echo "Cambia a otra rama antes de hacer commit." >&2
    exit 1
    ;;
esac

exit 0
